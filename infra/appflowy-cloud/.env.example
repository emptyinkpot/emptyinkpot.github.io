# AppFlowy Cloud target runtime for Project Studio.
# Copy to .env on the server and fill real secrets there. Do not commit .env.

APPFLOWY_PUBLIC_HOST=project.tengokukk.com
APPFLOWY_BASE_URL=https://project.tengokukk.com
APPFLOWY_WEBSOCKET_BASE_URL=wss://project.tengokukk.com/ws

# Existing host Nginx already owns 80/443. Keep AppFlowy internal Nginx on loopback.
NGINX_PORT=127.0.0.1:18080
NGINX_TLS_PORT=127.0.0.1:18443

# Startup gate.
MIN_FREE_GB=40
EXPECTED_SERVER_IP=124.220.233.126

# AppFlowy upstream checkout. Keep the official repo as a nested runtime source,
# not as MyBlog source code.
APPFLOWY_CLOUD_REPO=https://github.com/AppFlowy-IO/AppFlowy-Cloud.git
APPFLOWY_CLOUD_REF=main
APPFLOWY_CLOUD_UPSTREAM_DIR=upstream

# Fill these in the upstream .env after cloning AppFlowy-Cloud.
GOTRUE_ADMIN_EMAIL=
GOTRUE_ADMIN_PASSWORD=
GOTRUE_JWT_SECRET=
POSTGRES_PASSWORD=
APPFLOWY_S3_ACCESS_KEY=
APPFLOWY_S3_SECRET_KEY=
