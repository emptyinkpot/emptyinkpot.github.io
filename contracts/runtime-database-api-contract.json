{
  "schemaVersion": 1,
  "name": "myblog-runtime-database-api-contract",
  "updatedAt": "2026-05-10",
  "apiBoundary": {
    "serviceOwner": "apps/admin-next",
    "dbOwner": "apps/admin-next/lib/runtime-db.js",
    "dbBackend": "Tencent Cloud CynosDB MySQL 8.0",
    "browserRule": "browser must never connect to MySQL directly"
  },
  "basePath": "/api/runtime",
  "routes": [
    {
      "method": "GET",
      "path": "/api/runtime/reader/memory",
      "purpose": "list or fetch reader memory"
    },
    {
      "method": "POST",
      "path": "/api/runtime/reader/memory",
      "purpose": "upsert reader memory"
    },
    {
      "method": "GET",
      "path": "/api/runtime/reader/highlights",
      "purpose": "list reader highlights"
    },
    {
      "method": "POST",
      "path": "/api/runtime/reader/highlights",
      "purpose": "upsert reader highlights"
    },
    {
      "method": "GET",
      "path": "/api/runtime/visuals/snapshot",
      "purpose": "read visual runtime snapshot"
    },
    {
      "method": "POST",
      "path": "/api/runtime/visuals/sync",
      "purpose": "sync visual runtime snapshot"
    }
  ],
  "responseEnvelope": {
    "success": {
      "ok": true,
      "items": [],
      "item": null
    },
    "error": {
      "ok": false,
      "error": "message"
    }
  },
  "tables": [
    {
      "name": "reader_memory",
      "purpose": "reading progress and location state",
      "keyFields": ["object_id"],
      "mutableFields": ["progress", "location_json", "scroll_top", "last_read_at", "updated_at"]
    },
    {
      "name": "reader_highlights",
      "purpose": "reading annotations",
      "keyFields": ["id"],
      "mutableFields": ["title", "text", "color", "note", "anchor_json", "updated_at"]
    },
    {
      "name": "visual_sources",
      "purpose": "visual source registry",
      "keyFields": ["id"],
      "mutableFields": ["provider_config_json", "last_cursor", "last_synced_at", "sync_status", "pins_snapshot_hash", "last_error", "updated_at"]
    },
    {
      "name": "visual_pins",
      "purpose": "visual source items",
      "keyFields": ["source_id", "pin_id"],
      "mutableFields": ["position_index", "downloaded", "raw_json", "last_seen_at", "deleted_at"]
    },
    {
      "name": "visual_sync_runs",
      "purpose": "visual sync history",
      "keyFields": ["id"],
      "mutableFields": ["status", "synced_items", "active_items", "snapshot_hash", "error", "finished_at"]
    },
    {
      "name": "personal_secret_entries",
      "purpose": "plaintext operator secret storage by user requirement",
      "keyFields": ["id"],
      "mutableFields": ["namespace", "label", "account", "secret_type", "secret_value", "url", "note", "tags_json", "metadata_json", "visibility", "updated_at", "last_used_at", "deleted_at"]
    }
  ],
  "constraints": {
    "mustNotStore": [
      "article bodies",
      "EPUB/PDF/image/video blobs",
      "OpenList files",
      "COS objects",
      "Quark files",
      "Astro dist",
      "Pagefind output",
      "Syncthing hot mirror data"
    ],
    "transport": [
      "HTTP API only for browser clients",
      "MySQL only inside admin-next service"
    ]
  },
  "externalServicePattern": {
    "recommendedShapes": [
      "GET /api/v1/health",
      "GET /api/v1/schema",
      "GET /api/v1/tables/:table",
      "POST /api/v1/tables/:table/query",
      "POST /api/v1/tables/:table/insert",
      "PATCH /api/v1/tables/:table/:id",
      "DELETE /api/v1/tables/:table/:id"
    ],
    "sidecarCandidates": [
      "NocoDB",
      "Directus",
      "Supabase",
      "PocketBase"
    ]
  }
}
