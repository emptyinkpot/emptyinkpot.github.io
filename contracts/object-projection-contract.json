{
  "schemaVersion": 1,
  "name": "myblog-object-projection-contract",
  "updatedAt": "2026-05-08",
  "coreObject": "KnowledgeObject",
  "rule": "Objects define projections. Pages do not define object semantics.",
  "objectTypes": [
    "MarkdownObject",
    "BookObject",
    "VisualObject",
    "ProjectObject",
    "MusicObject",
    "GitHubObject",
    "KnowledgeCollection"
  ],
  "projections": {
    "home": {
      "surface": "mixed object feed",
      "form": "preview card"
    },
    "drawer": {
      "surface": "ReaderSession",
      "form": "active object content plus compact context"
    },
    "search": {
      "surface": "command/search overlay",
      "form": "compact result"
    },
    "graph": {
      "surface": "knowledge graph",
      "form": "node/link projection"
    },
    "collection": {
      "surface": "context lens",
      "form": "toc item or contextual member"
    }
  },
  "typeSpecificProjectionGrammar": {
    "BookObject": {
      "identity": [
        "KnowledgeObject",
        "ReadingObject"
      ],
      "home": "cover-first book card",
      "collection": "Shelf Surface, not article ReadingSession",
      "drawer": "book reader surface with cover, metadata and reader mount",
      "coverProjection": "book.cover || /api/openlist/cover?path=...&modified=...&size=...",
      "readingProjection": {
        "shelf": "cover-dominant thematic rows",
        "compact": "spine-oriented compact shelf",
        "reading": "continue-reading lane with progress"
      },
      "mustPreserve": [
        "real cover projection",
        "defaultBookSettings as public bookshelf directory authority",
        "home-feed-card--book",
        "data-book-projection=shelf",
        "data-bookshelf-surface",
        "BookCover generated cover fallback",
        "reader drawer mount",
        "ReaderMemory progress projection"
      ],
      "forbidden": [
        "BookObject rendered as text-only GenericCard",
        "books collection rendered as article list",
        "localStorage book settings changing public bookshelf source path",
        "allowGeneratedCover={false} on homepage RuntimeBookFeed",
        "title poster pretending to be a real cover",
        "raw source prefetch on homepage idle"
      ]
    }
  },
  "antiPatterns": [
    "one page owns one object type",
    "collection page owns object existence",
    "card grid replaces reader",
    "directory structure becomes UI taxonomy without projection"
  ]
}
