---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCategoryCounts, toSlug } from '../../lib/content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const categories = getCategoryCounts(posts);
---

<BaseLayout title="Categories / emptyinkpot" description="按分类浏览 site-v2 中的文章内容。">
  <main class="space-y-8 pb-10 pt-8 md:pt-14" data-pagefind-body>
    <section class="space-y-4">
      <p class="section-kicker">Categories</p>
      <h1 class="section-title text-4xl md:text-5xl">分类入口</h1>
      <p class="max-w-3xl text-base leading-8 text-stone-600">
        分类页是结构化浏览的第一层入口，用来承接首页的 Topics 区块。
      </p>
    </section>

    <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        categories.map(([category, count]) => (
          <a class="card-stack rounded-[2rem] p-6" href={`/categories/${toSlug(category)}/`}>
            <p class="section-kicker mb-3">Category</p>
            <h2 class="text-2xl font-semibold text-stone-950">{category}</h2>
            <p class="mt-3 text-sm leading-7 text-stone-600">{count} 篇文章</p>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
