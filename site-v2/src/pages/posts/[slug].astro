---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import GiscusComments from '../../components/post/GiscusComments.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  formatDate,
  getExcerptFromBody,
  getPrimaryCategory,
  getReadingTime,
  getRelatedPosts,
  sortPosts,
  toSlug
} from '../../lib/content';
import { getPostCover } from '../../lib/postCovers';
import { withBase } from '../../lib/site';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));

  return posts.map((post) => ({
    params: { slug: post.id },
    props: {
      post,
      posts
    }
  }));
}

const { post, posts } = Astro.props as {
  post: CollectionEntry<'posts'>;
  posts: CollectionEntry<'posts'>[];
};

const { Content, headings } = await render(post);
const currentIndex = posts.findIndex((entry) => entry.id === post.id);
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderPost = currentIndex < posts.length - 1 ? posts[currentIndex + 1] : undefined;
const relatedPosts = getRelatedPosts(post, posts);
const description = post.data.description ?? getExcerptFromBody(post.body, 160);
const primaryCategory = getPrimaryCategory(post);
const seriesPosts = post.data.series ? posts.filter((entry) => entry.data.series === post.data.series) : [];
const cover = getPostCover(post);
---

<BaseLayout title={`${post.data.title} / emptyinkpot`} description={description}>
  <main class="space-y-8 pb-10 pt-8 md:space-y-12 md:pt-14" data-pagefind-body>
    <section class="glass-card rounded-[2.25rem] p-6 md:p-8">
      <a class="section-kicker mb-4 inline-flex transition hover:text-stone-950" href={withBase(`/categories/${toSlug(primaryCategory)}/`)}>
        {primaryCategory}
      </a>
      <h1 class="max-w-4xl text-3xl font-semibold leading-tight text-stone-950 md:text-5xl">
        {post.data.title}
      </h1>

      <div class="mt-6 flex flex-wrap items-center gap-3 text-sm text-stone-600">
        <span class="pill">{formatDate(post.data.date)}</span>
        <span class="pill">{getReadingTime(post.body)} min read</span>
        {
          post.data.series && (
            <a class="pill" href={withBase(`/series/${toSlug(post.data.series)}/`)}>
              系列 · {post.data.series}
            </a>
          )
        }
        {
          post.data.tags.map((tag) => (
            <a class="pill" href={withBase(`/tags/${toSlug(tag)}/`)} key={tag}>
              {tag}
            </a>
          ))
        }
      </div>
    </section>

    {
      cover && (
        <section class="glass-card overflow-hidden rounded-[2.25rem] p-2 md:p-3">
          <img class="w-full rounded-[1.7rem]" src={cover} alt="" loading="eager" />
        </section>
      )
    }

    <section class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_280px]">
      <article class="prose-shell order-2 rounded-[2rem] lg:order-1">
        <Content />
      </article>

      <aside class="order-1 lg:order-2">
        <div class="toc-card sticky top-6 rounded-[2rem] p-5">
          <p class="section-kicker mb-4">On This Page</p>
          {
            headings.length ? (
              <ul class="space-y-3 text-sm text-stone-600">
                {headings
                  .filter((heading) => heading.depth <= 3)
                  .map((heading) => (
                    <li class:list={[heading.depth > 2 && 'pl-4']}>
                      <a href={`#${heading.slug}`}>{heading.text}</a>
                    </li>
                  ))}
              </ul>
            ) : (
              <p class="text-sm leading-7 text-stone-500">这篇文章当前没有可展示的目录。</p>
            )
          }
        </div>
      </aside>
    </section>

    {
      post.data.series && (
        <section class="glass-card rounded-[2rem] p-6">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Series Navigation</p>
              <h2 class="section-title">继续阅读「{post.data.series}」</h2>
            </div>
            <a class="text-sm text-stone-600 transition hover:text-stone-950" href={withBase(`/series/${toSlug(post.data.series)}/`)}>
              系列总览
            </a>
          </div>

          <div class="mt-6 grid gap-3">
            {seriesPosts.map((entry, index) => (
              <a
                class:list={[
                  'card-stack flex items-center justify-between gap-4 rounded-[1.5rem] p-4',
                  entry.id === post.id && 'border-stone-900/20 bg-white/90'
                ]}
                href={withBase(`/posts/${entry.id}/`)}
              >
                <div>
                  <p class="section-kicker mb-2">Chapter {index + 1}</p>
                  <h3 class="text-lg font-medium text-stone-950">{entry.data.title}</h3>
                </div>
                <span class="pill">{entry.id === post.id ? '当前' : formatDate(entry.data.date)}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section class="grid gap-5 md:grid-cols-2">
      <div class="glass-card rounded-[2rem] p-6">
        <p class="section-kicker mb-3">Newer</p>
        {
          newerPost ? (
            <a class="text-lg font-medium text-stone-900 transition hover:text-stone-600" href={withBase(`/posts/${newerPost.id}/`)}>
              {newerPost.data.title}
            </a>
          ) : (
            <p class="text-sm text-stone-500">已经是最新一篇。</p>
          )
        }
      </div>
      <div class="glass-card rounded-[2rem] p-6">
        <p class="section-kicker mb-3">Older</p>
        {
          olderPost ? (
            <a class="text-lg font-medium text-stone-900 transition hover:text-stone-600" href={withBase(`/posts/${olderPost.id}/`)}>
              {olderPost.data.title}
            </a>
          ) : (
            <p class="text-sm text-stone-500">已经是最早一篇。</p>
          )
        }
      </div>
    </section>

    {
      relatedPosts.length > 0 && (
        <section class="space-y-5">
          <div>
            <p class="section-kicker">Related</p>
            <h2 class="section-title">相关文章</h2>
          </div>
          <div class="grid gap-5 md:grid-cols-3">
            {relatedPosts.map((relatedPost) => (
              <a class="card-stack rounded-[1.75rem] p-5" href={withBase(`/posts/${relatedPost.id}/`)}>
                <p class="text-xs uppercase tracking-[0.22em] text-stone-500">{getPrimaryCategory(relatedPost)}</p>
                <h3 class="mt-3 text-lg font-medium leading-7 text-stone-900">{relatedPost.data.title}</h3>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <GiscusComments />
  </main>
</BaseLayout>
