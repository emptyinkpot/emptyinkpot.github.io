{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blog.tengokukk.com/schemas/runtime-envelope.schema.json",
  "title": "MyBlog Runtime Envelope",
  "type": "object",
  "required": ["ok", "version"],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "version": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {}
    },
    "item": {},
    "error": {
      "type": "string"
    },
    "sync": {
      "type": "object",
      "properties": {
        "watermark": {
          "type": "string"
        },
        "etag": {
          "type": "string"
        },
        "generatedAt": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
