{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://blog.tengokukk.com/schemas/knowledge-object.schema.json",
  "title": "KnowledgeObject",
  "type": "object",
  "required": ["id", "type", "title", "sources", "updatedAt"],
  "properties": {
    "id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": ["post", "note", "project", "book", "visual", "highlight", "annotation", "person", "place", "topic", "timeline"]
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "cover": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "href"],
        "properties": {
          "kind": {
            "type": "string"
          },
          "href": {
            "type": "string"
          },
          "modified": {
            "type": "string"
          },
          "size": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["targetId", "relation"],
        "properties": {
          "targetId": {
            "type": "string"
          },
          "relation": {
            "type": "string"
          },
          "weight": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "createdAt": {
      "type": "string"
    },
    "updatedAt": {
      "type": "string"
    },
    "snapshotVersion": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
