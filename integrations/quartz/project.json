{
  "projectName": "MyBlog Quartz Integration",
  "canonicalDoc": "README.md",
  "githubRepo": "https://github.com/emptyinkpot/blog",
  "defaultBranch": "main",
  "framework": {
    "name": "Quartz",
    "status": "embedded-integration",
    "upstream": "https://github.com/jackyzha0/quartz",
    "branch": "v4",
    "commit": "d25a6eabf96751ffca56f8a8139272def7a65041"
  },
  "myblogIntegration": {
    "status": "embedded-quartz-substrate",
    "rule": "Quartz is embedded inside MyBlog under integrations/quartz. It provides digital-garden publishing experiments and reusable Quartz-native MyBlog runtime work, but MyBlog apps/web remains the primary public shell.",
    "components": "quartz/components/myblog",
    "runtimeEmitter": "quartz/plugins/emitters/myblogRuntimePages.tsx",
    "runtimeResourcePlugin": "quartz/plugins/transformers/myblogStyle.ts",
    "contentSync": "quartz/myblog/sync-content.mjs",
    "buildWrapper": "quartz/myblog/build.mjs",
    "runtimeIndex": "static/myblog-runtime.json",
    "manualContentRoot": "content",
    "buildStagingRoot": "../.myblog-quartz-content",
    "buildOutputRoot": "public"
  },
  "contentTruth": {
    "authoringTruthRoot": "Windows:E:\\Vaults\\Obsidian",
    "serverHotMirrorRoot": "Linux:/home/vault/Obsidian",
    "publicContentAccessRoot": "/openlist/Obsidian",
    "defaultDocsRoot": "E:/Vaults/Obsidian/docs",
    "linuxDocsRoot": "/home/vault/Obsidian/docs"
  },
  "commands": {
    "sync": "npm run quartz:sync",
    "build": "npm run quartz:build",
    "dev": "npm run quartz:dev",
    "check": "npm run quartz:check"
  }
}
