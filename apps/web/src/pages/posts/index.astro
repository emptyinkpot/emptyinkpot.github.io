---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/shared/ArticleCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { sortPosts } from '../../lib/content';

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
---

<BaseLayout title="Posts / emptyinkpot" description="emptyinkpot 的文章列表页，集中展示站内公开文章。">
  <main class="space-y-8 pb-10 pt-8 md:pt-14" data-pagefind-body>
    <section class="space-y-4">
      <p class="section-kicker">All Posts</p>
      <h1 class="section-title text-4xl md:text-5xl">文章列表</h1>
      <p class="max-w-3xl text-base leading-8 text-stone-600">
        这里集中展示站内公开文章，保持从首页卡片浏览到正文阅读的稳定路径，并继续承接标签、系列与专题入口。
      </p>
    </section>

    <section class="grid gap-5 md:grid-cols-2">
      {posts.map((post) => <ArticleCard post={post} />)}
    </section>
  </main>
</BaseLayout>
