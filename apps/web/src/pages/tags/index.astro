---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGroupedCounts, toSlug } from '../../lib/content';
import { getRuntimeArticles } from '../../lib/runtimeContent';
import { withBase } from '../../lib/site';

const tags = getGroupedCounts(getRuntimeArticles().flatMap((article) => article.tags));
---

<BaseLayout title="Tags / emptyinkpot" description="按标签浏览 emptyinkpot 中的 Runtime MarkdownObject。">
  <main class="space-y-8 pb-10 pt-8 md:pt-14" data-pagefind-body>
    <section class="space-y-4">
      <p class="section-kicker">Tags</p>
      <h1 class="section-title text-4xl md:text-5xl">标签入口</h1>
      <p class="max-w-3xl text-base leading-8 text-stone-600">
        标签页只读取 Runtime MarkdownObject，不再读取 Astro posts archive。
      </p>
    </section>

    <section class="flex flex-wrap gap-3">
      {
        tags.map(([tag, count]) => (
          <a class="pill" href={withBase(`/tags/${toSlug(tag)}/`)}>
            {tag} · {count}
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
