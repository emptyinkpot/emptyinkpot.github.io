---
import ArticleCard from '../../components/shared/ArticleCard';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGroupedCounts, toSlug } from '../../lib/content';
import { getRuntimeArticles } from '../../lib/runtimeContent';

export function getStaticPaths() {
  const articles = getRuntimeArticles();
  const categories = getGroupedCounts(articles.flatMap((article) => article.categories));

  return categories.map(([category]) => ({
    params: { slug: toSlug(category) },
    props: {
      category,
      articles: articles.filter((article) => article.categories.includes(category))
    }
  }));
}

const { category, articles } = Astro.props;
---

<BaseLayout title={`${category} / emptyinkpot`} description={`浏览分类「${category}」下的 Runtime MarkdownObject。`}>
  <main class="space-y-8 pb-10 pt-8 md:pt-14" data-pagefind-body>
    <section class="space-y-4">
      <p class="section-kicker">Category</p>
      <h1 class="section-title text-4xl md:text-5xl">{category}</h1>
      <p class="max-w-3xl text-base leading-8 text-stone-600">
        当前分类下共有 {articles.length} 篇 Runtime MarkdownObject。
      </p>
    </section>

    <section class="grid gap-5 md:grid-cols-2">
      {articles.map((article) => <ArticleCard article={article} />)}
    </section>
  </main>
</BaseLayout>
