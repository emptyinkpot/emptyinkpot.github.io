---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGroupedCounts, toSlug } from '../../lib/content';
import { getRuntimeArticles } from '../../lib/runtimeContent';
import { withBase } from '../../lib/site';

const seriesList = getGroupedCounts(getRuntimeArticles().map((article) => article.series).filter(Boolean) as string[]);
---

<BaseLayout title="专题 / emptyinkpot" description="按系列浏览 emptyinkpot 中的 Runtime MarkdownObject。">
  <main class="space-y-8 pb-10 pt-8 md:pt-14" data-pagefind-body>
    <section class="space-y-4">
      <p class="section-kicker">专题</p>
      <h1 class="section-title text-4xl md:text-5xl">专题系列</h1>
      <p class="max-w-3xl text-base leading-8 text-stone-600">
        系列页只读取 Runtime MarkdownObject，不再读取 Astro posts archive。
      </p>
    </section>

    <section class="grid gap-5 md:grid-cols-2 xl:grid-cols-3">
      {
        seriesList.map(([series, count]) => (
          <a class="card-stack rounded-[2rem] p-6" href={withBase(`/series/${toSlug(series)}/`)}>
            <p class="section-kicker mb-3">专题</p>
            <h2 class="text-2xl font-semibold text-stone-950">{series}</h2>
            <p class="mt-3 text-sm leading-7 text-stone-600">{count} 篇文章</p>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
