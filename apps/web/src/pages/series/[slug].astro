---
import { getCollection } from 'astro:content';
import ArticleCard from '../../components/shared/ArticleCard.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getSeriesCounts, sortPosts, toSlug } from '../../lib/content';

export async function getStaticPaths() {
  const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
  const seriesList = getSeriesCounts(posts);

  return seriesList.map(([series]) => ({
    params: { slug: toSlug(series) },
    props: {
      series,
      posts: posts.filter((post) => post.data.series === series)
    }
  }));
}

const { series, posts } = Astro.props as {
  series: string;
  posts: Awaited<ReturnType<typeof getCollection<'posts'>>>;
};
---

<BaseLayout title={`${series} / emptyinkpot`} description={`浏览系列「${series}」中的连续内容。`}>
  <main class="space-y-8 pb-10 pt-8 md:pt-14" data-pagefind-body>
    <section class="space-y-4">
      <p class="section-kicker">Series</p>
      <h1 class="section-title text-4xl md:text-5xl">{series}</h1>
      <p class="max-w-3xl text-base leading-8 text-stone-600">
        当前系列下共有 {posts.length} 篇文章。系列适合承接主题连续、顺序明确的长线内容。
      </p>
    </section>

    <section class="grid gap-5 md:grid-cols-2">
      {posts.map((post) => <ArticleCard post={post} />)}
    </section>
  </main>
</BaseLayout>
