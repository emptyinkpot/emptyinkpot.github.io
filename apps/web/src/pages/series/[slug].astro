---
import ArticleCard from '../../components/shared/ArticleCard';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getGroupedCounts, toSlug } from '../../lib/content';
import { getRuntimeArticles } from '../../lib/runtimeContent';

export function getStaticPaths() {
  const articles = getRuntimeArticles();
  const seriesList = getGroupedCounts(articles.map((article) => article.series).filter(Boolean) as string[]);

  return seriesList.map(([series]) => ({
    params: { slug: toSlug(series) },
    props: {
      series,
      articles: articles.filter((article) => article.series === series)
    }
  }));
}

const { series, articles } = Astro.props;
---

<BaseLayout title={`${series} / emptyinkpot`} description={`浏览系列「${series}」中的 Runtime MarkdownObject。`}>
  <main class="space-y-8 pb-10 pt-8 md:pt-14" data-pagefind-body>
    <section class="space-y-4">
      <p class="section-kicker">Series</p>
      <h1 class="section-title text-4xl md:text-5xl">{series}</h1>
      <p class="max-w-3xl text-base leading-8 text-stone-600">
        当前系列下共有 {articles.length} 篇 Runtime MarkdownObject。
      </p>
    </section>

    <section class="grid gap-5 md:grid-cols-2">
      {articles.map((article) => <ArticleCard article={article} />)}
    </section>
  </main>
</BaseLayout>
