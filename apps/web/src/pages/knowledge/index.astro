---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import githubOverview from '../../data/github-overview.emptyinkpot.json';
import { musicItems } from '../../data/music';
import { visualItems } from '../../data/visuals';
import { buildClusteredRadialGraph } from '../../lib/knowledge/graph';
import { buildKnowledgeRelations, type KnowledgeRelationSource } from '../../lib/knowledge/relations';
import { defaultSealDefinitions } from '../../lib/knowledge/seals';
import type { KnowledgeGraphLink, KnowledgeGraphNode } from '../../lib/knowledge/types';
import { getRuntimeArticles } from '../../lib/runtimeContent';
import { withBase } from '../../lib/site';

const runtimeArticles = getRuntimeArticles().slice(0, 16);
const notes = [...(await getCollection('notes', ({ data }) => !data.draft))].slice(0, 8);
const projects = [...(await getCollection('projects'))].slice(0, 8);

type GraphCluster = NonNullable<KnowledgeGraphNode['cluster']>;

const collectionConfig: Array<{ id: string; label: string; cluster: GraphCluster; summary: string }> = [
  { id: 'posts', label: 'Posts', cluster: 'writing', summary: 'Long-form writing and engineering notes.' },
  { id: 'notes', label: 'Notes', cluster: 'writing', summary: 'Shorter notes and reconstruction logs.' },
  { id: 'projects', label: 'Projects', cluster: 'engineering', summary: 'Implemented systems and active engineering work.' },
  { id: 'books', label: 'Books', cluster: 'reading', summary: 'Reading queue and reference shelf.' },
  { id: 'music', label: 'Music', cluster: 'media', summary: 'Listening context for writing and building.' },
  { id: 'visuals', label: 'Visuals', cluster: 'visual', summary: 'Mood cards, posters, palettes and visual references.' },
  { id: 'github', label: 'GitHub', cluster: 'github', summary: 'Repository activity and public code traces.' }
];

const collectionNodes: KnowledgeGraphNode[] = collectionConfig.map((item) => ({
  id: `collection:${item.id}`,
  label: item.label,
  type: 'collection',
  level: 1,
  weight: 8,
  cluster: item.cluster,
  summary: item.summary,
  href: item.id === 'github' ? withBase('/github/') : withBase(`/${item.id === 'posts' ? 'posts' : item.id}/`),
  meta: 'collection'
}));

const githubRepos = githubOverview.overview.repos.slice(0, 5);

const contentNodes: KnowledgeGraphNode[] = [
  ...runtimeArticles.map((article) => ({
    id: `runtime:${article.id}`,
    label: article.title,
    type: 'post' as const,
    level: 2,
    weight: 4,
    cluster: 'writing' as const,
    href: withBase(`/posts/${article.slug}/`),
    summary: article.summary || article.description,
    meta: [...article.categories, ...article.tags].filter(Boolean).slice(0, 4).join(' / ')
  })),
  ...notes.map((note) => ({
    id: `note:${note.id}`,
    label: note.data.title,
    type: 'note' as const,
    level: 2,
    weight: 3,
    cluster: 'writing' as const,
    href: withBase(`/notes/${note.id}/`),
    summary: note.data.description ?? '',
    meta: 'note'
  })),
  ...projects.map((project) => ({
    id: `project:${project.id}`,
    label: project.data.title,
    type: 'project' as const,
    level: 2,
    weight: 4,
    cluster: 'engineering' as const,
    href: withBase(`/projects/${project.id}/`),
    summary: project.data.description ?? '',
    meta: project.data.stack.slice(0, 4).join(' / ')
  })),
  ...musicItems.map((item) => ({
    id: `music:${item.id}`,
    label: item.title,
    type: 'music' as const,
    level: 2,
    weight: 2,
    cluster: 'media' as const,
    href: item.href,
    summary: item.note,
    meta: [item.artist, ...item.mood].join(' / ')
  })),
  ...visualItems.map((item) => ({
    id: `visual:${item.id}`,
    label: item.title,
    type: 'visual' as const,
    level: 2,
    weight: 3,
    cluster: 'visual' as const,
    href: withBase(`/visuals/#${item.id}`),
    summary: item.summary,
    meta: [item.type, ...item.tags.slice(0, 3)].join(' / ')
  })),
  ...githubRepos.map((repo) => ({
    id: `github:${repo.name}`,
    label: repo.name,
    type: 'github' as const,
    level: 2,
    weight: Math.max(2, Math.min(5, Math.round(repo.size / 4000))),
    cluster: 'github' as const,
    href: repo.htmlUrl,
    summary: `${repo.language || 'Repository'} repo updated ${repo.updatedAt.slice(0, 10)}.`,
    meta: `${repo.language || 'unknown'} / ${repo.stars} stars / ${repo.issues} issues`
  }))
];

const tagLabels = Array.from(
  new Set([
    ...runtimeArticles.flatMap((article) => [...article.categories, ...article.tags]),
    ...projects.flatMap((project) => project.data.stack),
    ...musicItems.flatMap((item) => item.mood),
    ...visualItems.flatMap((item) => [item.type, ...item.tags]),
    ...githubRepos.map((repo) => repo.language || 'code')
  ])
).slice(0, 36);

const tagCluster = new Map<string, GraphCluster>();
runtimeArticles.forEach((article) => [...article.categories, ...article.tags].forEach((tag) => tagCluster.set(tag, 'writing')));
projects.forEach((project) => project.data.stack.forEach((tag) => tagCluster.set(tag, 'engineering')));
musicItems.forEach((item) => item.mood.forEach((tag) => tagCluster.set(tag, 'media')));
visualItems.forEach((item) => [item.type, ...item.tags].forEach((tag) => tagCluster.set(tag, 'visual')));
githubRepos.forEach((repo) => tagCluster.set(repo.language || 'code', 'github'));

const tagNodes: KnowledgeGraphNode[] = tagLabels.map((tag) => ({
  id: `tag:${tag}`,
  label: tag,
  type: 'tag',
  level: 3,
  weight: 2,
  cluster: tagCluster.get(tag) ?? 'archive',
  href: withBase(`/search/?q=${encodeURIComponent(tag)}`),
  summary: `Content tagged with ${tag}.`,
  meta: 'tag'
}));

const relationSources = [
  ...runtimeArticles.map((article) => ({
    id: `runtime:${article.id}`,
    kind: 'post',
    title: article.title,
    summary: article.summary || article.description,
    tags: [...article.categories, ...article.tags, ...(article.series ? [article.series] : [])],
    series: article.series,
    href: withBase(`/posts/${article.slug}/`),
    body: [article.description, article.summary, ...(article.categories || []), ...(article.tags || [])].filter(Boolean).join('\n')
  })),
  ...notes.map((note) => ({
    id: `note:${note.id}`,
    kind: 'note',
    title: note.data.title,
    summary: note.data.description ?? '',
    tags: ['note'],
    href: withBase(`/notes/${note.id}/`),
    body: note.body
  })),
  ...projects.map((project) => ({
    id: `project:${project.id}`,
    kind: 'project',
    title: project.data.title,
    summary: project.data.description ?? '',
    tags: project.data.stack,
    href: withBase(`/projects/${project.id}/`),
    body: project.body
  })),
  ...visualItems.map((item) => ({
    id: `visual:${item.id}`,
    kind: 'visual',
    title: item.title,
    summary: item.summary,
    tags: [item.type, ...item.tags],
    href: withBase(`/visuals/#${item.id}`),
    body: item.note
  }))
] satisfies KnowledgeRelationSource[];

const relationLinks = buildKnowledgeRelations(relationSources, { minScore: 4, limitPerSource: 8 });

const sealNodes: KnowledgeGraphNode[] = defaultSealDefinitions.map((seal) => ({
  id: `seal:${seal.id}`,
  label: seal.label,
  type: 'seal',
  level: 3,
  weight: ['selected', 'important', 'insight'].includes(seal.id) ? 3 : 2,
  cluster: 'archive',
  summary: `人工判断：${seal.summary}`,
  meta: `seal / ${seal.id}`
}));

const links: KnowledgeGraphLink[] = [
  ...collectionNodes.map((node) => ({ source: 'self:emptyinkpot', target: node.id, type: 'contains' as const, weight: 2 })),
  ...runtimeArticles.map((article) => ({ source: 'collection:posts', target: `runtime:${article.id}`, type: 'contains' as const, weight: 1 })),
  ...notes.map((note) => ({ source: 'collection:notes', target: `note:${note.id}`, type: 'contains' as const, weight: 1 })),
  ...projects.map((project) => ({ source: 'collection:projects', target: `project:${project.id}`, type: 'contains' as const, weight: 1 })),
  ...musicItems.map((item) => ({ source: 'collection:music', target: `music:${item.id}`, type: 'contains' as const, weight: 1 })),
  ...visualItems.map((item) => ({ source: 'collection:visuals', target: `visual:${item.id}`, type: 'contains' as const, weight: 1 })),
  ...githubRepos.map((repo) => ({ source: 'collection:github', target: `github:${repo.name}`, type: 'contains' as const, weight: 1 })),
  ...runtimeArticles.flatMap((article) =>
    [...article.categories, ...article.tags]
      .filter((tag) => tagLabels.includes(tag))
      .map((tag) => ({ source: `runtime:${article.id}`, target: `tag:${tag}`, type: 'tagged' as const, weight: 1 }))
  ),
  ...projects.flatMap((project) =>
    project.data.stack
      .filter((tag) => tagLabels.includes(tag))
      .map((tag) => ({ source: `project:${project.id}`, target: `tag:${tag}`, type: 'tagged' as const, weight: 1 }))
  ),
  ...musicItems.flatMap((item) =>
    item.mood
      .filter((tag) => tagLabels.includes(tag))
      .map((tag) => ({ source: `music:${item.id}`, target: `tag:${tag}`, type: 'tagged' as const, weight: 1 }))
  ),
  ...visualItems.flatMap((item) =>
    [item.type, ...item.tags]
      .filter((tag) => tagLabels.includes(tag))
      .map((tag) => ({ source: `visual:${item.id}`, target: `tag:${tag}`, type: 'tagged' as const, weight: 1 }))
  ),
  ...githubRepos.map((repo) => ({
    source: `github:${repo.name}`,
    target: `tag:${repo.language || 'code'}`,
    type: 'tagged' as const,
    weight: 1
  })),
  ...relationLinks.map((link) => ({
    source: link.source,
    target: link.target,
    type: link.type,
    weight: Math.max(1, Math.min(4, Math.round(link.score / 3)))
  })),
  ...sealNodes.map((node) => ({ source: 'self:emptyinkpot', target: node.id, type: 'related' as const, weight: 1 }))
];

const graph = buildClusteredRadialGraph(
  [
    {
      id: 'self:emptyinkpot',
      label: 'emptyinkpot',
      type: 'self',
      level: 0,
      weight: 10,
      summary: 'Center node for the Content OS knowledge map.',
      meta: 'self'
    },
    ...collectionNodes,
    ...contentNodes,
    ...tagNodes,
    ...sealNodes
  ],
  links
);

function colorFor(type: KnowledgeGraphNode['type']) {
  return {
    self: '#6b2d5c',
    collection: '#c9a227',
    post: '#6b2d5c',
    note: '#9e2a2b',
    project: '#2f5d50',
    book: '#9e2a2b',
    music: '#c9a227',
    visual: '#e9b6c8',
    tag: '#6b645c',
    highlight: '#c9a227',
    annotation: '#2f5d50',
    seal: '#9e2a2b',
    sticker: '#d8b34a'
  }[type];
}

const viewBox = '-620 -620 1240 1240';
---

<BaseLayout title="Knowledge Graph / emptyinkpot" description="emptyinkpot 的 Knowledge Layer 图谱入口。">
  <main class="knowledge-page">
    <section class="knowledge-page__hero glass-card">
      <p class="section-kicker">Knowledge Layer</p>
      <h1>搜索、标记和图谱的统一底座</h1>
      <p>这里展示当前静态内容、标签和本地阅读记忆系统的第一版图谱。Graph 不追求炫技，先保持分层和语义清晰。</p>
      <div class="knowledge-page__actions">
        <a href={withBase('/data/knowledge-index.json')}>查看 Knowledge Index</a>
        <a href={withBase('/')}>回到首页 Feed</a>
      </div>
    </section>

    <section class="knowledge-page__panel glass-card">
      <div class="knowledge-page__panel-head">
        <span>Radial Graph</span>
        <strong>{graph.nodes.length} nodes / {graph.links.length} links</strong>
      </div>
      <div class="knowledge-page__graph-layout">
        <aside class="knowledge-sidebar" aria-label="Graph clusters">
          <p>Clusters</p>
          <button type="button" class="is-active" data-graph-filter="all">All</button>
          <button type="button" data-graph-filter="writing">Writing</button>
          <button type="button" data-graph-filter="engineering">Engineering</button>
          <button type="button" data-graph-filter="reading">Reading</button>
          <button type="button" data-graph-filter="media">Media</button>
          <button type="button" data-graph-filter="visual">Visuals</button>
          <button type="button" data-graph-filter="github">GitHub</button>
          <button type="button" data-graph-filter="tag">Tags</button>
          <button type="button" data-graph-filter="seal">Seals</button>
          <button type="button" data-graph-filter="sticker">Stickers</button>
        </aside>

        <div class="knowledge-canvas">
          <svg class="knowledge-graph-svg" viewBox={viewBox} role="img" aria-label="Knowledge graph" data-knowledge-graph>
            {graph.links.map((link) => {
              const source = graph.nodes.find((node) => node.id === link.source);
              const target = graph.nodes.find((node) => node.id === link.target);
              if (!source || !target) return null;
              return (
                <line
                  x1={source.x}
                  y1={source.y}
                  x2={target.x}
                  y2={target.y}
                  class={`knowledge-link knowledge-link--${link.type}`}
                  data-graph-link
                  data-source={source.id}
                  data-target={target.id}
                />
              );
            })}
            {graph.nodes.map((node) => (
              <g
                class={`knowledge-node knowledge-node--${node.type}`}
                transform={`translate(${node.x ?? 0} ${node.y ?? 0})`}
                tabindex="0"
                role="button"
                data-graph-node
                data-node-id={node.id}
                data-node-label={node.label}
                data-node-type={node.type}
                data-node-cluster={node.cluster ?? 'all'}
                data-node-summary={node.summary ?? ''}
                data-node-meta={node.meta ?? ''}
                data-node-href={node.href ?? ''}
                data-node-article-id={node.type === 'highlight' ? node.id : ''}
                data-node-highlight-id=""
              >
                <circle r={node.level === 0 ? 16 : node.level === 1 ? 11 : node.level === 2 ? 7 : 4} fill={colorFor(node.type)} />
                <text x={node.level <= 1 ? 18 : 9} y="4">{node.label}</text>
              </g>
            ))}
          </svg>
        </div>

        <aside class="knowledge-inspector" aria-label="Node inspector">
          <p>Inspector</p>
          <span data-node-type-label>graph</span>
          <h2 data-node-title>Knowledge</h2>
          <p data-node-summary>选择一个节点查看类型、分区、关联入口和一跳关系。</p>
          <dl>
            <div>
              <dt>Cluster</dt>
              <dd data-node-cluster-label>all</dd>
            </div>
            <div>
              <dt>Meta</dt>
              <dd data-node-meta-label>center / collections / content / tags</dd>
            </div>
          </dl>
          <a href={withBase('/')} data-node-open>打开首页 Feed</a>
          <a href={withBase('/search/')} data-node-search>打开搜索页</a>
        </aside>
      </div>
    </section>
  </main>

  <script>
    (() => {
      const nodes = [...document.querySelectorAll('[data-graph-node]')];
      const links = [...document.querySelectorAll('[data-graph-link]')];
      const filterButtons = [...document.querySelectorAll('[data-graph-filter]')];
      const title = document.querySelector('[data-node-title]');
      const summary = document.querySelector('[data-node-summary]');
      const typeLabel = document.querySelector('[data-node-type-label]');
      const clusterLabel = document.querySelector('[data-node-cluster-label]');
      const metaLabel = document.querySelector('[data-node-meta-label]');
      const openLink = document.querySelector('[data-node-open]');
      const searchLink = document.querySelector('[data-node-search]');
      const graphSvg = document.querySelector('[data-knowledge-graph]');
      let activeFilter = 'all';

      const storageKeys = {
        seals: 'emptyinkpot-reader-seals',
        stickers: 'emptyinkpot-stickers'
      };

      const visibleNodeIds = () => new Set(nodes.filter((node) => !node.classList.contains('is-hidden')).map((node) => node.dataset.nodeId));

      const nodeMatchesFilter = (node, filter) => {
        if (filter === 'all') return true;
        if (filter === 'tag') return node.dataset.nodeType === 'tag' || node.dataset.nodeType === 'self' || node.dataset.nodeType === 'collection';
        if (filter === 'seal') return node.dataset.nodeType === 'seal' || node.dataset.nodeType === 'self' || node.dataset.localSealed === 'true';
        if (filter === 'sticker') return node.dataset.nodeType === 'sticker' || node.dataset.nodeType === 'self' || node.dataset.localStickered === 'true';
        if (node.dataset.nodeType === 'self') return true;
        return node.dataset.nodeCluster === filter;
      };

      const nodeCoordinates = (node) => {
        const match = node.getAttribute('transform')?.match(/translate\(([-\d.]+)\s+([-\d.]+)\)/);
        return {
          x: Number(match?.[1] || 0),
          y: Number(match?.[2] || 0)
        };
      };

      const hydrateLocalSealLinks = () => {
        if (!graphSvg) return;
        let placements;
        try {
          placements = JSON.parse(localStorage.getItem(storageKeys.seals) || '[]');
        } catch {
          placements = [];
        }
        if (!Array.isArray(placements) || !placements.length) return;
        const nodesById = new Map(nodes.map((node) => [node.dataset.nodeId, node]));
        const existing = new Set(links.map((link) => `${link.dataset.source}->${link.dataset.target}`));
        const firstNode = graphSvg.querySelector('[data-graph-node]');
        placements.forEach((placement) => {
          const sealId = `seal:${placement.sealId || placement.type}`;
          const targetId = placement.targetId;
          const source = nodesById.get(sealId);
          const target = nodesById.get(targetId);
          if (!source || !target || existing.has(`${sealId}->${targetId}`)) return;
          target.dataset.localSealed = 'true';
          const sourcePoint = nodeCoordinates(source);
          const targetPoint = nodeCoordinates(target);
          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
          line.setAttribute('x1', `${sourcePoint.x}`);
          line.setAttribute('y1', `${sourcePoint.y}`);
          line.setAttribute('x2', `${targetPoint.x}`);
          line.setAttribute('y2', `${targetPoint.y}`);
          line.dataset.graphLink = '';
          line.dataset.source = sealId;
          line.dataset.target = targetId;
          line.classList.add('knowledge-link', 'knowledge-link--related', 'knowledge-link--local-seal');
          graphSvg.insertBefore(line, firstNode);
          links.push(line);
        });
      };

      const applyFilter = (filter) => {
        activeFilter = filter;
        filterButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.graphFilter === filter));
        nodes.forEach((node) => {
          node.classList.toggle('is-hidden', !nodeMatchesFilter(node, filter));
          node.classList.remove('is-muted', 'is-neighbor');
        });
        const visible = visibleNodeIds();
        links.forEach((link) => {
          const show = visible.has(link.dataset.source) && visible.has(link.dataset.target);
          link.classList.toggle('is-hidden', !show);
          link.classList.remove('is-active', 'is-muted');
        });
      };

      const neighborsFor = (nodeId) => {
        const neighborIds = new Set([nodeId]);
        const activeLinks = new Set();
        links.forEach((link, index) => {
          if (link.dataset.source === nodeId || link.dataset.target === nodeId) {
            activeLinks.add(index);
            neighborIds.add(link.dataset.source);
            neighborIds.add(link.dataset.target);
          }
        });
        return { neighborIds, activeLinks };
      };

      const clearHover = () => {
        nodes.forEach((node) => node.classList.remove('is-muted', 'is-neighbor'));
        links.forEach((link) => link.classList.remove('is-active', 'is-muted'));
      };

      const focusNode = (node) => {
        const nodeId = node.dataset.nodeId;
        const { neighborIds, activeLinks } = neighborsFor(nodeId);
        nodes.forEach((item) => {
          if (item.classList.contains('is-hidden')) return;
          item.classList.toggle('is-muted', !neighborIds.has(item.dataset.nodeId));
          item.classList.toggle('is-neighbor', neighborIds.has(item.dataset.nodeId) && item !== node);
        });
        links.forEach((link, index) => {
          if (link.classList.contains('is-hidden')) return;
          link.classList.toggle('is-active', activeLinks.has(index));
          link.classList.toggle('is-muted', !activeLinks.has(index));
        });
      };

      const selectNode = (node) => {
        nodes.forEach((item) => item.classList.toggle('is-active', item === node));
        if (title) title.textContent = node.dataset.nodeLabel || 'Knowledge';
        if (summary) summary.textContent = node.dataset.nodeSummary || '这个节点还没有摘要。';
        if (typeLabel) typeLabel.textContent = node.dataset.nodeType || 'node';
        if (clusterLabel) clusterLabel.textContent = node.dataset.nodeCluster || 'all';
        if (metaLabel) metaLabel.textContent = node.dataset.nodeMeta || 'none';

        const href = node.dataset.nodeHref;
        const nodeType = node.dataset.nodeType;
        const nodeId = node.dataset.nodeId || '';
        const articleId = node.dataset.nodeArticleId || nodeId;
        const highlightId = node.dataset.nodeHighlightId || '';
        if (openLink instanceof HTMLAnchorElement) {
          openLink.hidden = !href && !['post', 'note', 'project', 'tag', 'highlight'].includes(nodeType || '');
          if (nodeType === 'tag') {
            openLink.href = `/?searchTag=${encodeURIComponent(node.dataset.nodeLabel || '')}`;
            openLink.textContent = '在首页搜索标签';
          } else if (nodeType === 'highlight') {
            openLink.href = `/?reader=${encodeURIComponent(articleId)}&highlight=${encodeURIComponent(highlightId)}`;
            openLink.textContent = '打开高亮';
          } else if (['post', 'note', 'project'].includes(nodeType || '')) {
            openLink.href = `/?reader=${encodeURIComponent(nodeId)}`;
            openLink.textContent = '在 Reader 打开';
          } else if (href) {
            openLink.href = href;
            openLink.textContent = '打开节点';
          }
        }
        if (searchLink instanceof HTMLAnchorElement) {
          searchLink.href = `/?searchTag=${encodeURIComponent(node.dataset.nodeLabel || '')}`;
        }
      };

      const openReaderCommand = (node) => {
        const nodeType = node.dataset.nodeType;
        const nodeId = node.dataset.nodeId || '';
        if (['post', 'note', 'project'].includes(nodeType || '')) {
          window.location.href = `/?reader=${encodeURIComponent(nodeId)}`;
        }
        if (nodeType === 'highlight' || nodeType === 'annotation') {
          window.location.href = `/?reader=${encodeURIComponent(node.dataset.nodeArticleId || '')}&highlight=${encodeURIComponent(node.dataset.nodeHighlightId || '')}`;
        }
        if (nodeType === 'tag') {
          window.location.href = `/?searchTag=${encodeURIComponent(node.dataset.nodeLabel || '')}`;
        }
      };

      const getTranslate = (node) => {
        const match = node.getAttribute('transform')?.match(/translate\\(([-0-9.]+)\\s+([-0-9.]+)\\)/);
        return match ? { x: Number(match[1]), y: Number(match[2]) } : { x: 0, y: 0 };
      };

      const escapeCssIdentifier = (value) => {
        if (window.CSS?.escape) return window.CSS.escape(value);
        return String(value).replace(/["\\]/g, '\\$&');
      };

      const readLocalArray = (key) => {
        try {
          return JSON.parse(localStorage.getItem(key) || '[]');
        } catch {
          return [];
        }
      };

      const createLocalLine = (sourceId, targetId, source, x, y, className) => {
        const base = getTranslate(source);
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('x1', String(base.x));
        line.setAttribute('y1', String(base.y));
        line.setAttribute('x2', String(x));
        line.setAttribute('y2', String(y));
        line.classList.add('knowledge-link', className);
        line.dataset.graphLink = 'true';
        line.dataset.source = sourceId;
        line.dataset.target = targetId;
        graphSvg.insertBefore(line, graphSvg.querySelector('[data-graph-node]'));
        links.push(line);
      };

      const createLocalNode = ({ id, label, type, x, y, summary, meta, articleId, highlightId, fill }) => {
        const node = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        node.classList.add('knowledge-node', `knowledge-node--${type}`);
        node.setAttribute('transform', `translate(${x} ${y})`);
        node.setAttribute('tabindex', '0');
        node.setAttribute('role', 'button');
        node.dataset.graphNode = 'true';
        node.dataset.nodeId = id;
        node.dataset.nodeLabel = label || type;
        node.dataset.nodeType = type;
        node.dataset.nodeCluster = 'archive';
        node.dataset.nodeSummary = summary || '';
        node.dataset.nodeMeta = meta || type;
        node.dataset.nodeArticleId = articleId || '';
        node.dataset.nodeHighlightId = highlightId || '';
        node.innerHTML = `<circle r="4" fill="${fill}"></circle><text x="9" y="4">${type === 'annotation' ? 'Annotation' : type === 'sticker' ? 'Sticker' : 'Highlight'}</text>`;
        graphSvg.append(node);
        nodes.push(node);
        return node;
      };

      const injectLocalMemoryNodes = () => {
        if (!graphSvg) return;
        const highlights = readLocalArray('emptyinkpot-reader-highlights');
        const annotations = readLocalArray('emptyinkpot-reader-annotations');
        highlights.slice(0, 12).forEach((highlight, index) => {
          const source = graphSvg.querySelector(`[data-node-id="${escapeCssIdentifier(highlight.articleId || '')}"]`);
          if (!source) return;
          const base = getTranslate(source);
          const angle = (Math.PI * 2 * (index % 6)) / 6;
          const x = Number((base.x + Math.cos(angle) * 74).toFixed(2));
          const y = Number((base.y + Math.sin(angle) * 74).toFixed(2));
          const id = `highlight:${highlight.id}`;
          createLocalLine(highlight.articleId, id, source, x, y, 'knowledge-link--highlighted');
          createLocalNode({
            id,
            label: highlight.text || 'Highlight',
            type: 'highlight',
            x,
            y,
            summary: highlight.text || '',
            meta: `highlight / ${highlight.color || 'gold'}`,
            articleId: highlight.articleId || '',
            highlightId: highlight.id || '',
            fill: '#c9a227'
          });
        });

        annotations.slice(0, 12).forEach((annotation, index) => {
          const highlightNodeId = `highlight:${annotation.highlightId}`;
          const source =
            graphSvg.querySelector(`[data-node-id="${escapeCssIdentifier(highlightNodeId)}"]`) ||
            graphSvg.querySelector(`[data-node-id="${escapeCssIdentifier(annotation.articleId || '')}"]`);
          if (!source) return;
          const base = getTranslate(source);
          const angle = (Math.PI * 2 * (index % 6)) / 6 + Math.PI / 6;
          const distance = source.dataset.nodeType === 'highlight' ? 46 : 92;
          const x = Number((base.x + Math.cos(angle) * distance).toFixed(2));
          const y = Number((base.y + Math.sin(angle) * distance).toFixed(2));
          const id = `annotation:${annotation.id}`;
          createLocalLine(source.dataset.nodeId || annotation.articleId, id, source, x, y, 'knowledge-link--annotated');
          createLocalNode({
            id,
            label: annotation.body || 'Annotation',
            type: 'annotation',
            x,
            y,
            summary: annotation.body || '',
            meta: `annotation / ${annotation.color || 'gold'}`,
            articleId: annotation.articleId || '',
            highlightId: annotation.highlightId || '',
            fill: '#2f5d50'
          });
        });

        const stickers = readLocalArray(storageKeys.stickers);
        stickers.slice(0, 16).forEach((sticker, index) => {
          const targetId = sticker.targetId || '';
          const source = graphSvg.querySelector(`[data-node-id="${escapeCssIdentifier(targetId)}"]`);
          if (!source) return;
          source.dataset.localStickered = 'true';
          const base = getTranslate(source);
          const angle = (Math.PI * 2 * (index % 8)) / 8 + Math.PI / 9;
          const x = Number((base.x + Math.cos(angle) * 104).toFixed(2));
          const y = Number((base.y + Math.sin(angle) * 104).toFixed(2));
          const id = `sticker:${sticker.id}`;
          createLocalLine(targetId, id, source, x, y, 'knowledge-link--stickered');
          createLocalNode({
            id,
            label: sticker.content || 'Sticker',
            type: 'sticker',
            x,
            y,
            summary: [sticker.kind, sticker.content, sticker.note].filter(Boolean).join(' / '),
            meta: `sticker / ${sticker.kind || 'note'}`,
            articleId: targetId,
            fill: sticker.color || '#d8b34a'
          });
        });
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => applyFilter(button.dataset.graphFilter || 'all'));
      });

      nodes.forEach((node) => {
        node.addEventListener('mouseenter', () => focusNode(node));
        node.addEventListener('mouseleave', clearHover);
        node.addEventListener('focus', () => focusNode(node));
        node.addEventListener('blur', clearHover);
        node.addEventListener('click', () => {
          selectNode(node);
          openReaderCommand(node);
        });
        node.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            selectNode(node);
            openReaderCommand(node);
          }
        });
      });

      const firstInjectedIndex = nodes.length;
      injectLocalMemoryNodes();
      nodes.slice(firstInjectedIndex).forEach((node) => {
        node.addEventListener('mouseenter', () => focusNode(node));
        node.addEventListener('mouseleave', clearHover);
        node.addEventListener('focus', () => focusNode(node));
        node.addEventListener('blur', clearHover);
        node.addEventListener('click', () => {
          selectNode(node);
          openReaderCommand(node);
        });
        node.addEventListener('keydown', (event) => {
          if (event.key === 'Enter' || event.key === ' ') {
            event.preventDefault();
            selectNode(node);
            openReaderCommand(node);
          }
        });
      });
      hydrateLocalSealLinks();
      applyFilter(activeFilter);
      const focus = new URLSearchParams(window.location.search).get('focus');
      if (focus) {
        const target = nodes.find((node) => node.dataset.nodeId === focus);
        if (target) {
          selectNode(target);
          focusNode(target);
          target.scrollIntoView?.({ block: 'center', inline: 'center' });
        }
      }
    })();
  </script>
</BaseLayout>
