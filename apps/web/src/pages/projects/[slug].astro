---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/content';
import { getGitHubOverview } from '../../lib/github';
import { buildProjectStudioView, getProjectTypeLabel } from '../../lib/projects';
import { withBase } from '../../lib/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

const { project } = Astro.props as {
  project: CollectionEntry<'projects'>;
};

const { Content } = await render(project);
const github = await getGitHubOverview('emptyinkpot');
const projectView = buildProjectStudioView(project, github);
const repoUpdatedAt = projectView.repo ? new Date(projectView.repo.updatedAt) : undefined;
---

<BaseLayout title={`${project.data.title} / emptyinkpot`} description={project.data.description}>
  <main class="project-space" data-pagefind-body>
    <section class="project-space__hero">
      <div class="project-space__hero-main">
        <p class="project-space__kicker">PROJECT STUDIO / {getProjectTypeLabel(projectView.type)}</p>
        <h1>{project.data.title}</h1>
        <p>{project.data.description}</p>

        <div class="project-space__tags">
          <span>{projectView.status}</span>
          {project.data.date && <span>{formatDate(project.data.date)}</span>}
          {project.data.stack.map((item) => <span>{item}</span>)}
        </div>

        <div class="project-space__actions">
          {project.data.repo && <a href={project.data.repo} target="_blank" rel="noreferrer">Repository</a>}
          {project.data.demo && <a href={project.data.demo} target="_blank" rel="noreferrer">Demo</a>}
          <a href={withBase('/projects/')}>Back to Project Studio</a>
        </div>
      </div>

      <aside class="project-space__status" aria-label="Project status">
        <span>{projectView.progress}%</span>
        <p>Overall progress</p>
        <div class="project-progress project-progress--large" aria-hidden="true">
          <span style={`--progress:${projectView.progress}%`}></span>
        </div>

        <dl>
          <div>
            <dt>Modules</dt>
            <dd>{projectView.modules.length}</dd>
          </div>
          <div>
            <dt>Issues</dt>
            <dd>{projectView.repo?.issues ?? 0}</dd>
          </div>
          <div>
            <dt>Updated</dt>
            <dd>{repoUpdatedAt ? formatDate(repoUpdatedAt) : 'manual'}</dd>
          </div>
        </dl>
      </aside>
    </section>

    <nav class="project-space__nav" aria-label="Project space sections">
      <a href="#overview">Overview</a>
      <a href="#modules">Modules</a>
      <a href="#wiki">Wiki</a>
      <a href="#timeline">Timeline</a>
      <a href="#contributors">Contributors</a>
      <a href="#graph">Graph</a>
    </nav>

    <div class="project-space__layout">
      <section class="project-space__section" id="overview">
        <div class="project-space__section-head">
          <p>Overview</p>
          <h2>项目总览</h2>
        </div>
        <article class="prose-shell project-space__prose">
          <Content />
        </article>
      </section>

      <section class="project-space__section" id="modules">
        <div class="project-space__section-head">
          <p>Modules</p>
          <h2>模块进度</h2>
        </div>

        <div class="project-module-grid">
          {
            projectView.modules.length > 0 ? (
              projectView.modules.map((module) => (
                <article class="project-module-card">
                  <div>
                    <span>{module.status}</span>
                    <strong>{module.progress}%</strong>
                  </div>
                  <h3>{module.name}</h3>
                  <div class="project-progress" aria-label={`${module.name} progress ${module.progress}%`}>
                    <span style={`--progress:${module.progress}%`}></span>
                  </div>
                </article>
              ))
            ) : (
              <p class="workbench-page__empty">模块等待补充。请在项目 frontmatter 的 modules 中维护进度。</p>
            )
          }
        </div>
      </section>

      <section class="project-space__section" id="wiki">
        <div class="project-space__section-head">
          <p>Wiki</p>
          <h2>协作文档</h2>
        </div>

        <div class="project-wiki-list">
          {
            projectView.wiki.map((item) => (
              <article>
                <div>
                  <span>{item.type}</span>
                  <code>{item.path}</code>
                </div>
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
                {item.editUrl && (
                  <a href={item.editUrl} target="_blank" rel="noreferrer">
                    Edit on GitHub
                  </a>
                )}
              </article>
            ))
          }
        </div>
      </section>

      <section class="project-space__section" id="timeline">
        <div class="project-space__section-head">
          <p>Timeline</p>
          <h2>时间线</h2>
        </div>

        <div class="project-timeline-list">
          {
            projectView.timeline.length > 0 ? (
              projectView.timeline.map((item) => (
                <article>
                  <span>{item.date ? formatDate(item.date) : 'No date'}</span>
                  <h3>{item.title}</h3>
                  <p>{item.summary}</p>
                  {item.href && (
                    <a href={item.href} target="_blank" rel="noreferrer">
                      Open source
                    </a>
                  )}
                </article>
              ))
            ) : (
              <p class="workbench-page__empty">时间线等待 milestones 或 GitHub snapshot 补充。</p>
            )
          }
        </div>
      </section>

      <section class="project-space__section" id="contributors">
        <div class="project-space__section-head">
          <p>Contributors</p>
          <h2>协作者</h2>
        </div>

        <div class="project-contributors">
          {
            projectView.contributors.map((contributor) => (
              <a href={contributor.href} target="_blank" rel="noreferrer">
                <img src={contributor.avatarUrl} alt={`${contributor.name} avatar`} loading="lazy" decoding="async" />
                <span>{contributor.name}</span>
                <small>@{contributor.login}</small>
              </a>
            ))
          }
        </div>
      </section>

      <section class="project-space__section" id="graph">
        <div class="project-space__section-head">
          <p>Graph</p>
          <h2>项目关系图</h2>
        </div>

        <div class="project-mini-graph" aria-label="Project mini graph">
          <div class="project-mini-graph__node project-mini-graph__node--main">{project.data.title}</div>
          <div class="project-mini-graph__links">
            {projectView.modules.slice(0, 3).map((module) => <span>{module.name}</span>)}
            {projectView.wiki.slice(0, 3).map((item) => <span>{item.title}</span>)}
            {project.data.stack.slice(0, 3).map((tag) => <span>#{tag}</span>)}
          </div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
