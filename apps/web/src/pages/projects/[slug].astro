---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectWorkbenchCommand from '../../components/react/ProjectWorkbenchCommand';
import { formatDate } from '../../lib/content';
import { getGitHubOverview } from '../../lib/github';
import { buildProjectStudioView, getProjectTypeLabel } from '../../lib/projects';
import { withBase } from '../../lib/site';

export async function getStaticPaths() {
  const projects = await getCollection('projects');

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project }
  }));
}

const { project } = Astro.props as {
  project: CollectionEntry<'projects'>;
};

const github = await getGitHubOverview('emptyinkpot');
const projectView = buildProjectStudioView(project, github);
const repoUpdatedAt = projectView.repo ? new Date(projectView.repo.updatedAt) : undefined;
const repoLabel = projectView.owner && projectView.repoName ? `${projectView.owner}/${projectView.repoName}` : 'manual project';
const initialBranch = 'main';
const primaryWiki = projectView.wiki[0];
const initialWikiContent = project.body?.trim() || project.data.description;
const githubRuntimeMode = 'GitHub API';
const commandItems = [
  {
    id: 'wiki',
    label: 'Wiki 文档',
    description: primaryWiki?.path ?? '项目 Wiki 编辑区',
    href: '#wiki',
    kind: 'internal',
    icon: 'wiki'
  },
  {
    id: 'timeline',
    label: '时间线',
    description: '提交到 timeline API',
    href: '#timeline',
    kind: 'internal',
    icon: 'timeline'
  },
  {
    id: 'modules',
    label: '模块进度',
    description: `${projectView.modules.length} 个模块`,
    href: '#modules',
    kind: 'internal',
    icon: 'modules'
  },
  {
    id: 'issues',
    label: 'Issues',
    description: '实时读取 GitHub Issues',
    href: '#issues',
    kind: 'internal',
    icon: 'issues'
  },
  {
    id: 'pulls',
    label: 'Pull Requests',
    description: '实时读取 GitHub PR',
    href: '#pulls',
    kind: 'internal',
    icon: 'pulls'
  },
  {
    id: 'commits',
    label: 'Commits',
    description: '最近提交与 GitHub commits',
    href: '#commits',
    kind: 'internal',
    icon: 'commits'
  },
  {
    id: 'contributors',
    label: '贡献者',
    description: `${projectView.contributors.length} contributors`,
    href: '#contributors',
    kind: 'internal',
    icon: 'contributors'
  },
  ...(primaryWiki?.editUrl
    ? [
        {
          id: 'github-edit',
          label: 'GitHub 编辑',
          description: primaryWiki.path,
          href: primaryWiki.editUrl,
          kind: 'external',
          icon: 'github'
        }
      ]
    : [])
] as const;
---

<BaseLayout title={`${project.data.title} / GitHub Workbench`} description={project.data.description} hideSiteChrome={true} appMode={true}>
  <main class="project-workbench" data-pagefind-body data-project-slug={project.id} data-project-repo={repoLabel} data-github-api-ready="true">
    <aside class="project-workbench__sidebar" aria-label="Project workbench navigation">
      <a class="project-workbench__brand" href={withBase('/projects/')}>
        <i aria-hidden="true"></i>
        <span>PROJECT WORKBENCH</span>
        <strong>{project.data.title}</strong>
      </a>

      <nav class="project-workbench__nav">
        <a class="is-active" href="#wiki"><span aria-hidden="true">W</span>Wiki 文档</a>
        <a href="#timeline"><span aria-hidden="true">T</span>时间线</a>
        <a href="#modules"><span aria-hidden="true">M</span>模块进度</a>
        <a href="#issues"><span aria-hidden="true">I</span>Issues</a>
        <a href="#pulls"><span aria-hidden="true">P</span>Pull Requests</a>
        <a href="#commits"><span aria-hidden="true">C</span>Commits</a>
        <a href="#contributors"><span aria-hidden="true">U</span>贡献者</a>
        <a href="#graph"><span aria-hidden="true">G</span>知识关系</a>
      </nav>

      <div class="project-workbench__sidebar-note">
        <span>{getProjectTypeLabel(projectView.type)} / {projectView.status}</span>
        <p>写入与同步都经过服务端 GitHub API；前台不暴露 token，失败时保留当前构建期兜底。</p>
      </div>
    </aside>

    <section class="project-workbench__main">
      <header class="project-workbench__statusbar">
        <div class="project-workbench__repo">
          <span>项目工坊 / {repoLabel} / {githubRuntimeMode}</span>
          <strong>{project.data.title}</strong>
          <small data-project-live-summary>正在连接 GitHub API；失败时保留构建期兜底。</small>
        </div>

        <dl class="project-workbench__status">
          <div>
            <dt>Branch</dt>
            <dd data-project-status="branch">{initialBranch}</dd>
          </div>
          <div>
            <dt>Updated</dt>
            <dd data-project-status="updated">{repoUpdatedAt ? formatDate(repoUpdatedAt) : 'manual'}</dd>
          </div>
          <div>
            <dt>Issues</dt>
            <dd data-project-status="issues">{projectView.repo?.issues ?? 0}</dd>
          </div>
          <div>
            <dt>PR</dt>
            <dd data-project-status="pulls">...</dd>
          </div>
          <div>
            <dt>Contributors</dt>
            <dd data-project-status="contributors">{projectView.contributors.length}</dd>
          </div>
        </dl>

        <div class="project-workbench__status-actions">
          <span class="project-workbench__api-badge" data-project-live-status data-state="loading">连接中</span>
          <ProjectWorkbenchCommand client:idle commands={commandItems} />
          <a href={project.data.repo ?? withBase('/projects/')} target={project.data.repo ? '_blank' : undefined} rel={project.data.repo ? 'noreferrer' : undefined}>仓库</a>
          {primaryWiki?.editUrl && <a href={primaryWiki.editUrl} target="_blank" rel="noreferrer">GitHub 编辑</a>}
          <button type="button" data-sync-project>同步</button>
        </div>
      </header>

      <section id="wiki" class="project-work-panel project-work-panel--editor" data-wiki-editor>
        <header class="project-work-panel__header">
          <div>
            <span>WIKI EDITOR</span>
            <h1>{primaryWiki?.title ?? '项目 Wiki'}</h1>
          </div>
          <div class="project-work-panel__tools">
            <code>{primaryWiki?.path ?? 'README.md'}</code>
            <button type="button" data-save-wiki>提交到 GitHub</button>
          </div>
        </header>

        <textarea
          class="project-workbench__editor"
          id="project-wiki-editor"
          name="project-wiki-editor"
          data-wiki-content
          aria-label="Wiki editor"
        >{initialWikiContent}</textarea>

        <p class="project-workbench__message" data-wiki-message>
          当前静态站不会暴露 GitHub token。点击提交会调用服务端 `/api/github/file/save` 写入 GitHub。
        </p>
      </section>

      <section id="timeline" class="project-work-panel" data-timeline-editor>
        <header class="project-work-panel__header">
          <div>
            <span>TIMELINE</span>
            <h2>项目时间线</h2>
          </div>
          <button type="button" data-save-timeline>提交 timeline.json</button>
        </header>

        <div class="project-workbench__timeline-compose">
          <input id="project-timeline-title" name="project-timeline-title" data-timeline-title type="text" placeholder="记录本次进展标题" aria-label="Timeline title" />
          <textarea id="project-timeline-body" name="project-timeline-body" data-timeline-body placeholder="补充说明：模块、Wiki、卡牌、世界观或协作状态。" aria-label="Timeline body"></textarea>
          <p data-timeline-message>提交会调用 `/api/projects/[slug]/timeline`，由后端读取并更新仓库 `data/timeline.json`。</p>
        </div>

        <div class="project-workbench__timeline-list">
          {
            projectView.timeline.length > 0 ? (
              projectView.timeline.map((item) => (
                <article>
                  <time>{item.date ? formatDate(item.date) : 'No date'}</time>
                  <strong>{item.title}</strong>
                  <p>{item.summary}</p>
                  {item.href && <a href={item.href} target="_blank" rel="noreferrer">source</a>}
                </article>
              ))
            ) : (
              <p class="project-workbench__empty">等待 `data/timeline.json` 或 frontmatter milestones。</p>
            )
          }
        </div>
      </section>

      <section id="modules" class="project-work-panel">
        <header class="project-work-panel__header">
          <div>
            <span>MODULES</span>
            <h2>模块进度</h2>
          </div>
          <strong>{projectView.progress}%</strong>
        </header>

        <div class="project-workbench__module-list">
          {projectView.modules.map((module) => (
            <article>
              <div>
                <strong>{module.name}</strong>
                <span>{module.status}</span>
              </div>
              <i aria-label={`${module.name} progress ${module.progress}%`}><b style={`--progress:${module.progress}%`}></b></i>
              <em>{module.progress}%</em>
            </article>
          ))}
        </div>
      </section>

      <section id="issues" class="project-work-panel">
        <header class="project-work-panel__header">
          <div>
            <span>ISSUES</span>
            <h2>问题队列</h2>
          </div>
          <strong data-project-count="issues">{projectView.repo?.issues ?? 0} open</strong>
        </header>
        <div class="project-workbench__commit-list" data-github-issues-list>
          <p class="project-workbench__empty">正在从 `/api/github/issues` 读取公开 Issue。</p>
        </div>
      </section>

      <section id="pulls" class="project-work-panel">
        <header class="project-work-panel__header">
          <div>
            <span>PULL REQUESTS</span>
            <h2>合并请求</h2>
          </div>
          <strong data-project-count="pulls">...</strong>
        </header>
        <div class="project-workbench__commit-list" data-github-pulls-list>
          <p class="project-workbench__empty">正在从 `/api/github/pulls` 读取公开 PR。</p>
        </div>
      </section>

      <section id="commits" class="project-work-panel">
        <header class="project-work-panel__header">
          <div>
            <span>COMMITS</span>
            <h2>最近提交</h2>
          </div>
          {projectView.repo?.htmlUrl && <a href={`${projectView.repo.htmlUrl}/commits/main`} target="_blank" rel="noreferrer">GitHub commits</a>}
        </header>
        <div class="project-workbench__commit-list" data-github-commits-list>
          {projectView.timeline.map((item) => (
            <article>
              <strong>{item.title}</strong>
              <span>{item.date ? formatDate(item.date) : 'No date'}</span>
              <p>{item.summary}</p>
            </article>
          ))}
        </div>
      </section>
    </section>

    <aside class="project-workbench__inspector" aria-label="Project inspector">
      <section id="contributors">
        <span>CONTRIBUTORS</span>
        <div class="project-workbench__contributors" data-github-contributors-list>
          {projectView.contributors.map((contributor) => (
            <a href={contributor.href} target="_blank" rel="noreferrer">
              <img src={contributor.avatarUrl} alt={`${contributor.name} avatar`} loading="lazy" decoding="async" />
              <strong>{contributor.name}</strong>
              <small>@{contributor.login}</small>
            </a>
          ))}
        </div>
      </section>

      <section>
        <span>WIKI FILES</span>
        <div class="project-workbench__wiki-files">
          {projectView.wiki.map((item) => (
            <a href={item.editUrl ?? '#'} target={item.editUrl ? '_blank' : undefined} rel={item.editUrl ? 'noreferrer' : undefined}>
              <strong>{item.title}</strong>
              <code>{item.path}</code>
            </a>
          ))}
        </div>
      </section>

      <section id="graph">
        <span>KNOWLEDGE GRAPH</span>
        <div class="project-workbench__graph" aria-label="Project graph preview">
          <b>{project.data.title}</b>
          {projectView.modules.slice(0, 3).map((module) => <i>{module.name}</i>)}
          {project.data.stack.slice(0, 3).map((tag) => <i>#{tag}</i>)}
        </div>
      </section>
    </aside>
  </main>

  <script>
    (() => {
      const root = document.querySelector('[data-project-slug]');
      if (!(root instanceof HTMLElement)) return;

      const slug = root.dataset.projectSlug || 'project';
      const repo = root.dataset.projectRepo || '';
      const apiReady = root.dataset.githubApiReady === 'true';
      const wikiButton = root.querySelector('[data-save-wiki]');
      const wikiContent = root.querySelector('[data-wiki-content]');
      const wikiMessage = root.querySelector('[data-wiki-message]');
      const timelineButton = root.querySelector('[data-save-timeline]');
      const timelineTitle = root.querySelector('[data-timeline-title]');
      const timelineBody = root.querySelector('[data-timeline-body]');
      const timelineMessage = root.querySelector('[data-timeline-message]');
      const syncButton = root.querySelector('[data-sync-project]');
      const liveStatus = root.querySelector('[data-project-live-status]');
      const liveSummary = root.querySelector('[data-project-live-summary]');
      const issuesList = root.querySelector('[data-github-issues-list]');
      const pullsList = root.querySelector('[data-github-pulls-list]');
      const commitsList = root.querySelector('[data-github-commits-list]');
      const contributorsList = root.querySelector('[data-github-contributors-list]');

      const setMessage = (target, value, tone = '') => {
        if (!(target instanceof HTMLElement)) return;
        target.textContent = value;
        target.dataset.tone = tone;
      };

      const formatLiveDate = (value) => {
        const date = new Date(value);
        if (Number.isNaN(date.getTime())) return '未知时间';
        return new Intl.DateTimeFormat('zh-CN', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
          hour: '2-digit',
          minute: '2-digit'
        }).format(date);
      };

      const setLiveStatus = (value, state = 'loading') => {
        if (!(liveStatus instanceof HTMLElement)) return;
        liveStatus.textContent = value;
        liveStatus.dataset.state = state;
      };

      const setLiveSummary = (value) => {
        if (liveSummary instanceof HTMLElement) liveSummary.textContent = value;
      };

      const setStatusValue = (key, value) => {
        root.querySelectorAll(`[data-project-status="${key}"]`).forEach((node) => {
          node.textContent = String(value);
        });
      };

      const setCount = (key, value) => {
        root.querySelectorAll(`[data-project-count="${key}"]`).forEach((node) => {
          node.textContent = value;
        });
      };

      const getJson = async (url) => {
        const response = await fetch(url, {
          headers: { Accept: 'application/json' },
          cache: 'no-store'
        });
        if (!response.ok) throw new Error(`HTTP ${response.status}`);
        const payload = await response.json();
        if (!payload.ok) throw new Error(payload.error || 'GitHub API payload invalid');
        return payload;
      };

      const createLiveArticle = ({ title, href, meta, body }) => {
        const article = document.createElement('article');
        const heading = document.createElement('strong');
        const link = document.createElement('a');
        const detail = document.createElement('span');
        const summary = document.createElement('p');
        link.href = href || '#';
        if (href) {
          link.target = '_blank';
          link.rel = 'noreferrer';
        }
        link.textContent = title;
        heading.append(link);
        detail.textContent = meta;
        summary.textContent = body;
        article.append(heading, detail, summary);
        return article;
      };

      const renderEmpty = (container, message) => {
        if (!container) return;
        const empty = document.createElement('p');
        empty.className = 'project-workbench__empty';
        empty.textContent = message;
        container.replaceChildren(empty);
      };

      const renderIssues = (items = []) => {
        setStatusValue('issues', items.length);
        setCount('issues', `${items.length} open`);
        if (!issuesList) return;
        if (!items.length) {
          renderEmpty(issuesList, '当前没有打开的 Issue。');
          return;
        }
        issuesList.replaceChildren(
          ...items.slice(0, 8).map((issue) =>
            createLiveArticle({
              title: `#${issue.number} ${issue.title}`,
              href: issue.htmlUrl,
              meta: `${issue.state} · 更新 ${formatLiveDate(issue.updatedAt)}`,
              body: issue.labels?.filter(Boolean).length ? `Labels: ${issue.labels.filter(Boolean).join(', ')}` : 'GitHub live issue'
            })
          )
        );
      };

      const renderPulls = (items = []) => {
        setStatusValue('pulls', items.length);
        setCount('pulls', `${items.length} open`);
        if (!pullsList) return;
        if (!items.length) {
          renderEmpty(pullsList, '当前没有打开的 Pull Request。');
          return;
        }
        pullsList.replaceChildren(
          ...items.slice(0, 8).map((pull) =>
            createLiveArticle({
              title: `#${pull.number} ${pull.title}`,
              href: pull.htmlUrl,
              meta: `${pull.draft ? 'draft' : pull.state} · 更新 ${formatLiveDate(pull.updatedAt)}`,
              body: pull.user?.login ? `Author: @${pull.user.login}` : 'GitHub live pull request'
            })
          )
        );
      };

      const renderCommits = (items = []) => {
        if (!commitsList) return;
        if (!items.length) {
          renderEmpty(commitsList, '最近提交暂时不可用。');
          return;
        }
        commitsList.replaceChildren(
          ...items.slice(0, 10).map((commit) =>
            createLiveArticle({
              title: commit.message?.split('\n')[0] || commit.sha.slice(0, 7),
              href: commit.htmlUrl,
              meta: `${commit.sha.slice(0, 7)} · ${formatLiveDate(commit.date)}`,
              body: commit.author?.login ? `Author: @${commit.author.login}` : 'Git commit'
            })
          )
        );
      };

      const renderContributors = (items = []) => {
        setStatusValue('contributors', items.length);
        if (!contributorsList) return;
        if (!items.length) {
          renderEmpty(contributorsList, '贡献者数据暂时不可用。');
          return;
        }
        contributorsList.replaceChildren(
          ...items.slice(0, 10).map((contributor) => {
            const anchor = document.createElement('a');
            const avatar = document.createElement('img');
            const login = document.createElement('strong');
            const count = document.createElement('small');
            anchor.href = contributor.htmlUrl;
            anchor.target = '_blank';
            anchor.rel = 'noreferrer';
            avatar.src = contributor.avatarUrl;
            avatar.alt = `${contributor.login} avatar`;
            avatar.loading = 'lazy';
            avatar.decoding = 'async';
            login.textContent = `@${contributor.login}`;
            count.textContent = `${contributor.contributions || 0} commits`;
            anchor.append(avatar, login, count);
            return anchor;
          })
        );
      };

      const syncProjectLive = async () => {
        if (!apiReady || !repo.includes('/')) {
          setLiveStatus('本地模式', 'snapshot');
          setLiveSummary('这个项目没有可同步的 GitHub 仓库，当前使用项目 frontmatter。');
          return;
        }

        setLiveStatus('连接中', 'loading');
        setLiveSummary('正在读取 GitHub repo / issues / PR / commits / contributors。');
        const repoQuery = encodeURIComponent(repo);

        try {
          const repoPayload = await getJson(`/api/github/repo?repo=${repoQuery}`);
          const liveRepo = repoPayload.repo || {};
          const branch = liveRepo.defaultBranch || 'main';
          const updatedAt = liveRepo.pushedAt || liveRepo.updatedAt;

          setStatusValue('branch', branch);
          setStatusValue('updated', formatLiveDate(updatedAt));
          setLiveSummary(
            `${liveRepo.fullName || repo} · ${liveRepo.language || 'Unknown'} · 正在同步 open Issues / PR · 更新 ${formatLiveDate(updatedAt)}`
          );

          const [issues, pulls, commits, contributors] = await Promise.allSettled([
            getJson(`/api/github/issues?repo=${repoQuery}&state=open`),
            getJson(`/api/github/pulls?repo=${repoQuery}&state=open`),
            getJson(`/api/github/commits?repo=${repoQuery}&branch=${encodeURIComponent(branch)}&limit=10`),
            getJson(`/api/github/contributors?repo=${repoQuery}`)
          ]);

          if (issues.status === 'fulfilled') renderIssues(issues.value.issues || []);
          else renderEmpty(issuesList, 'Issues API 读取失败，保留仓库 open issue 计数。');

          if (pulls.status === 'fulfilled') renderPulls(pulls.value.pulls || []);
          else renderEmpty(pullsList, 'Pull Requests API 读取失败。');

          if (commits.status === 'fulfilled') renderCommits(commits.value.commits || []);
          else renderEmpty(commitsList, 'Commits API 读取失败，保留构建期时间线。');

          if (contributors.status === 'fulfilled') renderContributors(contributors.value.contributors || []);
          else renderEmpty(contributorsList, 'Contributors API 读取失败，保留构建期贡献者。');

          const issueCount = issues.status === 'fulfilled' ? (issues.value.issues || []).length : liveRepo.openIssues;
          const pullCount = pulls.status === 'fulfilled' ? (pulls.value.pulls || []).length : '未知';
          const contributorCount = contributors.status === 'fulfilled' ? (contributors.value.contributors || []).length : '未知';
          setLiveSummary(
            `${liveRepo.fullName || repo} · ${branch} · ${issueCount} Issues / ${pullCount} PR / ${contributorCount} contributors · 更新 ${formatLiveDate(updatedAt)}`
          );
          setLiveStatus('已同步', 'live');
        } catch (error) {
          console.warn('[project-workbench-live]', error);
          setLiveStatus('同步失败', 'error');
          setLiveSummary('GitHub API 读取失败，当前页面保留构建期兜底。');
        }
      };

      const postJson = async (url, payload) => {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!response.ok) {
          throw new Error(`HTTP ${response.status}`);
        }

        return response.json();
      };

      wikiButton?.addEventListener('click', async () => {
        if (!(wikiContent instanceof HTMLTextAreaElement)) return;
        if (!apiReady) {
          setMessage(wikiMessage, 'API 中间层尚未接入；当前请使用 GitHub 编辑入口提交。', 'warn');
          return;
        }

        setMessage(wikiMessage, '正在提交到 /api/github/file/save ...');
        try {
          await postJson('/api/github/file/save', {
            repo,
            path: 'README.md',
            content: wikiContent.value,
            message: `更新 Wiki：${slug}`
          });
          setMessage(wikiMessage, '已提交到 GitHub。', 'ok');
        } catch {
          setMessage(wikiMessage, 'API 中间层尚未接入；当前请使用 GitHub 编辑入口提交。', 'warn');
        }
      });

      timelineButton?.addEventListener('click', async () => {
        if (!(timelineTitle instanceof HTMLInputElement) || !(timelineBody instanceof HTMLTextAreaElement)) return;
        const title = timelineTitle.value.trim();
        const body = timelineBody.value.trim();
        if (!title) {
          setMessage(timelineMessage, '请先填写时间线标题。', 'warn');
          return;
        }

        if (!apiReady) {
          setMessage(timelineMessage, 'API 中间层尚未接入；不会写入 localStorage 或伪造提交。', 'warn');
          return;
        }

        setMessage(timelineMessage, '正在提交到 timeline API ...');
        try {
          await postJson(`/api/projects/${slug}/timeline`, { title, body, repo });
          timelineTitle.value = '';
          timelineBody.value = '';
          setMessage(timelineMessage, '时间线已提交到 GitHub。', 'ok');
        } catch {
          setMessage(timelineMessage, 'API 中间层尚未接入；不会写入 localStorage 或伪造提交。', 'warn');
        }
      });

      syncButton?.addEventListener('click', () => {
        if (syncButton instanceof HTMLButtonElement) {
          syncButton.textContent = '同步中';
          syncProjectLive().finally(() => {
            window.setTimeout(() => {
              syncButton.textContent = '同步';
            }, 600);
          });
        }
      });

      syncProjectLive();
    })();
  </script>
