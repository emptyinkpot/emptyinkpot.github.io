---
import { getCollection } from 'astro:content';
import WorkbenchPageIntro from '../../components/shared/WorkbenchPageIntro.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { formatDate } from '../../lib/content';
import { withBase } from '../../lib/site';

const projects = await getCollection('projects');
---

<BaseLayout title="项目 / emptyinkpot" description="站点中的项目展示入口。">
  <main class="workbench-page" data-pagefind-body>
    <WorkbenchPageIntro
      kicker="SECTION / PROJECTS"
      title="项目展示"
      summary="这一层是“产品化技术博客”的第二条内容主线。后续会接更多项目卡、仓库链接和相关文章映射。"
      stats={[
        { label: 'Project count', value: String(projects.length) },
        { label: 'Active focus', value: projects[0]?.data.status ?? 'planned' }
      ]}
    />

    <section class="workbench-page__grid workbench-page__grid--projects">
      {
        projects.map((project) => (
          <a class="workbench-page__project-card home-workbench__card home-workbench__card--panel" href={withBase(`/projects/${project.id}/`)}>
            <div class="workbench-page__meta">
              <span>{project.data.status}</span>
              {project.data.date && <span>{formatDate(project.data.date)}</span>}
            </div>
            <h2>{project.data.title}</h2>
            <p>{project.data.description}</p>
            <div class="home-workbench__badges">
              {project.data.stack.map((item) => <span>{item}</span>)}
            </div>
          </a>
        ))
      }
    </section>
  </main>
</BaseLayout>
