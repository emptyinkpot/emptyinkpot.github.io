---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ChartCard from '../../components/visualizations/ChartCard.astro';
import GitHubHeatmap from '../../components/visualizations/GitHubHeatmap.astro';
import GitHubLanguageDonut from '../../components/visualizations/GitHubLanguageDonut.astro';
import GitHubMonthlyLine from '../../components/visualizations/GitHubMonthlyLine.astro';
import GitHubRepoMatrix from '../../components/visualizations/GitHubRepoMatrix.astro';
import GitHubRuntimeSync from '../../components/visualizations/GitHubRuntimeSync.astro';
import TeamSignalGraph from '../../components/visualizations/TeamSignalGraph.astro';
import { buildGitHubAnalytics } from '../../lib/analytics';
import { getGitHubOverview } from '../../lib/github';

const github = await getGitHubOverview('emptyinkpot');
const analytics = buildGitHubAnalytics(github);
---

<BaseLayout title="GitHub 仪表盘 / emptyinkpot" description="emptyinkpot 的 GitHub 热力图、折线图、语言分布、仓库矩阵和团队信号。">
  <main class="showcase-page" data-github-live-root data-github-username="emptyinkpot">
    <section class="showcase-page__hero glass-card">
      <div>
        <p class="section-kicker">GitHub Dashboard</p>
        <h1>GitHub 仪表盘</h1>
        <p>这里展开首页 mini 卡片背后的完整 GitHub 数据：页面先使用构建快照兜底，打开后由服务器端 GitHub API 实时覆盖头像、仓库、贡献热力图和语言分布。</p>
        <div class="showcase-page__profile">
          <img src={github.profile.avatarUrl} alt={github.profile.name} data-github-profile="avatar" />
          <div>
            <strong data-github-profile="name">{github.profile.name}</strong>
            <span data-github-profile="login">@{github.profile.login}</span>
          </div>
          <small data-github-live-status data-github-live-state="loading">等待实时同步</small>
        </div>
      </div>
      <div class="showcase-page__metrics">
        <span><strong data-github-metric="totalContributions">{analytics.totalContributions}</strong>年度活动</span>
        <span><strong data-github-metric="activeDays">{analytics.activeDays}</strong>活跃日</span>
        <span><strong data-github-metric="publicRepos">{github.profile.publicRepos}</strong>公开仓库</span>
      </div>
    </section>

    <section class="showcase-page__grid showcase-page__grid--wide">
      <ChartCard
        kicker="Heatmap"
        title="年度活动热力图"
        summary="完整周粒度贡献格子，运行时通过站内 API 从 GitHub GraphQL 刷新。"
        metric={`${analytics.totalContributions} total`}
      >
        <GitHubHeatmap weeks={analytics.heatmapWeeks} />
      </ChartCard>

      <ChartCard kicker="Monthly" title="月度贡献折线" summary="月度贡献趋势由实时贡献日历聚合，快照只作为兜底。" metric="trend">
        <GitHubMonthlyLine points={analytics.monthly} />
      </ChartCard>

      <ChartCard
        kicker="Languages"
        title="语言占比"
        summary="仓库语言分布由最近公开仓库语言字节数聚合。"
        metric={analytics.topLanguage ? analytics.topLanguage.label : 'N/A'}
      >
        <GitHubLanguageDonut languages={analytics.languages} />
      </ChartCard>

      <ChartCard kicker="Team Signal" title="团队与自动化信号" summary="头像、账号和最近仓库会在 API 成功后替换为 live 数据。">
        <TeamSignalGraph profile={github.profile} repos={analytics.repos} />
      </ChartCard>
    </section>

    <section class="showcase-page__section glass-card">
      <div class="showcase-page__section-head">
        <span>Repo Matrix</span>
        <h2>仓库矩阵</h2>
      </div>
      <GitHubRepoMatrix repos={analytics.repos} />
    </section>
  </main>
  <GitHubRuntimeSync />
</BaseLayout>
