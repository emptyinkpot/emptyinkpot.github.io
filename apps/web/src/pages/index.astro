---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChartCard from '../components/visualizations/ChartCard.astro';
import GitHubHeatmap from '../components/visualizations/GitHubHeatmap.astro';
import GitHubLanguageDonut from '../components/visualizations/GitHubLanguageDonut.astro';
import GitHubMonthlyLine from '../components/visualizations/GitHubMonthlyLine.astro';
import MusicCard from '../components/showcase/MusicCard.astro';
import type { HomeBook } from '../data/books';
import { formatDate, getExcerptFromBody, getPrimaryCategory, getReadingTime, sortPosts, toSlug } from '../lib/content';
import { buildGitHubAnalytics, getRecentHeatmapWeeks } from '../lib/analytics';
import { books } from '../data/books';
import { musicItems, type MusicItem } from '../data/music';
import { getGitHubOverview } from '../lib/github';
import { profileLinks } from '../lib/profile';
import { getPostCover } from '../lib/postCovers';
import { withBase } from '../lib/site';

type DrawerKind = 'post' | 'note' | 'project' | 'book' | 'music' | 'github' | 'bilibili' | 'update';

type DrawerEntry = {
  id: string;
  kind: DrawerKind;
  title: string;
  kicker: string;
  date?: string;
  href: string;
  summary: string;
  Content?: Awaited<ReturnType<typeof render>>['Content'];
  toc?: Array<{ href: string; className: string; text: string }>;
  coverSrc?: string;
  accent?: string;
  tags?: string[];
  details?: Array<{ label: string; value: string }>;
  chartVariant?: 'heatmap' | 'line' | 'language';
};

type FeedItem = {
  id: string;
  type: 'post' | 'note' | 'project' | 'book' | 'music' | 'github' | 'bilibili' | 'update';
  title: string;
  summary: string;
  kicker: string;
  meta?: string;
  href?: string;
  drawerId?: string;
  githubVariant?: 'repo' | 'heatmap' | 'line' | 'language' | 'team';
  musicItem?: MusicItem;
  coverSrc?: string;
  tags?: string[];
  accent?: string;
  size?: 'compact' | 'standard' | 'tall';
};

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const notes = [...(await getCollection('notes', ({ data }) => !data.draft))].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const projects = [...(await getCollection('projects'))].sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
const github = await getGitHubOverview('emptyinkpot');
const githubAnalytics = buildGitHubAnalytics(github);
const recentHeatmapWeeks = getRecentHeatmapWeeks(githubAnalytics, 12);

const drawerSources = [
  ...posts.map((entry) => ({ entry, kind: 'post' as const })),
  ...notes.map((entry) => ({ entry, kind: 'note' as const })),
  ...projects.map((entry) => ({ entry, kind: 'project' as const }))
];

const articleDrawerEntries: DrawerEntry[] = await Promise.all(
  drawerSources.map(async ({ entry, kind }) => {
    const rendered = await render(entry as CollectionEntry<'posts'>);
    const basePath = kind === 'post' ? 'posts' : kind === 'note' ? 'notes' : 'projects';
    const summary =
      'summary' in entry.data && entry.data.summary
        ? entry.data.summary
        : entry.data.description ?? getExcerptFromBody(entry.body, 180);

    return {
      id: `${kind}:${entry.id}`,
      kind,
      title: entry.data.title,
      kicker: kind === 'post' ? getPrimaryCategory(entry as CollectionEntry<'posts'>) : kind === 'note' ? '札记' : '项目',
      date: 'date' in entry.data && entry.data.date ? formatDate(entry.data.date) : undefined,
      href: withBase(`/${basePath}/${entry.id}/`),
      summary,
      Content: rendered.Content,
      toc: rendered.headings
        .filter((heading) => heading.depth <= 3)
        .map((heading) => ({
          href: `#${heading.slug}`,
          className: `depth-${heading.depth}`,
          text: heading.text
        }))
    };
  })
);

const postItems: FeedItem[] = posts.map((post, index) => ({
  id: `post-${post.id}`,
  type: 'post',
  title: post.data.title,
  summary: post.data.summary ?? post.data.description ?? getExcerptFromBody(post.body, index === 0 ? 220 : 130),
  kicker: getPrimaryCategory(post),
  meta: `${formatDate(post.data.date)} / ${getReadingTime(post.body)} min read`,
  href: withBase(`/posts/${post.id}/`),
  drawerId: `post:${post.id}`,
  coverSrc: getPostCover(post),
  tags: post.data.tags.slice(0, 3),
  size: index % 5 === 0 ? 'tall' : index % 3 === 0 ? 'compact' : 'standard'
}));

const noteItems: FeedItem[] = notes.map((note) => ({
  id: `note-${note.id}`,
  type: 'note',
  title: note.data.title,
  summary: note.data.description ?? getExcerptFromBody(note.body, 120),
  kicker: '札记',
  meta: formatDate(note.data.date),
  href: withBase(`/notes/${note.id}/`),
  drawerId: `note:${note.id}`,
  tags: ['note'],
  size: 'compact'
}));

const projectItems: FeedItem[] = projects.map((project) => ({
  id: `project-${project.id}`,
  type: 'project',
  title: project.data.title,
  summary: project.data.description ?? getExcerptFromBody(project.body, 130),
  kicker: `项目 / ${project.data.status}`,
  meta: project.data.stack.slice(0, 3).join(' / '),
  href: withBase(`/projects/${project.id}/`),
  drawerId: `project:${project.id}`,
  tags: project.data.stack.slice(0, 3),
  size: 'standard'
}));

const githubItems: FeedItem[] = github.repos.slice(0, 6).map((repo, index) => ({
  id: `github-${repo.name}`,
  type: 'github',
  githubVariant: 'repo',
  title: repo.name,
  summary: `${repo.language} / ${repo.stars} stars / ${repo.issues} issues`,
  kicker: 'GitHub',
  meta: `更新 ${formatDate(new Date(repo.updatedAt))}`,
  href: repo.htmlUrl,
  drawerId: `github-repo:${repo.name}`,
  accent: ['#660874', '#244a5a', '#3b6b50', '#8e53a2'][index % 4],
  tags: [repo.language],
  size: 'compact'
}));

const githubChartItems: FeedItem[] = [
  {
    id: 'github-heatmap-mini',
    type: 'github',
    githubVariant: 'heatmap',
    title: 'GitHub 活动热力图',
    summary: `${githubAnalytics.totalContributions} 次年度活动 / ${githubAnalytics.activeDays} 个活跃日`,
    kicker: 'GitHub / Heatmap',
    meta: '最近 12 周',
    href: withBase('/github/'),
    drawerId: 'github:heatmap',
    tags: ['heatmap', 'activity'],
    size: 'standard'
  },
  {
    id: 'github-line-mini',
    type: 'github',
    githubVariant: 'line',
    title: '月度贡献折线',
    summary: '从 GitHub 快照派生的月度活动趋势，不在首页重抓数据。',
    kicker: 'GitHub / Line',
    meta: 'monthly',
    href: withBase('/github/'),
    drawerId: 'github:line',
    tags: ['line', 'trend'],
    size: 'compact'
  },
  {
    id: 'github-language-mini',
    type: 'github',
    githubVariant: 'language',
    title: '语言占比',
    summary: githubAnalytics.topLanguage
      ? `${githubAnalytics.topLanguage.label} 当前占比 ${githubAnalytics.topLanguage.percent}%`
      : '语言分布等待快照数据。',
    kicker: 'GitHub / Donut',
    meta: 'languages',
    href: withBase('/github/'),
    drawerId: 'github:language',
    tags: ['donut', 'language'],
    size: 'compact'
  }
];

const bookItems: FeedItem[] = books.map((book) => ({
  id: `book-${toSlug(book.title)}`,
  type: 'book',
  title: book.title,
  summary: book.note,
  kicker: `书架 / ${book.statusLabel}`,
  meta: book.author,
  href: withBase('/books/'),
  drawerId: `book:${toSlug(book.title)}`,
  coverSrc: book.cover,
  tags: [book.statusLabel],
  size: 'compact'
}));

const musicFeedItems: FeedItem[] = musicItems.map((item) => ({
  id: `music-${item.id}`,
  type: 'music',
  title: item.title,
  summary: item.note,
  kicker: `音乐 / ${item.platform}`,
  meta: item.artist,
  href: withBase('/music/'),
  drawerId: `music:${item.id}`,
  musicItem: item,
  coverSrc: item.cover,
  tags: item.mood,
  size: 'compact'
}));

const bilibiliItems: FeedItem[] = [
  {
    id: 'bilibili-profile',
    type: 'bilibili',
    title: profileLinks.bilibiliLabel,
    summary: profileLinks.bilibiliDescription,
    kicker: 'Bilibili',
    meta: profileLinks.bilibiliConfigured ? '视频主页' : '待配置主页链接',
    href: profileLinks.bilibili,
    drawerId: 'bilibili:profile',
    tags: ['video'],
    accent: '#fb7299',
    size: 'compact'
  }
];

const updateItems: FeedItem[] = [
  {
    id: 'update-evidence-library',
    type: 'update',
    title: '史料素材库已经成为独立板块',
    summary: '用于沉淀 OpenList、Remotion、Evidence Resolver 和素材标注的公开说明入口。',
    kicker: 'Update',
    meta: 'evidence-library',
    href: withBase('/evidence-library/'),
    drawerId: 'update:evidence-library',
    tags: ['evidence', 'remotion'],
    size: 'standard'
  }
];

const feedItems = [
  postItems[0],
  ...projectItems.slice(0, 1),
  ...noteItems.slice(0, 1),
  ...bookItems.slice(0, 2),
  githubChartItems[0],
  musicFeedItems[0],
  ...githubItems.slice(0, 2),
  ...postItems.slice(1, 5),
  githubChartItems[1],
  ...bilibiliItems,
  ...updateItems,
  githubChartItems[2],
  ...postItems.slice(5),
  ...projectItems.slice(1),
  ...noteItems.slice(1),
  ...githubItems.slice(2),
  ...bookItems.slice(2),
  ...musicFeedItems.slice(1)
].filter(Boolean) as FeedItem[];

const bookDrawerEntries: DrawerEntry[] = books.map((book: HomeBook) => ({
  id: `book:${toSlug(book.title)}`,
  kind: 'book',
  title: book.title,
  kicker: `书架 / ${book.statusLabel}`,
  href: withBase('/books/'),
  summary: book.note,
  coverSrc: book.cover,
  tags: [book.statusLabel],
  details: [
    { label: '作者', value: book.author },
    { label: '状态', value: book.statusLabel }
  ]
}));

const musicDrawerEntries: DrawerEntry[] = musicItems.map((item) => ({
  id: `music:${item.id}`,
  kind: 'music',
  title: item.title,
  kicker: `音乐 / ${item.platform}`,
  href: withBase('/music/'),
  summary: item.note,
  coverSrc: item.cover,
  tags: item.mood,
  details: [
    { label: 'Artist', value: item.artist },
    ...(item.album ? [{ label: 'Album', value: item.album }] : []),
    { label: 'Platform', value: item.platform }
  ]
}));

const githubDrawerEntries: DrawerEntry[] = [
  {
    id: 'github:heatmap',
    kind: 'github',
    title: 'GitHub 活动热力图',
    kicker: 'GitHub / Heatmap',
    href: withBase('/github/'),
    summary: `${githubAnalytics.totalContributions} 次年度活动，最近 12 周作为首页 mini 图表展示，完整年度热力图在 GitHub 仪表盘里展开。`,
    chartVariant: 'heatmap',
    tags: ['heatmap', 'activity'],
    details: [
      { label: '年度活动', value: String(githubAnalytics.totalContributions) },
      { label: '活跃日', value: String(githubAnalytics.activeDays) }
    ]
  },
  {
    id: 'github:line',
    kind: 'github',
    title: '月度贡献折线',
    kicker: 'GitHub / Line',
    href: withBase('/github/'),
    summary: '从 GitHub snapshot 派生的月度贡献趋势。首页只保留摘要，完整图表进入 /github/。',
    chartVariant: 'line',
    tags: ['line', 'trend']
  },
  {
    id: 'github:language',
    kind: 'github',
    title: '语言占比',
    kicker: 'GitHub / Donut',
    href: withBase('/github/'),
    summary: githubAnalytics.topLanguage
      ? `${githubAnalytics.topLanguage.label} 当前占比 ${githubAnalytics.topLanguage.percent}%，完整语言分布在 /github/。`
      : '语言分布等待 GitHub snapshot 数据。',
    chartVariant: 'language',
    tags: ['donut', 'language']
  },
  ...github.repos.slice(0, 6).map((repo) => ({
    id: `github-repo:${repo.name}`,
    kind: 'github' as const,
    title: repo.name,
    kicker: 'GitHub / Repository',
    href: repo.htmlUrl,
    summary: repo.description || `${repo.language} repository`,
    tags: [repo.language],
    details: [
      { label: 'Stars', value: String(repo.stars) },
      { label: 'Issues', value: String(repo.issues) },
      { label: 'Updated', value: formatDate(new Date(repo.updatedAt)) }
    ]
  }))
];

const utilityDrawerEntries: DrawerEntry[] = [
  {
    id: 'bilibili:profile',
    kind: 'bilibili',
    title: profileLinks.bilibiliLabel,
    kicker: 'Bilibili',
    href: profileLinks.bilibili,
    summary: profileLinks.bilibiliDescription,
    accent: '#fb7299',
    tags: [profileLinks.bilibiliConfigured ? 'configured' : 'pending']
  },
  {
    id: 'update:evidence-library',
    kind: 'update',
    title: '史料素材库已经成为独立板块',
    kicker: 'Update',
    href: withBase('/evidence-library/'),
    summary: '用于沉淀 OpenList、Remotion、Evidence Resolver 和素材标注的公开说明入口。',
    tags: ['evidence', 'remotion']
  }
];

const drawerEntries = [
  ...articleDrawerEntries,
  ...bookDrawerEntries,
  ...musicDrawerEntries,
  ...githubDrawerEntries,
  ...utilityDrawerEntries
];
const drawerById = new Map(drawerEntries.map((entry) => [entry.id, entry]));
const knowledgeDocs = drawerEntries.map((entry) => ({
  id: entry.id,
  type: entry.kind,
  title: entry.title,
  content: [entry.summary, ...(entry.tags ?? []), ...(entry.details?.map((detail) => `${detail.label} ${detail.value}`) ?? [])].join('\n'),
  tags: entry.tags ?? [],
  href: entry.href,
  drawerId: entry.id
}));

function feedCardClass(item: FeedItem) {
  return ['home-feed-card', `home-feed-card--${item.type}`, `home-feed-card--${item.size ?? 'standard'}`].join(' ');
}
---

<BaseLayout title="emptyinkpot" description="emptyinkpot 的首页，聚合文章、书架、项目、GitHub 与视频入口。" hideSiteChrome={true}>
  <div class="home-feed-shell">
    <aside class="home-feed-rail" aria-label="个人展示与站点入口">
      <section class="home-feed-profile">
        <a class="home-feed-brand" href={withBase('/')}>
          <img src={withBase('/images/branding/vita-atramenti-logo.png')} alt="emptyinkpot" />
          <span>emptyinkpot</span>
        </a>
        <img class="home-feed-avatar" src={github.profile.avatarUrl} alt={github.profile.name} />
        <h1>{github.profile.name}</h1>
        <p>个人内容工作台。文章、项目、书架、GitHub 与视频入口混排在一条可连续浏览的信息流里。</p>
      </section>

      <nav class="home-feed-nav" aria-label="站点导航">
        <a href={withBase('/posts/')}>文章</a>
        <a href={withBase('/notes/')}>札记</a>
        <a href={withBase('/projects/')}>项目</a>
        <a href={withBase('/github/')}>GitHub</a>
        <a href={withBase('/books/')}>书架</a>
        <a href={withBase('/music/')}>音乐</a>
        <a href={withBase('/knowledge/')}>知识图谱</a>
        <a href={withBase('/evidence-library/')}>史料素材库</a>
        <a href={withBase('/settings/')}>显示设置</a>
        <a href={withBase('/search/')}>搜索</a>
        <a href={withBase('/about/')}>关于</a>
      </nav>

      <section class="home-feed-rail-card">
        <span>GitHub</span>
        <strong>@{github.profile.login}</strong>
        <p>{github.totalContributions} 次年度活动 / {github.profile.publicRepos} 个公开仓库</p>
        <button type="button" data-drawer-id="github:heatmap">查看仪表盘</button>
      </section>

      <section class="home-feed-rail-card">
        <span>书架</span>
        <strong>{books[0]?.title ?? 'Reading shelf'}</strong>
        <p>{books[0]?.note ?? '正在整理阅读记录。'}</p>
        <button type="button" data-drawer-id={books[0] ? `book:${toSlug(books[0].title)}` : undefined}>打开书架</button>
      </section>

      <section class="home-feed-rail-card">
        <span>音乐</span>
        <strong>{musicItems[0]?.title ?? 'Music shelf'}</strong>
        <p>{musicItems[0]?.note ?? '正在整理音乐记录。'}</p>
        <button type="button" data-drawer-id={musicItems[0] ? `music:${musicItems[0].id}` : undefined}>打开音乐</button>
      </section>

      <section class="home-feed-rail-card">
        <span>Bilibili</span>
        <strong>{profileLinks.bilibiliLabel}</strong>
        <p>{profileLinks.bilibiliDescription}</p>
        <button type="button" data-drawer-id="bilibili:profile">{profileLinks.bilibiliConfigured ? '打开主页' : '稍后配置'}</button>
      </section>
    </aside>

    <main class="home-feed-main" data-pagefind-body>
      <div class="home-feed-toolbar" aria-label="首页内容筛选">
        <div>
          <span>Feed</span>
          <strong>连续浏览</strong>
        </div>
        <div class="home-feed-filters" role="list" aria-label="内容类型">
          <button type="button" class="home-feed-filter home-feed-filter--search" data-search-open>搜索</button>
          <button type="button" class="home-feed-filter is-active" data-feed-filter="all">全部</button>
          <button type="button" class="home-feed-filter" data-feed-filter="post">文章</button>
          <button type="button" class="home-feed-filter" data-feed-filter="note">札记</button>
          <button type="button" class="home-feed-filter" data-feed-filter="project">项目</button>
          <button type="button" class="home-feed-filter" data-feed-filter="book">书架</button>
          <button type="button" class="home-feed-filter" data-feed-filter="music">音乐</button>
          <button type="button" class="home-feed-filter" data-feed-filter="github">GitHub</button>
          <button type="button" class="home-feed-filter" data-feed-filter="bilibili">Bilibili</button>
        </div>
      </div>

      <section class="home-feed-grid" aria-label="内容流">
        {feedItems.map((item) =>
          item.type === 'github' && item.githubVariant === 'heatmap' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
            >
              <div class="bookmark bookmark--github"><span>GitHub</span></div>
              <ChartCard
                kicker={item.kicker}
                title={item.title}
                summary={item.summary}
                metric={item.meta}
                compact
              >
                <GitHubHeatmap weeks={recentHeatmapWeeks} compact />
              </ChartCard>
            </button>
          ) : item.type === 'github' && item.githubVariant === 'line' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
            >
              <div class="bookmark bookmark--github"><span>Line</span></div>
              <ChartCard kicker={item.kicker} title={item.title} summary={item.summary} compact>
                <GitHubMonthlyLine points={githubAnalytics.monthly} compact />
              </ChartCard>
            </button>
          ) : item.type === 'github' && item.githubVariant === 'language' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
            >
              <div class="bookmark bookmark--github"><span>Donut</span></div>
              <ChartCard kicker={item.kicker} title={item.title} summary={item.summary} compact>
                <GitHubLanguageDonut languages={githubAnalytics.languages} compact />
              </ChartCard>
            </button>
          ) : item.type === 'music' && item.musicItem ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
            >
              <div class="bookmark bookmark--music"><span>Music</span></div>
              <MusicCard item={item.musicItem} compact inertCard />
            </button>
          ) : item.drawerId && drawerById.has(item.drawerId) ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
            >
              <div class={`bookmark bookmark--${item.type}`}><span>{item.type}</span></div>
              {item.coverSrc ? (
                <div class="home-feed-card__cover">
                  <img src={item.coverSrc} alt="" loading="lazy" />
                </div>
              ) : (
                <div class="home-feed-card__mark" style={item.accent ? `--feed-accent:${item.accent}` : undefined}>
                  {item.type}
                </div>
              )}
              <div class="home-feed-card__body">
                <div class="home-feed-card__meta">
                  <span>{item.kicker}</span>
                  {item.meta && <small>{item.meta}</small>}
                </div>
                <h2>{item.title}</h2>
                <p>{item.summary}</p>
                {item.tags?.length ? (
                  <div class="home-feed-card__tags">
                    {item.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                ) : null}
              </div>
            </button>
          ) : (
            <a
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              href={item.href ?? withBase('/')}
            >
              {item.coverSrc ? (
                <div class="home-feed-card__cover">
                  <img src={item.coverSrc} alt="" loading="lazy" />
                </div>
              ) : (
                <div class="home-feed-card__mark" style={item.accent ? `--feed-accent:${item.accent}` : undefined}>
                  {item.type}
                </div>
              )}
              <div class="home-feed-card__body">
                <div class="home-feed-card__meta">
                  <span>{item.kicker}</span>
                  {item.meta && <small>{item.meta}</small>}
                </div>
                <h2>{item.title}</h2>
                <p>{item.summary}</p>
                {item.tags?.length ? (
                  <div class="home-feed-card__tags">
                    {item.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                ) : null}
              </div>
            </a>
          )
        )}
      </section>
    </main>
  </div>

  <div class="home-article-layer" data-article-layer hidden>
    <button class="home-article-backdrop" type="button" data-article-close aria-label="关闭阅读抽屉"></button>
    <aside class="home-article-drawer" role="dialog" aria-modal="true" aria-labelledby="home-article-title">
      <div class="reading-progress" data-reading-progress></div>
      <header class="home-article-drawer__header">
        <div>
          <span data-article-kicker></span>
          <h2 id="home-article-title" data-article-title></h2>
        </div>
        <div class="home-article-drawer__actions">
          <div class="reader-theme-switch" aria-label="阅读主题">
            <button type="button" data-reader-theme="light">Light</button>
            <button type="button" data-reader-theme="sepia">Sepia</button>
            <button type="button" data-reader-theme="dark">Dark</button>
          </div>
          <button type="button" data-reader-bookmark>收藏</button>
          <a href={withBase('/posts/')} data-article-full>完整页面</a>
          <button type="button" data-article-close>关闭</button>
        </div>
      </header>
      <div class="home-article-drawer__body" data-article-body></div>
    </aside>
  </div>

  <div class="knowledge-search-layer" data-search-layer hidden>
    <button class="knowledge-search-backdrop" type="button" data-search-close aria-label="关闭搜索"></button>
    <section class="knowledge-search-panel" role="dialog" aria-modal="true" aria-label="Knowledge search">
      <div class="knowledge-search-input-row">
        <input type="search" data-search-input placeholder="搜索文章、项目、书架、音乐、GitHub、标记..." />
        <kbd>Esc</kbd>
      </div>
      <nav class="knowledge-search-tabs" aria-label="搜索类型">
        {['all', 'post', 'note', 'project', 'book', 'music', 'github', 'highlight'].map((kind) => (
          <button type="button" class={kind === 'all' ? 'is-active' : ''} data-search-kind={kind}>{kind}</button>
        ))}
      </nav>
      <div class="knowledge-search-results" data-search-results>
        <p class="knowledge-search-empty">输入关键词，或按 Cmd/Ctrl + K 随时打开搜索。</p>
      </div>
    </section>
  </div>

  <div class="selection-toolbar" data-selection-toolbar hidden>
    <button type="button" data-highlight-color="gold">金</button>
    <button type="button" data-highlight-color="purple">紫</button>
    <button type="button" data-highlight-color="green">绿</button>
    <button type="button" data-open-annotation>批注</button>
    <button type="button" data-copy-selection>复制</button>
  </div>

  <script type="application/json" id="knowledge-search-data" set:html={JSON.stringify(knowledgeDocs)} />

  <div class="home-article-templates" hidden>
    {drawerEntries.map((entry) => {
      const Content = entry.Content;

      return (
        <article
          class="home-article-reader"
          data-drawer-template={entry.id}
          data-article-id={entry.id}
          data-full-href={entry.href}
          data-kicker={entry.kicker}
          data-title={entry.title}
        >
          <header class="home-article-intro">
            <span>{entry.kicker}</span>
            <h1>{entry.title}</h1>
            <p>{entry.summary}</p>
            {entry.date && <small>{entry.date}</small>}
          </header>
          {Content ? (
            <div class="home-article-reader__grid">
              <nav class="home-article-toc" aria-label="文章目录">
                <strong>目录</strong>
                {entry.toc?.length ? (
                  entry.toc.map((heading) => (
                    <a href={heading.href} class={heading.className}>
                      {heading.text}
                    </a>
                  ))
                ) : (
                  <span>暂无标题</span>
                )}
              </nav>
              <div class="home-article-content prose-shell prose-shell--plain">
                <Content />
              </div>
            </div>
          ) : (
            <div class="home-drawer-summary">
              {entry.coverSrc ? (
                <div class:list={['home-drawer-summary__media', entry.kind === 'music' && 'home-drawer-summary__media--round']}>
                  <img src={entry.coverSrc} alt="" loading="lazy" />
                </div>
              ) : (
                <div class="home-drawer-summary__mark" style={entry.accent ? `--feed-accent:${entry.accent}` : undefined}>
                  {entry.kind}
                </div>
              )}
              <div class="home-drawer-summary__main">
                {entry.chartVariant === 'heatmap' && (
                  <ChartCard kicker={entry.kicker} title={entry.title} summary={entry.summary} metric="全年" compact>
                    <GitHubHeatmap weeks={githubAnalytics.heatmapWeeks} />
                  </ChartCard>
                )}
                {entry.chartVariant === 'line' && (
                  <ChartCard kicker={entry.kicker} title={entry.title} summary={entry.summary} compact>
                    <GitHubMonthlyLine points={githubAnalytics.monthly} />
                  </ChartCard>
                )}
                {entry.chartVariant === 'language' && (
                  <ChartCard kicker={entry.kicker} title={entry.title} summary={entry.summary} compact>
                    <GitHubLanguageDonut languages={githubAnalytics.languages} />
                  </ChartCard>
                )}
                {!entry.chartVariant && (
                  <>
                    {entry.details?.length ? (
                      <dl class="home-drawer-summary__details">
                        {entry.details.map((detail) => (
                          <div>
                            <dt>{detail.label}</dt>
                            <dd>{detail.value}</dd>
                          </div>
                        ))}
                      </dl>
                    ) : null}
                    {entry.tags?.length ? (
                      <div class="home-feed-card__tags">
                        {entry.tags.map((tag) => <span>{tag}</span>)}
                      </div>
                    ) : null}
                  </>
                )}
              </div>
            </div>
          )}
        </article>
      );
    })}
  </div>

  <script>
    (() => {
      const layer = document.querySelector('[data-article-layer]');
      const drawerBody = document.querySelector('[data-article-body]');
      const titleTarget = document.querySelector('[data-article-title]');
      const kickerTarget = document.querySelector('[data-article-kicker]');
      const fullLink = document.querySelector('[data-article-full]');
      const bookmarkButton = document.querySelector('[data-reader-bookmark]');
      const progress = document.querySelector('[data-reading-progress]');
      const filterButtons = [...document.querySelectorAll('[data-feed-filter]')];
      const cards = [...document.querySelectorAll('[data-feed-card]')];
      const drawerTriggers = [...document.querySelectorAll('[data-drawer-id]')];
      const mainScroller = document.querySelector('.home-feed-main');
      const searchLayer = document.querySelector('[data-search-layer]');
      const searchInput = document.querySelector('[data-search-input]');
      const searchResults = document.querySelector('[data-search-results]');
      const searchKinds = [...document.querySelectorAll('[data-search-kind]')];
      const selectionToolbar = document.querySelector('[data-selection-toolbar]');
      const searchDocs = JSON.parse(document.getElementById('knowledge-search-data')?.textContent || '[]');
      const storageKeys = {
        history: 'emptyinkpot-reading-history',
        bookmarks: 'emptyinkpot-reader-bookmarks',
        highlights: 'emptyinkpot-reader-highlights',
        annotations: 'emptyinkpot-reader-annotations',
        readerTheme: 'emptyinkpot-reader-theme'
      };
      const drawerTransitionMs = 180;
      const searchTransitionMs = 120;
      let lastFocused = null;
      let savedScrollTop = 0;
      let currentArticle = null;
      let activeIndex = 0;
      let searchKind = 'all';
      let selectedRange = null;
      let drawerCloseTimer = 0;
      let searchCloseTimer = 0;

      const readJson = (key, fallback) => {
        try {
          return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
        } catch {
          return fallback;
        }
      };

      const writeJson = (key, value) => {
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch {
          // Ignore local storage failures; reading should still work.
        }
      };

      const normalizeReaderTheme = (theme) => (['light', 'sepia', 'dark'].includes(theme) ? theme : 'light');

      const applyReaderTheme = (theme) => {
        const next = normalizeReaderTheme(theme);
        document.documentElement.dataset.readerTheme = next;
        document.querySelectorAll('[data-reader-theme]').forEach((button) => {
          button.classList.toggle('is-active', button.dataset.readerTheme === next);
        });
        try {
          localStorage.setItem(storageKeys.readerTheme, next);
        } catch {
          // Ignore storage failures.
        }
      };

      const getVisibleCards = () => cards.filter((card) => !card.hidden);

      const setActiveCard = (index) => {
        const visibleCards = getVisibleCards();
        if (!visibleCards.length) return;
        cards.forEach((card) => card.classList.remove('feed-card--active'));
        activeIndex = Math.max(0, Math.min(index, visibleCards.length - 1));
        const card = visibleCards[activeIndex];
        card.classList.add('feed-card--active');
        card.scrollIntoView({ block: 'center', behavior: 'smooth' });
      };

      const saveHistory = (article) => {
        if (!article?.id) return;
        const list = readJson(storageKeys.history, []);
        const next = [{ id: article.id, title: article.title, href: article.href, timestamp: Date.now() }, ...list.filter((item) => item.id !== article.id)].slice(0, 50);
        writeJson(storageKeys.history, next);
      };

      const getBookmarks = () => readJson(storageKeys.bookmarks, []);

      const isBookmarked = (id) => getBookmarks().some((item) => item.id === id);

      const updateBookmarkButton = () => {
        if (!bookmarkButton || !currentArticle) return;
        const active = isBookmarked(currentArticle.id);
        bookmarkButton.classList.toggle('is-active', active);
        bookmarkButton.textContent = active ? '已收藏' : '收藏';
      };

      const toggleBookmark = () => {
        if (!currentArticle) return;
        const list = getBookmarks();
        const exists = list.some((item) => item.id === currentArticle.id);
        const next = exists
          ? list.filter((item) => item.id !== currentArticle.id)
          : [{ id: currentArticle.id, title: currentArticle.title, href: currentArticle.href, createdAt: Date.now() }, ...list];
        writeJson(storageKeys.bookmarks, next);
        updateBookmarkButton();
      };

      const updateReadingProgress = () => {
        if (!drawerBody || !progress) return;
        const max = drawerBody.scrollHeight - drawerBody.clientHeight;
        const ratio = max > 0 ? drawerBody.scrollTop / max : 0;
        progress.style.transform = `scaleX(${Math.max(0, Math.min(1, ratio))})`;
      };

      const applyStoredHighlights = () => {
        if (!drawerBody || !currentArticle) return;
        const root = drawerBody.querySelector('.home-article-content');
        if (!root) return;
        const highlights = readJson(storageKeys.highlights, []).filter((item) => item.articleId === currentArticle.id);
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
        const textNodes = [];
        let node = walker.nextNode();
        while (node) {
          textNodes.push(node);
          node = walker.nextNode();
        }
        highlights.forEach((item) => {
          const target = textNodes.find((textNode) => textNode.nodeValue?.includes(item.text));
          if (!target || target.parentElement?.closest('mark')) return;
          const start = target.nodeValue.indexOf(item.text);
          if (start < 0) return;
          const range = document.createRange();
          range.setStart(target, start);
          range.setEnd(target, start + item.text.length);
          const mark = document.createElement('mark');
          mark.className = `reader-highlight reader-highlight--${item.color || 'gold'}`;
          mark.dataset.highlightId = item.id;
          try {
            mark.append(range.extractContents());
            range.insertNode(mark);
          } catch {
            // If a text node changed, keep the stored highlight but skip rendering.
          }
        });
      };

      const hideSelectionToolbar = () => {
        if (selectionToolbar) selectionToolbar.hidden = true;
        selectedRange = null;
      };

      const showSelectionToolbar = () => {
        if (!currentArticle || !drawerBody || !selectionToolbar) return;
        const selection = window.getSelection();
        const text = selection?.toString().trim() || '';
        if (text.length < 10 || text.length > 240 || !selection.rangeCount) {
          hideSelectionToolbar();
          return;
        }
        const range = selection.getRangeAt(0);
        if (!drawerBody.contains(range.commonAncestorContainer)) {
          hideSelectionToolbar();
          return;
        }
        selectedRange = range.cloneRange();
        const rect = range.getBoundingClientRect();
        selectionToolbar.hidden = false;
        const left = Math.min(window.innerWidth - selectionToolbar.offsetWidth - 12, Math.max(12, rect.left));
        const top = Math.max(12, rect.top - selectionToolbar.offsetHeight - 10);
        selectionToolbar.style.left = `${left}px`;
        selectionToolbar.style.top = `${top}px`;
      };

      const saveSelectionHighlight = (color = 'gold', note = '') => {
        if (!currentArticle || !drawerBody) return;
        const selection = window.getSelection();
        const range = selectedRange || (selection?.rangeCount ? selection.getRangeAt(0) : null);
        const text = range?.toString().trim() || '';
        if (!range || text.length < 10 || text.length > 240) return;
        if (!drawerBody.contains(range.commonAncestorContainer)) return;
        const record = {
          id: `${currentArticle.id}:${Date.now()}`,
          articleId: currentArticle.id,
          title: currentArticle.title,
          text,
          color,
          anchor: {
            quote: { type: 'TextQuoteSelector', exact: text, prefix: '', suffix: '' },
            position: { type: 'TextPositionSelector', start: 0, end: text.length },
            dom: { type: 'DomPathSelector', startPath: [], startOffset: 0, endPath: [], endOffset: 0 },
            contentHash: ''
          },
          createdAt: Date.now(),
          updatedAt: Date.now()
        };
        const mark = document.createElement('mark');
        mark.className = `reader-highlight reader-highlight--${color}`;
        mark.dataset.highlightId = record.id;
        try {
          mark.append(range.extractContents());
          range.insertNode(mark);
          selection?.removeAllRanges();
        } catch {
          return;
        }
        writeJson(storageKeys.highlights, [record, ...readJson(storageKeys.highlights, [])]);
        if (note.trim()) {
          const annotation = {
            id: `annotation:${record.id}`,
            articleId: currentArticle.id,
            highlightId: record.id,
            body: note.trim(),
            color,
            tags: [],
            createdAt: Date.now(),
            updatedAt: Date.now()
          };
          writeJson(storageKeys.annotations, [annotation, ...readJson(storageKeys.annotations, [])]);
        }
        hideSelectionToolbar();
      };

      const search = (query) => {
        const q = query.trim().toLowerCase();
        if (!q) return [];
        const storedHighlights = readJson(storageKeys.highlights, []).map((item) => ({
          id: item.id,
          type: 'highlight',
          title: item.title,
          content: item.text,
          tags: ['highlight'],
          drawerId: item.articleId
        }));
        return [...searchDocs, ...storedHighlights]
          .filter((doc) => searchKind === 'all' || doc.type === searchKind)
          .map((doc) => {
            const content = [doc.title, doc.content, ...(doc.tags || [])].join(' ').toLowerCase();
            const score = (doc.title?.toLowerCase().includes(q) ? 5 : 0) + (content.includes(q) ? 1 : 0);
            return { doc, score };
          })
          .filter((item) => item.score > 0)
          .sort((a, b) => b.score - a.score)
          .map((item) => item.doc)
          .slice(0, 24);
      };

      const renderSearch = () => {
        if (!searchInput || !searchResults) return;
        const results = search(searchInput.value || '');
        if (!results.length) {
          searchResults.innerHTML = '<p class="knowledge-search-empty">输入关键词，搜索文章、项目、书架、音乐、GitHub 和本地标记。</p>';
          return;
        }
        searchResults.replaceChildren(
          ...results.map((doc) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'knowledge-search-result';
            button.innerHTML = `<span>${doc.type}</span><strong></strong><small></small>`;
            button.querySelector('strong').textContent = doc.title;
            button.querySelector('small').textContent = String(doc.content || '').slice(0, 150);
            button.addEventListener('click', () => {
              if (doc.drawerId) {
                openDrawer(doc.drawerId, button);
                closeSearch();
              } else if (doc.href) {
                window.location.href = doc.href;
              }
            });
            return button;
          })
        );
      };

      const openSearch = () => {
        if (!searchLayer || !searchInput) return;
        window.clearTimeout(searchCloseTimer);
        searchLayer.hidden = false;
        requestAnimationFrame(() => {
          searchLayer.classList.add('is-open');
          searchInput.focus({ preventScroll: true });
        });
        renderSearch();
      };

      const closeSearch = () => {
        if (!searchLayer) return;
        searchLayer.classList.remove('is-open');
        window.clearTimeout(searchCloseTimer);
        searchCloseTimer = window.setTimeout(() => {
          searchLayer.hidden = true;
        }, searchTransitionMs);
      };

      const setFilter = (kind) => {
        filterButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.feedFilter === kind));
        cards.forEach((card) => {
          const visible = kind === 'all' || card.dataset.feedKind === kind;
          card.hidden = !visible;
        });
        activeIndex = 0;
      };

      const closeDrawer = () => {
        if (!layer) return;
        hideSelectionToolbar();
        layer.classList.remove('is-open');
        window.clearTimeout(drawerCloseTimer);
        drawerCloseTimer = window.setTimeout(() => {
          layer.hidden = true;
          document.body.classList.remove('has-home-article-drawer');
          drawerBody?.replaceChildren();
          currentArticle = null;
          if (mainScroller) {
            mainScroller.scrollTop = savedScrollTop;
          }
          if (lastFocused instanceof HTMLElement) {
            lastFocused.focus({ preventScroll: true });
          }
          if (mainScroller) {
            requestAnimationFrame(() => {
              mainScroller.scrollTop = savedScrollTop;
            });
          }
        }, drawerTransitionMs);
      };

      const openDrawer = (id, trigger) => {
        const template = [...document.querySelectorAll('[data-drawer-template]')].find(
          (node) => node.dataset.drawerTemplate === id
        );
        if (!template || !drawerBody || !layer) return;

        const content = template.cloneNode(true);
        content.removeAttribute('data-drawer-template');
        const reader = content.matches('.home-article-reader') ? content : content.querySelector('.home-article-reader');
        const title = reader?.dataset.title ?? '';
        const kicker = reader?.dataset.kicker ?? '';
        const href = reader?.dataset.fullHref ?? '#';
        const articleId = reader?.dataset.articleId ?? id;
        lastFocused = trigger;
        savedScrollTop = mainScroller?.scrollTop ?? 0;
        currentArticle = { id: articleId, title, href };

        drawerBody.replaceChildren(content);
        if (titleTarget) titleTarget.textContent = title;
        if (kickerTarget) kickerTarget.textContent = kicker;
        if (fullLink) fullLink.setAttribute('href', href);
        window.clearTimeout(drawerCloseTimer);
        layer.hidden = false;
        document.body.classList.add('has-home-article-drawer');
        requestAnimationFrame(() => {
          layer.classList.add('is-open');
        });
        saveHistory(currentArticle);
        updateBookmarkButton();
        updateReadingProgress();
        requestAnimationFrame(applyStoredHighlights);
        layer.querySelector('[data-article-close]')?.focus({ preventScroll: true });
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => setFilter(button.dataset.feedFilter || 'all'));
      });

      drawerTriggers.forEach((trigger) => {
        trigger.addEventListener('click', (event) => {
          const id = trigger.dataset.drawerId;
          if (!id) return;
          event.preventDefault();
          openDrawer(id, trigger);
        });
      });

      document.querySelectorAll('[data-search-open]').forEach((button) => {
        button.addEventListener('click', openSearch);
      });

      document.querySelectorAll('[data-search-close]').forEach((button) => {
        button.addEventListener('click', closeSearch);
      });

      searchInput?.addEventListener('input', renderSearch);

      searchKinds.forEach((button) => {
        button.addEventListener('click', () => {
          searchKind = button.dataset.searchKind || 'all';
          searchKinds.forEach((item) => item.classList.toggle('is-active', item === button));
          renderSearch();
        });
      });

      document.querySelectorAll('[data-reader-theme]').forEach((button) => {
        button.addEventListener('click', () => applyReaderTheme(button.dataset.readerTheme));
      });

      bookmarkButton?.addEventListener('click', toggleBookmark);
      drawerBody?.addEventListener('scroll', updateReadingProgress);
      drawerBody?.addEventListener('mouseup', () => setTimeout(showSelectionToolbar, 0));

      selectionToolbar?.querySelectorAll('[data-highlight-color]').forEach((button) => {
        button.addEventListener('click', () => saveSelectionHighlight(button.dataset.highlightColor || 'gold'));
      });

      selectionToolbar?.querySelector('[data-open-annotation]')?.addEventListener('click', () => {
        const note = window.prompt('写下这条标记的批注');
        if (note !== null) saveSelectionHighlight('gold', note);
      });

      selectionToolbar?.querySelector('[data-copy-selection]')?.addEventListener('click', async () => {
        const text = selectedRange?.toString().trim();
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          // Clipboard can be unavailable in some preview contexts.
        }
        hideSelectionToolbar();
      });

      document.querySelectorAll('[data-article-close]').forEach((button) => {
        button.addEventListener('click', closeDrawer);
      });

      document.addEventListener('keydown', (event) => {
        const target = event.target;
        const isTyping = target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement;
        const commandSearch = (event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k';
        if (commandSearch) {
          event.preventDefault();
          openSearch();
          return;
        }
        if (event.key === 'Escape' && !searchLayer?.hidden) {
          closeSearch();
          return;
        }
        if (event.key === 'Escape' && !layer?.hidden) {
          closeDrawer();
          return;
        }
        if (isTyping || !layer?.hidden || !searchLayer?.hidden) return;
        if (event.key.toLowerCase() === 'j') {
          event.preventDefault();
          setActiveCard(activeIndex + 1);
        }
        if (event.key.toLowerCase() === 'k') {
          event.preventDefault();
          setActiveCard(activeIndex - 1);
        }
        if (event.key === 'Enter') {
          const visibleCards = getVisibleCards();
          const card = visibleCards[activeIndex];
          const id = card?.dataset.drawerId;
          if (id) {
            event.preventDefault();
            openDrawer(id, card);
          }
        }
      });

      applyReaderTheme(localStorage.getItem(storageKeys.readerTheme) || 'light');
    })();
  </script>
</BaseLayout>
