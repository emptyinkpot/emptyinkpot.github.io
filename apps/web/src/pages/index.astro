---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeWorkbenchHero from '../components/home/HomeWorkbenchHero.astro';
import HomeWorkbenchLatestPosts from '../components/home/HomeWorkbenchLatestPosts.astro';
import HomeWorkbenchMaintenance from '../components/home/HomeWorkbenchMaintenance.astro';
import HomeWorkbenchPlanned from '../components/home/HomeWorkbenchPlanned.astro';
import HomeWorkbenchProjectNotes from '../components/home/HomeWorkbenchProjectNotes.astro';
import HomeWorkbenchRoutes from '../components/home/HomeWorkbenchRoutes.astro';
import HomeWorkbenchScripts from '../components/home/HomeWorkbenchScripts.astro';
import HomeWorkbenchSearch from '../components/home/HomeWorkbenchSearch.astro';
import HomeWorkbenchSidebar from '../components/home/HomeWorkbenchSidebar.astro';
import HomeWorkbenchSignals from '../components/home/HomeWorkbenchSignals.astro';
import HomeWorkbenchTaxonomy from '../components/home/HomeWorkbenchTaxonomy.astro';
import HomeWorkbenchUtility from '../components/home/HomeWorkbenchUtility.astro';
import { formatDate, getExcerptFromBody, getPrimaryCategory } from '../lib/content';
import { getHomePagePayload } from '../lib/home';
import { getPostCover } from '../lib/postCovers';
import { withBase } from '../lib/site';

const payload = await getHomePagePayload();

const sideNavItems = [
  { label: '首页', href: withBase('/') },
  { label: '文章', href: withBase('/posts') },
  { label: '专题', href: withBase('/series') },
  { label: '项目', href: withBase('/projects') },
  { label: '更新', href: withBase('/updates') },
  { label: '搜索', href: withBase('/search') },
  { label: '关于', href: withBase('/about') }
];

const topicCards = payload.topics.map((topic) => ({
  kicker: 'TOPICS',
  title: topic.label,
  meta: `${topic.count} 篇内容`,
  href: topic.href
}));

const seriesCards = payload.series.map((series) => ({
  kicker: 'SERIES',
  title: series.label,
  meta: `${series.count} 篇连续内容`,
  href: series.href
}));

const routeTopCards = payload.routeCards.slice(0, 3);
const routeBottomCards = payload.routeCards.slice(3);

const activeProject = payload.activeProject;
const latestNote = payload.latestNotes[0];
const latestPostCards = payload.latestPosts.map((post) => ({
  href: withBase(`/posts/${post.id}/`),
  title: post.data.title,
  date: formatDate(post.data.date),
  category: getPrimaryCategory(post),
  summary: post.data.summary ?? post.data.description ?? getExcerptFromBody(post.body, 92),
  coverSrc: getPostCover(post)
}));
---

<BaseLayout title="emptyinkpot" description="emptyinkpot 的首页，聚合文章、专题、项目与阶段笔记。" hideSiteChrome={true}>
  <div class="home-editorial-shell">
    <HomeWorkbenchSidebar items={sideNavItems} />

    <main class="home-editorial-page" data-pagefind-body>
      <div class="home-editorial-page__inner home-workbench">
        <HomeWorkbenchSearch filters={payload.quickFilters} />
        <HomeWorkbenchUtility friendlySites={payload.friendlySites} teams={payload.teams} />
        <HomeWorkbenchHero
          hero={payload.hero}
          snapshot={payload.snapshot}
          checkIn={payload.checkIn}
          github={payload.github}
          featuredPost={payload.featuredPost}
        />
        <HomeWorkbenchLatestPosts posts={latestPostCards} />
        <HomeWorkbenchTaxonomy topics={topicCards} series={seriesCards} />
        <HomeWorkbenchProjectNotes activeProject={activeProject} latestNote={latestNote} />
        <HomeWorkbenchMaintenance items={payload.maintenanceItems} />
        <HomeWorkbenchSignals teams={payload.teams} />
        <HomeWorkbenchRoutes topCards={routeTopCards} bottomCards={routeBottomCards} />
        <HomeWorkbenchPlanned cards={payload.plannedCards} />
      </div>
    </main>
  </div>
  <HomeWorkbenchScripts />
</BaseLayout>
