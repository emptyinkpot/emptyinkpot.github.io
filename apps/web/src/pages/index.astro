        <div>
          <span data-copy-key="home.feed.kicker">Feed</span>
          <strong data-copy-key="home.feed.title">连续浏览</strong>
        </div>
        <nav class="home-feed-tabs" aria-label="首页唯一导航">
          <HomeCommandPalette client:idle commands={homeCommands} />
          <button type="button" class="home-feed-tab is-active" data-feed-filter="all" data-copy-key="home.feed.all">全部</button>
          <button type="button" class="home-feed-tab" data-feed-filter="post" data-copy-key="home.feed.post">文章</button>
          <button type="button" class="home-feed-tab" data-feed-filter="note" data-copy-key="home.feed.note">笔记</button>
          <button type="button" class="home-feed-tab" data-feed-filter="project" data-copy-key="home.feed.project">项目工坊</button>
          <button type="button" class="home-feed-tab" data-feed-filter="book" data-copy-key="home.feed.book">书架</button>
          <button type="button" class="home-feed-tab" data-feed-filter="music" data-copy-key="home.feed.music">音乐</button>
          <button type="button" class="home-feed-tab" data-feed-filter="github" data-copy-key="home.feed.github">GitHub</button>
          <button type="button" class="home-feed-tab" data-feed-filter="visual">视觉素材</button>
          {profileLinks.bilibiliConfigured && <button type="button" class="home-feed-tab" data-feed-filter="bilibili" data-copy-key="home.feed.bilibili">Bilibili</button>}
          <button type="button" class="home-feed-tab" data-feed-filter="update" data-copy-key="home.feed.evidence">史料素材库</button>
          <button type="button" class="home-feed-tab home-feed-tab--openlist" data-openlist-embed-open>OpenList</button>
        </nav>
      </div>

      <section class="home-feed-grid" aria-label="内容流">
        {feedItems.map((item) =>
          item.type === 'github' && item.githubVariant === 'heatmap' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-github-repo-card={item.githubVariant === 'repo' ? item.title : undefined}
              {...hoverPreviewAttrs(item)}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--github"><span>GitHub</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <span class="card-paperclip" aria-hidden="true"></span>
              <ChartCard
                kicker={item.kicker}
                title={item.title}
                summary={item.summary}
                metric={item.meta}
                compact
              >
                <GitHubHeatmap weeks={recentHeatmapWeeks} compact />
              </ChartCard>
            </button>
          ) : item.type === 'github' && item.githubVariant === 'line' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              {...hoverPreviewAttrs(item)}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--github"><span>Line</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <span class="card-paperclip" aria-hidden="true"></span>
              <ChartCard kicker={item.kicker} title={item.title} summary={item.summary} compact>
                <GitHubMonthlyLine points={githubAnalytics.monthly} compact />
              </ChartCard>
            </button>
          ) : item.type === 'github' && item.githubVariant === 'language' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              {...hoverPreviewAttrs(item)}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--github"><span>Donut</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <span class="card-paperclip" aria-hidden="true"></span>
              <ChartCard kicker={item.kicker} title={item.title} summary={item.summary} compact>
                <GitHubLanguageDonut languages={githubAnalytics.languages} compact />
              </ChartCard>
            </button>
          ) : item.type === 'visual' && item.visualItem ? (
            <button
              type="button"
              class={`${feedCardClass(item)} visual-feed-card`}
              data-feed-card
              data-feed-kind={item.type}
              {...hoverPreviewAttrs(item)}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
              style={`--visual-accent:${item.visualItem.palette.dominant}`}
            >
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <span class="card-paperclip" aria-hidden="true"></span>
              <div class="visual-feed-card__media">
                <img src={item.visualItem.image} alt="" loading="lazy" />
              </div>
              <div class="visual-feed-card__overlay">
                <small>{item.kicker}</small>
                <h2>{item.title}</h2>
                <p>{item.summary}</p>
                <div class="visual-feed-card__palette" aria-label="调色板">
                  {item.visualItem.palette.colors.slice(0, 5).map((color) => <i style={`background:${color}`}></i>)}
                </div>
                <div class="home-feed-card__tags">
                  {item.tags?.slice(0, 4).map((tag) => <span>{tag}</span>)}
                </div>
              </div>
            </button>
          ) : item.type === 'music' && item.musicItem ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              {...hoverPreviewAttrs(item)}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--music"><span>Music</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <span class="card-paperclip" aria-hidden="true"></span>
              <MusicCard item={item.musicItem} compact inertCard />
            </button>
          ) : item.drawerId && drawerById.has(item.drawerId) ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              {...hoverPreviewAttrs(item)}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class={`bookmark bookmark--${item.type}`}><span>{item.type}</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <span class="card-paperclip" aria-hidden="true"></span>
              {item.coverSrc ? (
                <div class:list={['home-feed-card__cover', item.type === 'book' && 'home-feed-card__cover--book']}>
                  <img src={item.coverSrc} alt="" loading="lazy" />
                </div>
              ) : item.type === 'book' ? (
                <div class="home-feed-book-cover" aria-hidden="true">
                  <span>{item.tags?.[0] ?? 'Book'}</span>
                  <strong>{item.title}</strong>
                  <small>{item.meta}</small>
                </div>
              ) : (
                <div class="home-feed-card__mark" style={item.accent ? `--feed-accent:${item.accent}` : undefined}>
                  {item.type}
                </div>
              )}
              <div class="home-feed-card__body">
                <div class="home-feed-card__meta">
                  <span>{item.kicker}</span>
                  {item.meta && <small>{item.meta}</small>}
                </div>
                <h2>{item.title}</h2>
                <p>{item.summary}</p>
                {item.tags?.length ? (
                  <div class="home-feed-card__tags">
                    {item.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                ) : null}
              </div>
            </button>
          ) : (
            <a
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              {...hoverPreviewAttrs(item)}
              data-seal-target={item.drawerId ?? item.href ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
              href={item.href ?? withBase('/')}
            >
              <div class={`bookmark bookmark--${item.type}`}><span>{item.type}</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <span class="card-paperclip" aria-hidden="true"></span>
              {item.coverSrc ? (
                <div class:list={['home-feed-card__cover', item.type === 'book' && 'home-feed-card__cover--book']}>
                  <img src={item.coverSrc} alt="" loading="lazy" />
                </div>
              ) : item.type === 'book' ? (
                <div class="home-feed-book-cover" aria-hidden="true">
                  <span>{item.tags?.[0] ?? 'Book'}</span>
                  <strong>{item.title}</strong>
                  <small>{item.meta}</small>
                </div>
              ) : (
                <div class="home-feed-card__mark" style={item.accent ? `--feed-accent:${item.accent}` : undefined}>
                  {item.type}
                </div>
              )}
              <div class="home-feed-card__body">
                <div class="home-feed-card__meta">
                  <span>{item.kicker}</span>
                  {item.meta && <small>{item.meta}</small>}
                </div>
                <h2>{item.title}</h2>
                <p>{item.summary}</p>
                {item.tags?.length ? (
                  <div class="home-feed-card__tags">
                    {item.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                ) : null}
              </div>
            </a>
          )
        )}
      </section>
    </main>
  </div>

  <div class="home-article-layer" data-article-layer hidden>
    <button class="home-article-backdrop" type="button" data-article-close aria-label="关闭阅读抽屉"></button>
    <aside class="home-article-drawer" role="dialog" aria-modal="true" aria-labelledby="home-article-title">
      <div class="reading-progress" data-reading-progress></div>
      <header class="home-article-drawer__header">
        <div>
          <span data-article-kicker></span>
          <h2 id="home-article-title" data-article-title></h2>
        </div>
        <div class="home-article-drawer__actions">
          <div class="reader-theme-switch" aria-label="阅读主题">
            <button type="button" data-reader-theme="light">Light</button>
            <button type="button" data-reader-theme="sepia">Sepia</button>
            <button type="button" data-reader-theme="dark">Dark</button>
          </div>
          <button type="button" data-reader-bookmark>收藏</button>
          <button type="button" data-reader-seal>盖章</button>
          <a href={withBase('/knowledge/')} data-reader-graph>知识图谱</a>
          <a href={withBase('/posts/')} data-article-full>完整页面</a>
          <a href={withBase('/books/')} data-article-read hidden>开始阅读</a>
          <a href={withBase('/books/')} data-article-shelf hidden>完整书架</a>
          <button type="button" data-article-close>关闭</button>
        </div>
      </header>
      <div class="home-article-drawer__body" data-article-body></div>
    </aside>
  </div>

  <div class="knowledge-search-layer" data-search-layer hidden>
    <button class="knowledge-search-backdrop" type="button" data-search-close aria-label="关闭搜索"></button>
    <section class="knowledge-search-panel" role="dialog" aria-modal="true" aria-label="Knowledge search">
      <div class="knowledge-search-input-row">
        <input type="search" name="knowledge-search" data-search-input placeholder="搜索文章、项目、书架、音乐、GitHub、标记..." aria-label="Knowledge search" />
        <kbd>Esc</kbd>
      </div>
      <nav class="knowledge-search-tabs" aria-label="搜索类型">
        {['all', 'post', 'note', 'project', 'book', 'music', 'github', 'visual', 'highlight', 'annotation', 'seal', 'sticker'].map((kind) => (
          <button type="button" class={kind === 'all' ? 'is-active' : ''} data-search-kind={kind}>{kind}</button>
        ))}
      </nav>
      <div class="knowledge-search-results" data-search-results>
        <p class="knowledge-search-empty">输入关键词，或按 Cmd/Ctrl + K 随时打开搜索。</p>
      </div>
    </section>
  </div>

  <div class="selection-toolbar" data-selection-toolbar hidden>
    <button type="button" data-highlight-color="gold">金</button>
    <button type="button" data-highlight-color="purple">紫</button>
    <button type="button" data-highlight-color="green">绿</button>
    <button type="button" data-open-annotation>批注</button>
    <button type="button" data-copy-selection>复制</button>
  </div>

  <div class="seal-palette" data-seal-palette hidden>
    <div class="seal-palette__panel" role="dialog" aria-modal="false" aria-label="选择印章">
      <header>
        <span>Seal</span>
        <strong data-seal-target-title>选择判断</strong>
        <button type="button" data-seal-close>关闭</button>
      </header>
      <div class="seal-palette__grid">
        {sealTypes.map((seal) => (
          <button
            type="button"
            class={`seal-palette__option knowledge-seal knowledge-seal--${seal.shape} knowledge-seal--${seal.texture}`}
            style={`--seal-color:${seal.color}`}
            data-seal-type={seal.id}
            data-seal-label={seal.label}
            data-seal-sublabel={seal.subLabel}
            data-seal-color={seal.color}
            data-seal-shape={seal.shape}
            data-seal-texture={seal.texture}
            title={seal.summary}
          >
            <span class="knowledge-seal__inner">
              <strong>{seal.label}</strong>
              <em>{seal.subLabel}</em>
            </span>
          </button>
        ))}
      </div>
      <button type="button" class="seal-palette__remove" data-seal-remove>移除当前印章</button>
    </div>
  </div>

  <script type="application/json" id="seal-definition-data" set:html={JSON.stringify({ key: sealDefinitionStorageKey, definitions: sealTypes })} />
  <script type="application/json" id="visual-knowledge-data" set:html={JSON.stringify(visualItems)} />
  <script type="application/json" id="knowledge-search-data" set:html={JSON.stringify(knowledgeDocs)} />

  <div class="home-article-templates" hidden>
    {drawerEntries.map((entry) => {
      const Content = entry.Content;
      const related = getRelatedEntries(entry);

      return (
        <article
          class="home-article-reader"
          data-drawer-template={entry.id}
          data-article-id={entry.id}
          data-github-repo-template={entry.id.startsWith('github-repo:') ? entry.title : undefined}
          data-kind={entry.kind}
          data-full-href={entry.href}
          data-read-href={entry.readHref ?? ''}
          data-kicker={entry.kicker}
          data-title={entry.title}
        >
          <header class="home-article-intro">
            <span>{entry.kicker}</span>
            <h1>{entry.title}</h1>
            <p>{entry.summary}</p>
            {entry.date && <small>{entry.date}</small>}
          </header>
          {Content ? (
            <>
              <div class="home-article-reader__grid">
                <nav class="home-article-toc" aria-label="文章目录">
                  <strong>目录</strong>
                  {entry.toc?.length ? (
                    entry.toc.map((heading) => (
                      <a href={heading.href} class={heading.className}>
                        {heading.text}
                      </a>
                    ))
                  ) : (
                    <span>暂无标题</span>
                  )}
                </nav>
                <div class="home-article-content prose-shell prose-shell--plain">
                  <Content />
                </div>
              </div>
              <section class="reader-mini-graph" data-reader-mini-graph data-reader-mini-article={entry.id} aria-label="文章知识网络">
                <header>
                  <span>Mini Graph</span>
                  <a href={withBase(`/knowledge/?focus=${encodeURIComponent(entry.id)}`)} data-mini-graph-open>查看知识图谱</a>
                </header>
                <div class="reader-mini-graph__grid">
                  <section>
                    <strong>当前</strong>
                    <button type="button" data-memory-drawer={entry.id}>{entry.title}</button>
                  </section>
                  <section>
                    <strong>关联</strong>
                    {related.length ? (
                      related.slice(0, 3).map((item) => (
                        <button type="button" data-memory-drawer={item.id}>{item.title}</button>
                      ))
                    ) : (
                      <p>暂无强关联</p>
                    )}
                  </section>
                  <section>
                    <strong>标签</strong>
                    {(entry.tags ?? []).slice(0, 3).length ? (
                      (entry.tags ?? []).slice(0, 3).map((tag) => (
                        <button type="button" data-mini-tag={tag}>{tag}</button>
                      ))
                    ) : (
                      <p>暂无标签</p>
                    )}
                  </section>
                  <section>
                    <strong>标记</strong>
                    <div data-mini-highlights>
                      <p>暂无本地标记</p>
                    </div>
                  </section>
                </div>
              </section>
              {related.length ? (
                <section class="home-article-related" aria-label="继续阅读">
                  <span>继续阅读</span>
                  <h3>相关内容</h3>
                  <div>
                    {related.map((item) => (
                      <button type="button" data-memory-drawer={item.id}>
                        <small>{item.kicker}</small>
                        <strong>{item.title}</strong>
                      </button>
                    ))}
                  </div>
                </section>
              ) : null}
            </>
          ) : (
            <div class="home-drawer-summary">
              {entry.visualItem ? (
                <section class="visual-drawer-panel" style={`--visual-accent:${entry.visualItem.palette.dominant}`}>
                  <div class="visual-drawer-panel__image">
                    <img src={entry.visualItem.image} alt="" loading="lazy" />
                  </div>
                  <div class="visual-drawer-panel__content">
                    <p>{entry.visualItem.note}</p>
                    <section>
                      <h3>调色板</h3>
                      <div class="visual-palette-row">
                        {entry.visualItem.palette.colors.map((color) => (
                          <button type="button" data-copy-color={color} style={`background:${color}`} title={`复制 ${color}`}>
                            <span>{color}</span>
                          </button>
                        ))}
                      </div>
                    </section>
                    <section>
                      <h3>知识关联</h3>
                      <div class="home-feed-card__tags">
                        {entry.visualItem.tags.map((tag) => <span>{tag}</span>)}
                      </div>
                    </section>
                    <section>
                      <h3>设计 Token</h3>
                      <button type="button" class="visual-token-copy" data-copy-visual-token={entry.visualItem.id}>
                        复制视觉 Token
                      </button>
                    </section>
                  </div>
                </section>
              ) : entry.coverSrc ? (
                <div class:list={['home-drawer-summary__media', entry.kind === 'music' && 'home-drawer-summary__media--round']}>
                  <img src={entry.coverSrc} alt="" loading="lazy" />
                </div>
              ) : (
                <div class="home-drawer-summary__mark" style={entry.accent ? `--feed-accent:${entry.accent}` : undefined}>
                  {entry.kind}
                </div>
              )}
              <div class="home-drawer-summary__main">
                {entry.chartVariant === 'heatmap' && (
                  <ChartCard kicker={entry.kicker} title={entry.title} summary={entry.summary} metric="全年" compact>
                    <GitHubHeatmap weeks={githubAnalytics.heatmapWeeks} />
                  </ChartCard>
                )}
                {entry.chartVariant === 'line' && (
                  <ChartCard kicker={entry.kicker} title={entry.title} summary={entry.summary} compact>
                    <GitHubMonthlyLine points={githubAnalytics.monthly} />
                  </ChartCard>
                )}
                {entry.chartVariant === 'language' && (
                  <ChartCard kicker={entry.kicker} title={entry.title} summary={entry.summary} compact>
                    <GitHubLanguageDonut languages={githubAnalytics.languages} />
                  </ChartCard>
                )}
                {!entry.chartVariant && (
                  <>
                    {entry.details?.length ? (
                      <dl
                        class="home-drawer-summary__details"
                        data-github-repo-details={entry.id.startsWith('github-repo:') ? entry.title : undefined}
                      >
                        {entry.details.map((detail) => (
                          <div>
                            <dt>{detail.label}</dt>
                            <dd>{detail.value}</dd>
                          </div>
                        ))}
                      </dl>
                    ) : null}
                    {entry.tags?.length ? (
                      <div class="home-feed-card__tags">
                        {entry.tags.map((tag) => <span>{tag}</span>)}
                      </div>
                    ) : null}
                  </>
                )}
              </div>
            </div>
          )}
        </article>
      );
    })}
  </div>

  <script>
    (() => {
      const layer = document.querySelector('[data-article-layer]');
      const drawerBody = document.querySelector('[data-article-body]');
      const titleTarget = document.querySelector('[data-article-title]');
      const kickerTarget = document.querySelector('[data-article-kicker]');
      const fullLink = document.querySelector('[data-article-full]');
      const readLink = document.querySelector('[data-article-read]');
      const shelfLink = document.querySelector('[data-article-shelf]');
      const bookmarkButton = document.querySelector('[data-reader-bookmark]');
      const progress = document.querySelector('[data-reading-progress]');
      const filterButtons = [...document.querySelectorAll('[data-feed-filter]')];
      const cards = [...document.querySelectorAll('[data-feed-card]')];
      const drawerTriggers = [...document.querySelectorAll('[data-drawer-id]')];
      const mainScroller = document.querySelector('.home-feed-main');
      const searchLayer = document.querySelector('[data-search-layer]');
      const searchInput = document.querySelector('[data-search-input]');
      const searchResults = document.querySelector('[data-search-results]');
      const searchKinds = [...document.querySelectorAll('[data-search-kind]')];
      const selectionToolbar = document.querySelector('[data-selection-toolbar]');
      const sealPalette = document.querySelector('[data-seal-palette]');
      const sealTargetTitle = document.querySelector('[data-seal-target-title]');
      const readerSealButton = document.querySelector('[data-reader-seal]');
      const readerGraphLink = document.querySelector('[data-reader-graph]');
      const homeShell = document.querySelector('.home-feed-shell');
      const sidebarCollapse = document.querySelector('[data-sidebar-collapse]');
      const sidebarCollapseIcon = document.querySelector('[data-sidebar-collapse-icon]');
      const sidebarHistory = document.querySelector('[data-sidebar-history]');
      const sidebarBookmarks = document.querySelector('[data-sidebar-bookmarks]');
      const sidebarStats = [...document.querySelectorAll('[data-sidebar-stat]')];
      const searchDocs = JSON.parse(document.getElementById('knowledge-search-data')?.textContent || '[]');
      const sealConfig = JSON.parse(document.getElementById('seal-definition-data')?.textContent || '{"definitions":[]}');
      const visualKnowledgeItems = JSON.parse(document.getElementById('visual-knowledge-data')?.textContent || '[]');
      const storageKeys = {
        history: 'emptyinkpot-reading-history',
        bookmarks: 'emptyinkpot-reader-bookmarks',
        highlights: 'emptyinkpot-reader-highlights',
        annotations: 'emptyinkpot-reader-annotations',
        seals: 'emptyinkpot-reader-seals',
        stickers: 'emptyinkpot-stickers',
        sealDefinitions: sealConfig.key || 'emptyinkpot-seal-definitions',
        readerTheme: 'emptyinkpot-reader-theme',
        sidebarCollapsed: 'emptyinkpot-home-sidebar-collapsed'
      };
      const defaultSealDefinitions = Array.isArray(sealConfig.definitions) ? sealConfig.definitions : [];
      const loadSealDefinitions = () => {
        let stored;
        try {
          stored = JSON.parse(localStorage.getItem(storageKeys.sealDefinitions) || '[]');
        } catch {
          stored = [];
        }
        const source = Array.isArray(stored) && stored.length ? stored : defaultSealDefinitions;
        return source.reduce((map, definition) => {
          if (definition?.id) map[definition.id] = definition;
          return map;
        }, {});
      };
      let sealDefinitions = loadSealDefinitions();
      const drawerTransitionMs = 180;
      const searchTransitionMs = 120;
      let lastFocused = null;
      let savedScrollTop = 0;
      let currentArticle = null;
      let activeIndex = 0;
      let searchKind = 'all';
      let selectedRange = null;
      let pendingHighlightId = null;
      let sealContext = null;
      let drawerCloseTimer = 0;
      let searchCloseTimer = 0;
      let readerMemoryFrame = 0;

      const setSidebarCollapsed = (collapsed) => {
        homeShell?.classList.toggle('is-sidebar-collapsed', collapsed);
        if (sidebarCollapse) {
          sidebarCollapse.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
          sidebarCollapse.setAttribute('aria-label', collapsed ? '展开右侧栏' : '折叠右侧栏');
        }
        if (sidebarCollapseIcon) {
          sidebarCollapseIcon.textContent = collapsed ? '‹' : '›';
        }
        localStorage.setItem(storageKeys.sidebarCollapsed, collapsed ? 'true' : 'false');
      };

      const initSidebar = () => {
        setSidebarCollapsed(localStorage.getItem(storageKeys.sidebarCollapsed) === 'true');
        sidebarCollapse?.addEventListener('click', () => {
          setSidebarCollapsed(!homeShell?.classList.contains('is-sidebar-collapsed'));
        });
      };

      const initHeroBanner = () => {
        const hero = document.querySelector('[data-hero-banner]');
        if (!hero) return;
        const layers = {
          bg: hero.querySelector('[data-hero-layer="bg"]'),
          mid: hero.querySelector('[data-hero-layer="mid"]'),
          front: hero.querySelector('[data-hero-layer="front"]')
        };
        const label = hero.querySelector('[data-hero-season-label]');
        const title = hero.querySelector('[data-hero-title]');
        const subtitle = hero.querySelector('[data-hero-subtitle]');
        const contentSettings = window.emptyinkpotVisualSettings?.load?.().content;
        const bannerSettings = contentSettings?.banner || {};
        const month = new Date().getMonth();
        const season = month < 2 || month === 11 ? 'winter' : month < 5 ? 'spring' : month < 8 ? 'summer' : 'autumn';
        const seasonLabels = {
          spring: bannerSettings.springLabel || 'Spring Field',
          summer: bannerSettings.summerLabel || 'Summer Field',
          autumn: bannerSettings.autumnLabel || 'Autumn Field',
          winter: bannerSettings.winterLabel || 'Winter Field'
        };
        const heroImages = {
          spring: bannerSettings.bgImage || '/images/home/homepage-floral-bg.png',
          summer: bannerSettings.bgImage || '/images/home/homepage-floral-bg.png',
          autumn: bannerSettings.bgImage || '/images/home/homepage-floral-bg.png',
          winter: bannerSettings.bgImage || '/images/home/homepage-floral-bg.png'
        };
        const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        hero.dataset.season = season;
        const setImageVar = (name, value) => {
          if (!value) return;
          hero.style.setProperty(name, value.startsWith('url(') ? value : `url("${value.replaceAll('"', '%22')}")`);
        };
        setImageVar('--hero-bg-image', heroImages[season]);
        setImageVar('--hero-mid-image', bannerSettings.midImage);
        setImageVar('--hero-front-image', bannerSettings.frontImage);
        if (label) label.textContent = bannerSettings.kicker || seasonLabels[season];
        if (title && bannerSettings.title) title.textContent = bannerSettings.title;
        if (subtitle && bannerSettings.subtitle) subtitle.textContent = bannerSettings.subtitle;

        const resetLayers = () => {
          if (layers.bg instanceof HTMLElement) layers.bg.style.transform = 'scale(1.1)';
          if (layers.mid instanceof HTMLElement) layers.mid.style.transform = 'scale(1.08)';
          if (layers.front instanceof HTMLElement) layers.front.style.transform = 'scale(1.05)';
        };

        if (!reducedMotion) {
          let targetX = 0;
          let targetY = 0;
          let currentX = 0;
          let currentY = 0;
          let hovering = false;

          hero.addEventListener('mousemove', (event) => {
            const rect = hero.getBoundingClientRect();
            targetX = (event.clientX - rect.left) / rect.width - 0.5;
            targetY = (event.clientY - rect.top) / rect.height - 0.5;
            hovering = true;
          });
          hero.addEventListener('mouseleave', () => {
            targetX = 0;
            targetY = 0;
            hovering = false;
          });

          const animate = () => {
            currentX += (targetX - currentX) * 0.08;
            currentY += (targetY - currentY) * 0.08;
            if (Math.abs(currentX) > 0.001 || Math.abs(currentY) > 0.001 || hovering) {
              if (layers.bg instanceof HTMLElement) layers.bg.style.transform = `scale(1.1) translate(${currentX * 10}px, ${currentY * 8}px)`;
              if (layers.mid instanceof HTMLElement) layers.mid.style.transform = `scale(1.08) translate(${currentX * 20}px, ${currentY * 14}px)`;
              if (layers.front instanceof HTMLElement) layers.front.style.transform = `scale(1.05) translate(${currentX * 34}px, ${currentY * 20}px)`;
            } else {
              resetLayers();
            }
            requestAnimationFrame(animate);
          };

          requestAnimationFrame(animate);
        }
      };

      const readJson = (key, fallback) => {
        try {
          return JSON.parse(localStorage.getItem(key) || JSON.stringify(fallback));
        } catch {
          return fallback;
        }
      };

      const writeJson = (key, value) => {
        try {
          localStorage.setItem(key, JSON.stringify(value));
        } catch {
          // Ignore local storage failures; reading should still work.
        }
      };

      const normalizeReaderTheme = (theme) => (['light', 'sepia', 'dark'].includes(theme) ? theme : 'light');

      const applyReaderTheme = (theme) => {
        const next = normalizeReaderTheme(theme);
        document.documentElement.dataset.readerTheme = next;
        document.querySelectorAll('[data-reader-theme]').forEach((button) => {
          button.classList.toggle('is-active', button.dataset.readerTheme === next);
        });
        try {
          localStorage.setItem(storageKeys.readerTheme, next);
        } catch {
          // Ignore storage failures.
        }
      };

      const getVisibleCards = () => cards.filter((card) => !card.hidden);

      const setSearchKind = (kind) => {
        searchKind = kind || 'all';
        searchKinds.forEach((item) => item.classList.toggle('is-active', item.dataset.searchKind === searchKind));
      };

      const setActiveCard = (index) => {
        const visibleCards = getVisibleCards();
        if (!visibleCards.length) return;
        cards.forEach((card) => card.classList.remove('feed-card--active'));
        activeIndex = Math.max(0, Math.min(index, visibleCards.length - 1));
        const card = visibleCards[activeIndex];
        card.classList.add('feed-card--active');
        card.scrollIntoView({ block: 'center', behavior: 'smooth' });
      };

      const formatReaderProgress = (item) => {
        const progress = Number(item?.progress || 0);
        const percent = Math.round(Math.max(0, Math.min(1, progress)) * 100);
        const when = Number(item?.lastReadAt || item?.timestamp || 0);
        const date = when ? new Date(when).toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' }) : '';
        return [percent ? `${percent}%` : '未开始', date].filter(Boolean).join(' · ');
      };

      const renderSidebarList = (target, items, emptyText, type) => {
        if (!target) return;
        if (!items.length) {
          const empty = document.createElement('li');
          empty.textContent = emptyText;
          target.replaceChildren(empty);
          return;
        }
        target.replaceChildren(
          ...items.slice(0, 3).map((item) => {
            const row = document.createElement('li');
            const button = document.createElement('button');
            const drawerId = type === 'highlight' ? item.articleId : item.id;
            button.type = 'button';
            button.dataset.sidebarDrawer = drawerId || '';
            if (type === 'highlight' && item.id) button.dataset.sidebarHighlight = item.id;
            const label = document.createElement('span');
            label.textContent = type === 'highlight' ? item.text || 'Untitled highlight' : item.title || 'Untitled';
            button.append(label);
            if (type === 'history') {
              const meta = document.createElement('small');
              meta.textContent = formatReaderProgress(item);
              button.append(meta);
            }
            row.append(button);
            return row;
          })
        );
      };

      const renderSidebarState = () => {
        const history = readJson(storageKeys.history, []);
        const bookmarks = readJson(storageKeys.bookmarks, []);
        const highlights = readJson(storageKeys.highlights, []);
        const annotations = readJson(storageKeys.annotations, []);
        sidebarStats.forEach((node) => {
          const map = { history, bookmarks, highlights, annotations };
          const key = node.dataset.sidebarStat;
          node.textContent = String(map[key]?.length ?? 0);
        });
        renderSidebarList(sidebarHistory, history, '暂无记录', 'history');
        renderSidebarList(sidebarBookmarks, bookmarks.length ? bookmarks : highlights, bookmarks.length ? '暂无收藏' : '暂无标记', bookmarks.length ? 'bookmark' : 'highlight');
      };

      const getSeals = () => readJson(storageKeys.seals, []);

      const latestSealFor = (targetId) =>
        getSeals()
          .filter((item) => item.targetId === targetId)
          .sort((a, b) => (b.updatedAt || b.createdAt || 0) - (a.updatedAt || a.createdAt || 0))[0];

      const createSealElement = (record, options = {}) => {
        const definition = sealDefinitions[record.sealId || record.type] || sealDefinitions[record.type] || sealDefinitions.selected;
        const seal = document.createElement('span');
        const shape = record.shape || definition.shape || 'circle';
        const texture = record.texture || definition.texture || 'clean';
        seal.className = `knowledge-seal knowledge-seal--${shape} knowledge-seal--${texture}`;
        if (options.animate) seal.classList.add('knowledge-seal--stamp-in');
        seal.dataset.renderedSeal = record.id;
        seal.style.setProperty('--seal-color', record.color || definition.color);
        seal.style.setProperty('--seal-rotation', `${record.rotation || -7}deg`);
        seal.style.setProperty('--seal-x', `${Math.max(4, Math.min(96, (record.x ?? 0.78) * 100))}%`);
        seal.style.setProperty('--seal-y', `${Math.max(4, Math.min(96, (record.y ?? 0.12) * 100))}%`);
        const inner = document.createElement('span');
        inner.className = 'knowledge-seal__inner';
        const label = document.createElement('strong');
        label.textContent = record.label || definition.label;
        inner.append(label);
        const subLabelText = record.subLabel || definition.subLabel;
        if (subLabelText) {
          const subLabel = document.createElement('em');
          subLabel.textContent = subLabelText;
          inner.append(subLabel);
        }
        seal.append(inner);
        return seal;
      };

      const renderSeals = (options = {}) => {
        const animateId = options.animateId || '';
        document.querySelectorAll('[data-rendered-seal]').forEach((node) => node.remove());
        const sealSurfaces = [...document.querySelectorAll('[data-seal-surface], [data-feed-card]')];
        sealSurfaces.forEach((card) => {
          const targetId = card.dataset.sealTarget || card.dataset.drawerId || card.getAttribute('href');
          if (!targetId) return;
          const record = latestSealFor(targetId);
          if (!record) return;
          card.append(createSealElement(record, { animate: record.id === animateId }));
        });
        if (currentArticle && drawerBody) {
          const intro = drawerBody.querySelector('.home-article-intro');
          const record = latestSealFor(currentArticle.id);
          if (intro && record) intro.append(createSealElement(record, { animate: record.id === animateId }));
        }
      };

      const openSealPalette = (target, anchor) => {
        if (!sealPalette || !target?.targetId) return;
        sealDefinitions = loadSealDefinitions();
        sealContext = target;
        if (sealTargetTitle) sealTargetTitle.textContent = target.title || '选择判断';
        sealPalette.hidden = false;
        const rect = anchor?.getBoundingClientRect?.();
        if (rect && sealPalette instanceof HTMLElement) {
          sealPalette.style.setProperty('--seal-palette-x', `${Math.min(window.innerWidth - 280, Math.max(12, rect.left))}px`);
          sealPalette.style.setProperty('--seal-palette-y', `${Math.min(window.innerHeight - 260, Math.max(12, rect.bottom + 8))}px`);
        }
      };

      const closeSealPalette = () => {
        if (sealPalette) sealPalette.hidden = true;
        sealContext = null;
      };

      const saveSeal = (type) => {
        if (!sealContext?.targetId) return;
        sealDefinitions = loadSealDefinitions();
        const definition = sealDefinitions[type] || sealDefinitions.selected;
        const records = getSeals();
        const previous = records.find((item) => item.targetId === sealContext.targetId);
        const now = Date.now();
        const record = {
          id: previous?.id || `seal:${sealContext.targetId}:${now}`,
          sealId: definition.id || type,
          type,
          label: definition.label,
          subLabel: definition.subLabel,
          color: definition.color,
          shape: definition.shape,
          texture: definition.texture,
          targetId: sealContext.targetId,
          targetType: sealContext.targetType || 'card',
          title: sealContext.title || 'Untitled',
          kind: sealContext.kind || 'post',
          href: sealContext.href || '',
          drawerId: sealContext.drawerId || '',
          rotation: previous?.rotation ?? Math.round(Math.random() * 14 - 7),
          x: sealContext.x ?? previous?.x ?? 0.78,
          y: sealContext.y ?? previous?.y ?? 0.14,
          createdAt: previous?.createdAt || now,
          updatedAt: now
        };
        writeJson(storageKeys.seals, [record, ...records.filter((item) => item.id !== record.id && item.targetId !== record.targetId)]);
        renderSeals({ animateId: record.id });
        closeSealPalette();
      };

      const removeSeal = () => {
        if (!sealContext?.targetId) return;
        writeJson(storageKeys.seals, getSeals().filter((item) => item.targetId !== sealContext.targetId));
        renderSeals();
        closeSealPalette();
      };

      const saveHistory = (article) => {
        if (!article?.id) return;
        const list = readJson(storageKeys.history, []);
        const previous = list.find((item) => item.id === article.id) || {};
        const now = Date.now();
        const next = [
          {
            ...previous,
            id: article.id,
            title: article.title,
            href: article.href,
            timestamp: now,
            lastReadAt: now,
            scrollTop: previous.scrollTop || 0,
            progress: previous.progress || 0
          },
          ...list.filter((item) => item.id !== article.id)
        ].slice(0, 50);
        writeJson(storageKeys.history, next);
        renderSidebarState();
      };

      const getHistoryEntry = (id) => readJson(storageKeys.history, []).find((item) => item.id === id);

      const persistReadingMemory = (ratio) => {
        if (!currentArticle || !drawerBody) return;
        if (readerMemoryFrame) return;
        readerMemoryFrame = requestAnimationFrame(() => {
          readerMemoryFrame = 0;
          const list = readJson(storageKeys.history, []);
          const previous = list.find((item) => item.id === currentArticle.id) || {};
          const now = Date.now();
          const record = {
            ...previous,
            id: currentArticle.id,
            title: currentArticle.title,
            href: currentArticle.href,
            timestamp: previous.timestamp || now,
            lastReadAt: now,
            scrollTop: drawerBody.scrollTop,
            progress: Number.isFinite(ratio) ? Math.max(0, Math.min(1, ratio)) : 0
          };
          writeJson(storageKeys.history, [record, ...list.filter((item) => item.id !== currentArticle.id)].slice(0, 50));
        });
      };

      const getBookmarks = () => readJson(storageKeys.bookmarks, []);

      const isBookmarked = (id) => getBookmarks().some((item) => item.id === id);

      const updateBookmarkButton = () => {
        if (!bookmarkButton || !currentArticle) return;
        const active = isBookmarked(currentArticle.id);
        bookmarkButton.classList.toggle('is-active', active);
        bookmarkButton.textContent = active ? '已收藏' : '收藏';
      };

      const toggleBookmark = () => {
        if (!currentArticle) return;
        const list = getBookmarks();
        const exists = list.some((item) => item.id === currentArticle.id);
        const next = exists
          ? list.filter((item) => item.id !== currentArticle.id)
          : [{ id: currentArticle.id, title: currentArticle.title, href: currentArticle.href, createdAt: Date.now() }, ...list];
        writeJson(storageKeys.bookmarks, next);
        updateBookmarkButton();
        renderSidebarState();
      };

      const updateReadingProgress = () => {
        if (!drawerBody || !progress) return;
        const max = drawerBody.scrollHeight - drawerBody.clientHeight;
        const ratio = max > 0 ? drawerBody.scrollTop / max : 0;
        progress.style.transform = `scaleX(${Math.max(0, Math.min(1, ratio))})`;
        persistReadingMemory(ratio);
      };

      const updateReaderGraphLink = () => {
        if (!(readerGraphLink instanceof HTMLAnchorElement) || !currentArticle) return;
        readerGraphLink.href = `/knowledge/?focus=${encodeURIComponent(currentArticle.id)}`;
      };

      const escapeCssIdentifier = (value) => {
        if (window.CSS?.escape) return window.CSS.escape(value);
        return value.replace(/["\\]/g, '\\$&');
      };

      const normalizeAnchorText = (input) => input.replace(/\s+/g, ' ').trim();

      const hashText = (input) => {
        let hash = 0;
        for (let index = 0; index < input.length; index += 1) {
          hash = (hash << 5) - hash + input.charCodeAt(index);
          hash |= 0;
        }
        return String(hash);
      };

      const collectTextNodes = (root) => {
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
        const nodes = [];
        let current = walker.nextNode();
        while (current) {
          nodes.push(current);
          current = walker.nextNode();
        }
        return nodes;
      };

      const getNodePath = (root, target) => {
        const path = [];
        let node = target;
        while (node && node !== root && node.parentNode) {
          path.unshift([...node.parentNode.childNodes].indexOf(node));
          node = node.parentNode;
        }
        return path;
      };

      const resolveNodePath = (root, path) => {
        let node = root;
        for (const index of path || []) {
          node = node?.childNodes?.[index];
          if (!node) return null;
        }
        return node;
      };

      const findRangeTextOffset = (root, target, offset) => {
        let cursor = 0;
        for (const node of collectTextNodes(root)) {
          if (node === target) return cursor + offset;
          cursor += node.nodeValue?.length || 0;
        }
        return cursor;
      };

      const createRangeFromOffsets = (root, start, end) => {
        const nodes = collectTextNodes(root);
        const range = document.createRange();
        let cursor = 0;
        let started = false;
        for (const node of nodes) {
          const length = node.nodeValue?.length || 0;
          const next = cursor + length;
          if (!started && start <= next) {
            range.setStart(node, Math.max(0, start - cursor));
            started = true;
          }
          if (started && end <= next) {
            range.setEnd(node, Math.max(0, end - cursor));
            return range;
          }
          cursor = next;
        }
        return null;
      };

      const createHighlightAnchor = (root, range) => {
        const exact = range.toString();
        const fullText = root.textContent || '';
        const start = findRangeTextOffset(root, range.startContainer, range.startOffset);
        const end = start + exact.length;
        return {
          quote: {
            type: 'TextQuoteSelector',
            exact,
            prefix: fullText.slice(Math.max(0, start - 48), start),
            suffix: fullText.slice(end, Math.min(fullText.length, end + 48))
          },
          position: { type: 'TextPositionSelector', start, end },
          dom: {
            type: 'DomPathSelector',
            startPath: getNodePath(root, range.startContainer),
            startOffset: range.startOffset,
            endPath: getNodePath(root, range.endContainer),
            endOffset: range.endOffset
          },
          contentHash: hashText(normalizeAnchorText(fullText))
        };
      };

      const resolveByDomPath = (root, selector) => {
        if (!selector?.startPath || !selector?.endPath) return null;
        const startNode = resolveNodePath(root, selector.startPath);
        const endNode = resolveNodePath(root, selector.endPath);
        if (!startNode || !endNode) return null;
        try {
          const range = document.createRange();
          range.setStart(startNode, selector.startOffset);
          range.setEnd(endNode, selector.endOffset);
          return range;
        } catch {
          return null;
        }
      };

      const contextScore = (actual, expected) => {
        if (!expected) return 0.5;
        if (actual === expected) return 1;
        if (actual.endsWith(expected) || expected.endsWith(actual)) return 0.72;
        return 0;
      };

      const resolveByQuote = (root, quote, fallbackText) => {
        const exact = quote?.exact || fallbackText || '';
        if (!exact) return null;
        const fullText = root.textContent || '';
        const candidates = [];
        let index = fullText.indexOf(exact);
        while (index >= 0) {
          const end = index + exact.length;
          const prefix = fullText.slice(Math.max(0, index - (quote?.prefix?.length || 0)), index);
          const suffix = fullText.slice(end, end + (quote?.suffix?.length || 0));
          candidates.push({
            start: index,
            end,
            score: contextScore(prefix, quote?.prefix || '') + contextScore(suffix, quote?.suffix || '')
          });
          index = fullText.indexOf(exact, index + 1);
        }
        const best = candidates.sort((a, b) => b.score - a.score)[0];
        return best ? createRangeFromOffsets(root, best.start, best.end) : null;
      };

      const resolveHighlightRange = (root, record) => {
        const anchor = record.anchor;
        if (anchor?.contentHash === hashText(normalizeAnchorText(root.textContent || ''))) {
          const byPosition = createRangeFromOffsets(root, anchor.position?.start || 0, anchor.position?.end || 0);
          if (byPosition) return byPosition;
        }
        return resolveByQuote(root, anchor?.quote, record.text) || resolveByDomPath(root, anchor?.dom);
      };

      const scrollToHighlight = (highlightId) => {
        if (!highlightId || !drawerBody) return;
        const mark = drawerBody.querySelector(`[data-highlight-id="${escapeCssIdentifier(highlightId)}"]`);
        if (!mark) return;
        mark.scrollIntoView({ block: 'center', behavior: 'smooth' });
        mark.classList.add('reader-highlight--focus');
        window.setTimeout(() => mark.classList.remove('reader-highlight--focus'), 1200);
      };

      const createReaderMemoryPanel = () => {
        const panel = document.createElement('aside');
        panel.className = 'reader-memory-panel';
        const toggle = document.createElement('button');
        const content = document.createElement('div');
        toggle.type = 'button';
        toggle.className = 'reader-memory-panel__toggle';
        toggle.dataset.memoryToggle = 'true';
        toggle.textContent = '阅读记忆';
        content.className = 'reader-memory-panel__content';
        panel.append(toggle, content);
        const history = readJson(storageKeys.history, []).slice(0, 4);
        const bookmarks = readJson(storageKeys.bookmarks, []).slice(0, 4);
        const highlights = readJson(storageKeys.highlights, []).slice(0, 4);
        const annotations = readJson(storageKeys.annotations, []).slice(0, 4);
        const appendSection = (title, items, type) => {
          const section = document.createElement('section');
          const heading = document.createElement('span');
          heading.textContent = title;
          section.append(heading);

          if (!items.length) {
            const empty = document.createElement('p');
            empty.textContent = '暂无记录';
            section.append(empty);
            content.append(section);
            return;
          }

          items.forEach((item) => {
            const target = type === 'highlight' || type === 'annotation' ? item.articleId : item.id;
            const label = type === 'highlight' ? item.text : type === 'annotation' ? item.body : item.title;
            const button = document.createElement('button');
            const text = document.createElement('span');
            button.type = 'button';
            button.dataset.memoryDrawer = target || '';
            if (type === 'highlight' && item.id) button.dataset.memoryHighlight = item.id;
            if (type === 'annotation' && item.highlightId) button.dataset.memoryHighlight = item.highlightId;
            text.textContent = label || 'Untitled';
            button.append(text);
            if (type === 'history') {
              const meta = document.createElement('small');
              meta.textContent = formatReaderProgress(item);
              button.append(meta);
            }
            section.append(button);
          });

          content.append(section);
        };
        appendSection('最近阅读', history, 'history');
        appendSection('收藏', bookmarks, 'bookmark');
        appendSection('标记', highlights, 'highlight');
        appendSection('批注', annotations, 'annotation');
        return panel;
      };

      const renderReaderMiniGraph = () => {
        if (!drawerBody || !currentArticle) return;
        const mini = drawerBody.querySelector('[data-reader-mini-graph]');
        if (!mini) return;
        const highlightsTarget = mini.querySelector('[data-mini-highlights]');
        const graphOpen = mini.querySelector('[data-mini-graph-open]');
        if (graphOpen instanceof HTMLAnchorElement) {
          graphOpen.href = `/knowledge/?focus=${encodeURIComponent(currentArticle.id)}`;
        }
        if (!highlightsTarget) return;
        const highlights = readJson(storageKeys.highlights, [])
          .filter((item) => item.articleId === currentArticle.id)
          .slice(0, 3);
        const annotations = readJson(storageKeys.annotations, [])
          .filter((item) => item.articleId === currentArticle.id)
          .slice(0, Math.max(0, 3 - highlights.length));
        const memoryItems = [
          ...highlights.map((item) => ({ ...item, memoryType: 'highlight', label: item.text })),
          ...annotations.map((item) => ({ ...item, memoryType: 'annotation', label: item.body }))
        ].slice(0, 3);
        if (!memoryItems.length) {
          const empty = document.createElement('p');
          empty.textContent = '暂无本地标记';
          highlightsTarget.replaceChildren(empty);
          return;
        }
        highlightsTarget.replaceChildren(
          ...memoryItems.map((item) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.dataset.memoryDrawer = item.articleId;
            button.dataset.memoryHighlight = item.id;
            if (item.memoryType === 'annotation') button.dataset.memoryHighlight = item.highlightId || '';
            button.textContent = item.label || 'Untitled memory';
            return button;
          })
        );
      };

      const applyStoredHighlights = () => {
        if (!drawerBody || !currentArticle) return;
        const root = drawerBody.querySelector('.home-article-content');
        if (!root) return;
        const highlights = readJson(storageKeys.highlights, []).filter((item) => item.articleId === currentArticle.id);
        const orphaned = [];
        highlights.forEach((item) => {
          const range = resolveHighlightRange(root, item);
          if (!range) {
            orphaned.push(item);
            return;
          }
          const mark = document.createElement('mark');
          mark.className = `reader-highlight reader-highlight--${item.color || 'gold'}`;
          mark.dataset.highlightId = item.id;
          try {
            mark.append(range.extractContents());
            range.insertNode(mark);
          } catch {
            orphaned.push(item);
          }
        });
        drawerBody.querySelectorAll('.reader-orphan-highlights').forEach((node) => node.remove());
        if (orphaned.length) {
          const notice = document.createElement('aside');
          notice.className = 'reader-orphan-highlights';
          const title = document.createElement('strong');
          const details = document.createElement('p');
          title.textContent = `${orphaned.length} 条标记暂时无法定位`;
          details.textContent = orphaned
            .map((item) => item.text)
            .slice(0, 3)
            .join(' / ');
          notice.append(title, details);
          drawerBody.prepend(notice);
        }
        if (pendingHighlightId) {
          requestAnimationFrame(() => {
            scrollToHighlight(pendingHighlightId);
            pendingHighlightId = null;
          });
        }
        renderReaderMiniGraph();
      };

      const hideSelectionToolbar = () => {
        if (selectionToolbar) selectionToolbar.hidden = true;
        selectedRange = null;
      };

      const showSelectionToolbar = () => {
        if (!currentArticle || !drawerBody || !selectionToolbar) return;
        const selection = window.getSelection();
        const text = selection?.toString().trim() || '';
        if (text.length < 10 || text.length > 240 || !selection.rangeCount) {
          hideSelectionToolbar();
          return;
        }
        const range = selection.getRangeAt(0);
        if (!drawerBody.contains(range.commonAncestorContainer)) {
          hideSelectionToolbar();
          return;
        }
        selectedRange = range.cloneRange();
        const rect = range.getBoundingClientRect();
        selectionToolbar.hidden = false;
        const left = Math.min(window.innerWidth - selectionToolbar.offsetWidth - 12, Math.max(12, rect.left));
        const top = Math.max(12, rect.top - selectionToolbar.offsetHeight - 10);
        selectionToolbar.style.left = `${left}px`;
        selectionToolbar.style.top = `${top}px`;
      };

      const saveSelectionHighlight = (color = 'gold', note = '') => {
        if (!currentArticle || !drawerBody) return;
        const selection = window.getSelection();
        const range = selectedRange || (selection?.rangeCount ? selection.getRangeAt(0) : null);
        const text = range?.toString().trim() || '';
        if (!range || text.length < 10 || text.length > 240) return;
        if (!drawerBody.contains(range.commonAncestorContainer)) return;
        const root = drawerBody.querySelector('.home-article-content');
        if (!root || !root.contains(range.commonAncestorContainer)) return;
        const anchor = createHighlightAnchor(root, range);
        const record = {
          id: `${currentArticle.id}:${Date.now()}`,
          articleId: currentArticle.id,
          title: currentArticle.title,
          text,
          color,
          anchor,
          createdAt: Date.now(),
          updatedAt: Date.now()
        };
        const mark = document.createElement('mark');
        mark.className = `reader-highlight reader-highlight--${color}`;
        mark.dataset.highlightId = record.id;
        try {
          mark.append(range.extractContents());
          range.insertNode(mark);
          selection?.removeAllRanges();
        } catch {
          return;
        }
        writeJson(storageKeys.highlights, [record, ...readJson(storageKeys.highlights, [])]);
        if (note.trim()) {
          const annotation = {
            id: `annotation:${record.id}`,
            articleId: currentArticle.id,
            highlightId: record.id,
            body: note.trim(),
            color,
            tags: [],
            createdAt: Date.now(),
            updatedAt: Date.now()
          };
          writeJson(storageKeys.annotations, [annotation, ...readJson(storageKeys.annotations, [])]);
        }
        renderSidebarState();
        renderReaderMiniGraph();
        hideSelectionToolbar();
      };

      const search = (query) => {
        const q = query.trim().toLowerCase();
        if (!q) return [];
        const storedHighlights = readJson(storageKeys.highlights, []).map((item) => ({
          id: item.id,
          type: 'highlight',
          title: item.title,
          content: item.text,
          tags: ['highlight'],
          drawerId: item.articleId,
          highlightId: item.id
        }));
        const storedAnnotations = readJson(storageKeys.annotations, []).map((item) => ({
          id: item.id,
          type: 'annotation',
          title: `批注 · ${item.articleId}`,
          content: item.body,
          tags: ['annotation', item.color, ...(item.tags || [])].filter(Boolean),
          drawerId: item.articleId,
          highlightId: item.highlightId
        }));
        const storedSeals = getSeals().map((item) => ({
          id: item.id,
          type: 'seal',
          title: `${item.label} · ${item.title}`,
          content: [item.label, item.subLabel, item.sealId || item.type, item.title, item.kind].join(' '),
          tags: ['seal', item.sealId || item.type, item.type, item.kind].filter(Boolean),
          drawerId: item.drawerId,
          href: item.href
        }));
        const storedStickers = readJson(storageKeys.stickers, []).map((item) => ({
          id: item.id,
          type: 'sticker',
          title: `贴纸 · ${item.content || item.kind}`,
          content: [item.kind, item.content, item.note, item.targetId, item.targetType].join(' '),
          tags: ['sticker', item.kind, item.targetType].filter(Boolean),
          drawerId: item.targetId,
          href: item.targetId?.startsWith('visual:') ? `/visuals/#${encodeURIComponent(item.targetId.slice('visual:'.length))}` : undefined
        }));
        return [...searchDocs, ...storedHighlights, ...storedAnnotations, ...storedSeals, ...storedStickers]
          .filter((doc) => searchKind === 'all' || doc.type === searchKind)
          .map((doc) => {
            const content = [doc.title, doc.content, ...(doc.tags || [])].join(' ').toLowerCase();
            const score = (doc.title?.toLowerCase().includes(q) ? 5 : 0) + (content.includes(q) ? 1 : 0);
            return { doc, score };
          })
          .filter((item) => item.score > 0)
          .sort((a, b) => b.score - a.score)
          .map((item) => item.doc)
          .slice(0, 24);
      };

      const renderSearch = () => {
        if (!searchInput || !searchResults) return;
        const results = search(searchInput.value || '');
        if (!results.length) {
          searchResults.innerHTML = '<p class="knowledge-search-empty">输入关键词，搜索文章、项目、书架、音乐、GitHub 和本地标记。</p>';
          return;
        }
        searchResults.replaceChildren(
          ...results.map((doc) => {
            const button = document.createElement('button');
            button.type = 'button';
            button.className = 'knowledge-search-result';
            button.innerHTML = `<span>${doc.type}</span><strong></strong><small></small>`;
            button.querySelector('strong').textContent = doc.title;
            button.querySelector('small').textContent = String(doc.content || '').slice(0, 150);
            button.addEventListener('click', () => {
              if (doc.drawerId) {
                openDrawer(doc.drawerId, button, { highlightId: doc.highlightId });
                closeSearch();
              } else if (doc.href) {
                window.location.href = doc.href;
              }
            });
            return button;
          })
        );
      };

      const openSearch = () => {
        if (!searchLayer || !searchInput) return;
        window.clearTimeout(searchCloseTimer);
        searchLayer.hidden = false;
        requestAnimationFrame(() => {
          searchLayer.classList.add('is-open');
          searchInput.focus({ preventScroll: true });
        });
        renderSearch();
      };

      const openSearchWithQuery = (query, kind = 'all') => {
        setSearchKind(kind);
        if (searchInput instanceof HTMLInputElement) {
          searchInput.value = query || '';
        }
        openSearch();
        renderSearch();
      };

      const closeSearch = () => {
        if (!searchLayer) return;
        searchLayer.classList.remove('is-open');
        window.clearTimeout(searchCloseTimer);
        searchCloseTimer = window.setTimeout(() => {
          searchLayer.hidden = true;
        }, searchTransitionMs);
      };

      const setFilter = (kind) => {
        filterButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.feedFilter === kind));
        cards.forEach((card) => {
          const visible = kind === 'all' || card.dataset.feedKind === kind;
          card.hidden = !visible;
        });
        activeIndex = 0;
      };

      const closeDrawer = () => {
        if (!layer) return;
        hideSelectionToolbar();
        layer.classList.remove('is-open');
        window.clearTimeout(drawerCloseTimer);
        drawerCloseTimer = window.setTimeout(() => {
          layer.hidden = true;
          document.body.classList.remove('has-home-article-drawer');
          drawerBody?.replaceChildren();
          currentArticle = null;
          if (mainScroller) {
            mainScroller.scrollTop = savedScrollTop;
          }
          if (lastFocused instanceof HTMLElement) {
            lastFocused.focus({ preventScroll: true });
          }
          if (mainScroller) {
            requestAnimationFrame(() => {
              mainScroller.scrollTop = savedScrollTop;
            });
          }
        }, drawerTransitionMs);
      };

      const openDrawer = (id, trigger, options = {}) => {
        const template = [...document.querySelectorAll('[data-drawer-template]')].find(
          (node) => node.dataset.drawerTemplate === id
        );
        if (!template || !drawerBody || !layer) return;

        const content = template.cloneNode(true);
        content.removeAttribute('data-drawer-template');
        const reader = content.matches('.home-article-reader') ? content : content.querySelector('.home-article-reader');
        const title = reader?.dataset.title ?? '';
        const kicker = reader?.dataset.kicker ?? '';
        const href = reader?.dataset.fullHref ?? '#';
        const kind = reader?.dataset.kind ?? '';
        const readHref = reader?.dataset.readHref ?? '';
        const articleId = reader?.dataset.articleId ?? id;
        const storedMemory = getHistoryEntry(articleId);
        lastFocused = trigger;
        savedScrollTop = mainScroller?.scrollTop ?? 0;
        currentArticle = { id: articleId, title, href };
        pendingHighlightId = options.highlightId || null;

        drawerBody.replaceChildren(createReaderMemoryPanel(), content);
        if (titleTarget) titleTarget.textContent = title;
        if (kickerTarget) kickerTarget.textContent = kicker;
        if (fullLink) {
          fullLink.setAttribute('href', href);
          fullLink.textContent = kind === 'book' ? '书籍详情' : '完整页面';
        }
        if (readLink) {
          if (kind === 'book' && readHref) {
            readLink.hidden = false;
            readLink.setAttribute('href', readHref);
          } else {
            readLink.hidden = true;
            readLink.setAttribute('href', '#');
          }
        }
        if (shelfLink) {
          shelfLink.hidden = kind !== 'book';
        }
        updateReaderGraphLink();
        window.clearTimeout(drawerCloseTimer);
        layer.hidden = false;
        document.body.classList.add('has-home-article-drawer');
        requestAnimationFrame(() => {
          layer.classList.add('is-open');
        });
        saveHistory(currentArticle);
        updateBookmarkButton();
        if (storedMemory?.scrollTop && !options.highlightId) {
          requestAnimationFrame(() => {
            drawerBody.scrollTop = storedMemory.scrollTop;
            updateReadingProgress();
          });
        } else {
          updateReadingProgress();
        }
        requestAnimationFrame(applyStoredHighlights);
        requestAnimationFrame(renderReaderMiniGraph);
        requestAnimationFrame(renderSeals);
        layer.querySelector('[data-article-close]')?.focus({ preventScroll: true });
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => setFilter(button.dataset.feedFilter || 'all'));
      });

      drawerTriggers.forEach((trigger) => {
        trigger.addEventListener('click', (event) => {
          const id = trigger.dataset.drawerId;
          if (!id) return;
          event.preventDefault();
          openDrawer(id, trigger);
        });
      });

      window.addEventListener('home-search-open', openSearch);

      document.querySelectorAll('[data-search-close]').forEach((button) => {
        button.addEventListener('click', closeSearch);
      });

      searchInput?.addEventListener('input', renderSearch);

      searchKinds.forEach((button) => {
        button.addEventListener('click', () => {
          setSearchKind(button.dataset.searchKind || 'all');
          renderSearch();
        });
      });

      document.querySelectorAll('[data-reader-theme]').forEach((button) => {
        button.addEventListener('click', () => applyReaderTheme(button.dataset.readerTheme));
      });

      bookmarkButton?.addEventListener('click', toggleBookmark);
      drawerBody?.addEventListener('scroll', updateReadingProgress);
      drawerBody?.addEventListener('mouseup', () => setTimeout(showSelectionToolbar, 0));
      drawerBody?.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-memory-drawer]') : null;
        if (!target) return;
        const drawerId = target.dataset.memoryDrawer;
        if (!drawerId) return;
        openDrawer(drawerId, target, { highlightId: target.dataset.memoryHighlight });
      });

      drawerBody?.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-mini-tag]') : null;
        if (!target) return;
        openSearchWithQuery(target.dataset.miniTag || '', 'all');
      });

      drawerBody?.addEventListener('click', (event) => {
        const toggle = event.target instanceof Element ? event.target.closest('[data-memory-toggle]') : null;
        if (!toggle) return;
        const panel = toggle.closest('.reader-memory-panel');
        panel?.classList.toggle('is-open');
      });

      document.querySelector('.home-feed-rail')?.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('[data-sidebar-drawer]') : null;
        if (!target) return;
        const drawerId = target.dataset.sidebarDrawer;
        if (!drawerId) return;
        openDrawer(drawerId, target, { highlightId: target.dataset.sidebarHighlight });
      });

      document.addEventListener('click', (event) => {
        const trigger = event.target instanceof Element ? event.target.closest('[data-seal-trigger]') : null;
        if (!trigger) return;
        event.preventDefault();
        event.stopPropagation();
        const card = trigger.closest('[data-seal-surface], [data-feed-card]');
        if (!card) return;
        const rect = card.getBoundingClientRect?.();
        openSealPalette(
          {
            targetId: card.dataset.sealTarget || card.dataset.drawerId || card.getAttribute('href'),
            drawerId: card.dataset.drawerId || '',
            href: card.getAttribute('href') || '',
            title: card.dataset.sealTitle || card.textContent?.trim() || 'Untitled',
            kind: card.dataset.sealKind || card.dataset.feedKind || 'post',
            targetType: 'card',
            x: rect ? Math.min(0.88, Math.max(0.12, (event.clientX - rect.left) / rect.width)) : 0.78,
            y: rect ? Math.min(0.28, Math.max(0.1, (event.clientY - rect.top) / rect.height)) : 0.14
          },
          trigger
        );
      }, true);

      document.addEventListener('keydown', (event) => {
        const trigger = event.target instanceof Element ? event.target.closest('[data-seal-trigger]') : null;
        if (!trigger || (event.key !== 'Enter' && event.key !== ' ')) return;
        event.preventDefault();
        trigger.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      });

      readerSealButton?.addEventListener('click', () => {
        if (!currentArticle) return;
        openSealPalette(
          {
            targetId: currentArticle.id,
            drawerId: currentArticle.id,
            href: currentArticle.href,
            title: currentArticle.title,
            kind: currentArticle.id.split(':')[0],
            targetType: 'article'
          },
          readerSealButton
        );
      });

      sealPalette?.querySelectorAll('[data-seal-type]').forEach((button) => {
        button.addEventListener('click', () => saveSeal(button.dataset.sealType || 'selected'));
      });

      sealPalette?.querySelector('[data-seal-close]')?.addEventListener('click', closeSealPalette);
      sealPalette?.querySelector('[data-seal-remove]')?.addEventListener('click', removeSeal);

      document.addEventListener('click', async (event) => {
        const colorButton = event.target instanceof Element ? event.target.closest('[data-copy-color]') : null;
        const tokenButton = event.target instanceof Element ? event.target.closest('[data-copy-visual-token]') : null;
        const copyValue = colorButton?.dataset.copyColor;
        const visualId = tokenButton?.dataset.copyVisualToken;
        if (!copyValue && !visualId) return;
        event.preventDefault();
        event.stopPropagation();
        let text = copyValue || '';
        if (visualId) {
          const item = visualKnowledgeItems.find((visual) => visual.id === visualId);
          if (!item) return;
          const colors = item.palette?.colors || [];
          text = JSON.stringify(
            {
              name: item.id,
              tokens: {
                accent: colors[0] || item.palette?.dominant,
                accentMuted: colors[1],
                background: colors[2],
                text: colors[3],
                border: colors[4]
              }
            },
            null,
            2
          );
        }
        try {
          await navigator.clipboard?.writeText(text);
        } catch {
          window.prompt('复制这段内容', text);
        }
      });

      selectionToolbar?.querySelectorAll('[data-highlight-color]').forEach((button) => {
        button.addEventListener('click', () => saveSelectionHighlight(button.dataset.highlightColor || 'gold'));
      });

      selectionToolbar?.querySelector('[data-open-annotation]')?.addEventListener('click', () => {
        const note = window.prompt('写下这条标记的批注');
        if (note !== null) saveSelectionHighlight('gold', note);
      });

      selectionToolbar?.querySelector('[data-copy-selection]')?.addEventListener('click', async () => {
        const text = selectedRange?.toString().trim();
        if (!text) return;
        try {
          await navigator.clipboard.writeText(text);
        } catch {
          // Clipboard can be unavailable in some preview contexts.
        }
        hideSelectionToolbar();
      });

      document.querySelectorAll('[data-article-close]').forEach((button) => {
        button.addEventListener('click', closeDrawer);
      });

      const runReaderCommand = (command, trigger = document.body) => {
        if (!command?.type) return;
        if (command.type === 'openArticle' && command.articleId) {
          openDrawer(command.articleId, trigger);
        }
        if (command.type === 'openHighlight' && command.articleId) {
          openDrawer(command.articleId, trigger, { highlightId: command.highlightId });
        }
        if (command.type === 'searchTag' && command.tag) {
          openSearchWithQuery(command.tag, 'all');
        }
        if (command.type === 'focusGraphNode' && command.nodeId) {
          window.location.href = `/knowledge/?focus=${encodeURIComponent(command.nodeId)}`;
        }
      };

      window.addEventListener('reader-command', (event) => {
        runReaderCommand(event.detail, event.target);
      });

      document.addEventListener('keydown', (event) => {
        const target = event.target;
        const isTyping = target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement;
        const commandSearch = (event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k';
        if (commandSearch) {
          if (document.querySelector('.home-command__trigger')) {
            return;
          }
          event.preventDefault();
          openSearch();
          return;
        }
        if (event.key === 'Escape' && !searchLayer?.hidden) {
          closeSearch();
          return;
        }
        if (event.key === 'Escape' && !layer?.hidden) {
          closeDrawer();
          return;
        }
        if (isTyping || !layer?.hidden || !searchLayer?.hidden) return;
        if (event.key.toLowerCase() === 'j') {
          event.preventDefault();
          setActiveCard(activeIndex + 1);
        }
        if (event.key.toLowerCase() === 'k') {
          event.preventDefault();
          setActiveCard(activeIndex - 1);
        }
        if (event.key === 'Enter') {
          const visibleCards = getVisibleCards();
          const card = visibleCards[activeIndex];
          const id = card?.dataset.drawerId;
          if (id) {
            event.preventDefault();
            openDrawer(id, card);
          }
        }
      });

      applyReaderTheme(localStorage.getItem(storageKeys.readerTheme) || 'light');
      initSidebar();
      renderSidebarState();
      renderSeals();
      initHeroBanner();
      const params = new URLSearchParams(window.location.search);
      const readerId = params.get('reader');
      const highlightId = params.get('highlight');
      const searchTag = params.get('searchTag');
      if (readerId) {
        const trigger = document.querySelector(`[data-drawer-id="${escapeCssIdentifier(readerId)}"]`) || document.body;
        runReaderCommand(
          highlightId ? { type: 'openHighlight', articleId: readerId, highlightId } : { type: 'openArticle', articleId: readerId },
          trigger
        );
      } else if (searchTag) {
        runReaderCommand({ type: 'searchTag', tag: searchTag }, document.body);
      }
    })();
  </script>
  <GitHubRuntimeSync />
</BaseLayout>
