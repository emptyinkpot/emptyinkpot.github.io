---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChartCard from '../components/visualizations/ChartCard.astro';
import GitHubHeatmap from '../components/visualizations/GitHubHeatmap.astro';
import GitHubLanguageDonut from '../components/visualizations/GitHubLanguageDonut.astro';
import GitHubMonthlyLine from '../components/visualizations/GitHubMonthlyLine.astro';
import MusicCard from '../components/showcase/MusicCard.astro';
import type { HomeBook } from '../data/books';
import { formatDate, getExcerptFromBody, getPrimaryCategory, getReadingTime, sortPosts, toSlug } from '../lib/content';
import { buildGitHubAnalytics, getRecentHeatmapWeeks } from '../lib/analytics';
import { books } from '../data/books';
import { musicItems, type MusicItem } from '../data/music';
import { getGitHubOverview } from '../lib/github';
import { profileLinks } from '../lib/profile';
import { getPostCover } from '../lib/postCovers';
import { getRelatedKnowledgeEntries, type KnowledgeRelationSource } from '../lib/knowledge/relations';
import { withBase } from '../lib/site';

type DrawerKind = 'post' | 'note' | 'project' | 'book' | 'music' | 'github' | 'bilibili' | 'update';

type DrawerEntry = {
  id: string;
  kind: DrawerKind;
  title: string;
  kicker: string;
  date?: string;
  href: string;
  summary: string;
  Content?: Awaited<ReturnType<typeof render>>['Content'];
  toc?: Array<{ href: string; className: string; text: string }>;
  coverSrc?: string;
  accent?: string;
  tags?: string[];
  series?: string;
  body?: string;
  details?: Array<{ label: string; value: string }>;
  chartVariant?: 'heatmap' | 'line' | 'language';
};

type FeedItem = {
  id: string;
  type: 'post' | 'note' | 'project' | 'book' | 'music' | 'github' | 'bilibili' | 'update';
  title: string;
  summary: string;
  kicker: string;
  meta?: string;
  href?: string;
  drawerId?: string;
  githubVariant?: 'repo' | 'heatmap' | 'line' | 'language' | 'team';
  musicItem?: MusicItem;
  coverSrc?: string;
  tags?: string[];
  accent?: string;
  size?: 'compact' | 'standard' | 'tall';
};

const sealTypes = [
  { id: 'selected', label: '精选', color: '#9E2A2B', shape: 'circle' },
  { id: 'important', label: '重要', color: '#6B2D5C', shape: 'circle' },
  { id: 'insight', label: '洞见', color: '#2F5D50', shape: 'square' },
  { id: 'unfinished', label: '未完', color: '#6B645C', shape: 'square' },
  { id: 'reread', label: '重读', color: '#C9A227', shape: 'vertical' },
  { id: 'archive', label: '归档', color: '#3A3A3A', shape: 'vertical' }
] as const;

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const notes = [...(await getCollection('notes', ({ data }) => !data.draft))].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const projects = [...(await getCollection('projects'))].sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
const github = await getGitHubOverview('emptyinkpot');
const githubAnalytics = buildGitHubAnalytics(github);
const recentHeatmapWeeks = getRecentHeatmapWeeks(githubAnalytics, 12);
const recentSignalDays = githubAnalytics.heatmapWeeks.flatMap((week) => week.days).slice(-7);
const maxRecentSignal = Math.max(...recentSignalDays.map((day) => day.count), 1);

const drawerSources = [
  ...posts.map((entry) => ({ entry, kind: 'post' as const })),
  ...notes.map((entry) => ({ entry, kind: 'note' as const })),
  ...projects.map((entry) => ({ entry, kind: 'project' as const }))
];

const articleDrawerEntries: DrawerEntry[] = await Promise.all(
  drawerSources.map(async ({ entry, kind }) => {
    const rendered = await render(entry as CollectionEntry<'posts'>);
    const basePath = kind === 'post' ? 'posts' : kind === 'note' ? 'notes' : 'projects';
    const summary =
      'summary' in entry.data && entry.data.summary
        ? entry.data.summary
        : entry.data.description ?? getExcerptFromBody(entry.body, 180);
    const tags =
      kind === 'post'
        ? [
            getPrimaryCategory(entry as CollectionEntry<'posts'>),
            ...(entry as CollectionEntry<'posts'>).data.tags,
            ...((entry as CollectionEntry<'posts'>).data.series ? [(entry as CollectionEntry<'posts'>).data.series] : [])
          ]
        : kind === 'project'
          ? (entry as CollectionEntry<'projects'>).data.stack
          : ['note'];

    return {
      id: `${kind}:${entry.id}`,
      kind,
      title: entry.data.title,
      kicker: kind === 'post' ? getPrimaryCategory(entry as CollectionEntry<'posts'>) : kind === 'note' ? '札记' : '项目',
      date: 'date' in entry.data && entry.data.date ? formatDate(entry.data.date) : undefined,
      href: withBase(`/${basePath}/${entry.id}/`),
      summary,
      tags,
      series: kind === 'post' ? (entry as CollectionEntry<'posts'>).data.series : undefined,
      body: entry.body,
      Content: rendered.Content,
      toc: rendered.headings
        .filter((heading) => heading.depth <= 3)
        .map((heading) => ({
          href: `#${heading.slug}`,
          className: `depth-${heading.depth}`,
          text: heading.text
        }))
    };
  })
);

const postItems: FeedItem[] = posts.map((post, index) => ({
  id: `post-${post.id}`,
  type: 'post',
  title: post.data.title,
  summary: post.data.summary ?? post.data.description ?? getExcerptFromBody(post.body, index === 0 ? 220 : 130),
  kicker: getPrimaryCategory(post),
  meta: `${formatDate(post.data.date)} / ${getReadingTime(post.body)} min read`,
  href: withBase(`/posts/${post.id}/`),
  drawerId: `post:${post.id}`,
  coverSrc: getPostCover(post),
  tags: post.data.tags.slice(0, 3),
  size: index % 5 === 0 ? 'tall' : index % 3 === 0 ? 'compact' : 'standard'
}));

const noteItems: FeedItem[] = notes.map((note) => ({
  id: `note-${note.id}`,
  type: 'note',
  title: note.data.title,
  summary: note.data.description ?? getExcerptFromBody(note.body, 120),
  kicker: '札记',
  meta: formatDate(note.data.date),
  href: withBase(`/notes/${note.id}/`),
  drawerId: `note:${note.id}`,
  tags: ['note'],
  size: 'compact'
}));

const projectItems: FeedItem[] = projects.map((project) => ({
  id: `project-${project.id}`,
  type: 'project',
  title: project.data.title,
  summary: project.data.description ?? getExcerptFromBody(project.body, 130),
  kicker: `项目 / ${project.data.status}`,
  meta: project.data.stack.slice(0, 3).join(' / '),
  href: withBase(`/projects/${project.id}/`),
  drawerId: `project:${project.id}`,
  tags: project.data.stack.slice(0, 3),
  size: 'standard'
}));

const githubItems: FeedItem[] = github.repos.slice(0, 6).map((repo, index) => ({
  id: `github-${repo.name}`,
  type: 'github',
  githubVariant: 'repo',
  title: repo.name,
  summary: `${repo.language} / ${repo.stars} stars / ${repo.issues} issues`,
  kicker: 'GitHub',
  meta: `更新 ${formatDate(new Date(repo.updatedAt))}`,
  href: repo.htmlUrl,
  drawerId: `github-repo:${repo.name}`,
  accent: ['#660874', '#244a5a', '#3b6b50', '#8e53a2'][index % 4],
  tags: [repo.language],
  size: 'compact'
}));

const githubChartItems: FeedItem[] = [
  {
    id: 'github-heatmap-mini',
    type: 'github',
    githubVariant: 'heatmap',
    title: 'GitHub 活动热力图',
    summary: `${githubAnalytics.totalContributions} 次年度活动 / ${githubAnalytics.activeDays} 个活跃日`,
    kicker: 'GitHub / Heatmap',
    meta: '最近 12 周',
    href: withBase('/github/'),
    drawerId: 'github:heatmap',
    tags: ['heatmap', 'activity'],
    size: 'standard'
  },
  {
    id: 'github-line-mini',
    type: 'github',
    githubVariant: 'line',
    title: '月度贡献折线',
    summary: '从 GitHub 快照派生的月度活动趋势，不在首页重抓数据。',
    kicker: 'GitHub / Line',
    meta: 'monthly',
    href: withBase('/github/'),
    drawerId: 'github:line',
    tags: ['line', 'trend'],
    size: 'compact'
  },
  {
    id: 'github-language-mini',
    type: 'github',
    githubVariant: 'language',
    title: '语言占比',
    summary: githubAnalytics.topLanguage
      ? `${githubAnalytics.topLanguage.label} 当前占比 ${githubAnalytics.topLanguage.percent}%`
      : '语言分布等待快照数据。',
    kicker: 'GitHub / Donut',
    meta: 'languages',
    href: withBase('/github/'),
    drawerId: 'github:language',
    tags: ['donut', 'language'],
    size: 'compact'
  }
];

const bookItems: FeedItem[] = books.map((book) => ({
  id: `book-${toSlug(book.title)}`,
  type: 'book',
  title: book.title,
  summary: book.note,
  kicker: `书架 / ${book.statusLabel}`,
  meta: book.author,
  href: withBase('/books/'),
  drawerId: `book:${toSlug(book.title)}`,
  coverSrc: book.cover,
  tags: [book.statusLabel],
  size: 'compact'
}));

const musicFeedItems: FeedItem[] = musicItems.map((item) => ({
  id: `music-${item.id}`,
  type: 'music',
  title: item.title,
  summary: item.note,
  kicker: `音乐 / ${item.platform}`,
  meta: item.artist,
  href: withBase('/music/'),
  drawerId: `music:${item.id}`,
  musicItem: item,
  coverSrc: item.cover,
  tags: item.mood,
  size: 'compact'
}));

const bilibiliItems: FeedItem[] = [
  {
    id: 'bilibili-profile',
    type: 'bilibili',
    title: profileLinks.bilibiliLabel,
    summary: profileLinks.bilibiliDescription,
    kicker: 'Bilibili',
    meta: profileLinks.bilibiliConfigured ? '视频主页' : '待配置主页链接',
    href: profileLinks.bilibili,
    drawerId: 'bilibili:profile',
    tags: ['video'],
    accent: '#fb7299',
    size: 'compact'
  }
];

const updateItems: FeedItem[] = [
  {
    id: 'update-evidence-library',
    type: 'update',
    title: '史料素材库已经成为独立板块',
    summary: '用于沉淀 OpenList、Remotion、Evidence Resolver 和素材标注的公开说明入口。',
    kicker: 'Update',
    meta: 'evidence-library',
    href: withBase('/evidence-library/'),
    drawerId: 'update:evidence-library',
    tags: ['evidence', 'remotion'],
    size: 'standard'
  }
];

const feedItems = [
  postItems[0],
  ...projectItems.slice(0, 1),
  ...noteItems.slice(0, 1),
  ...bookItems.slice(0, 2),
  githubChartItems[0],
  musicFeedItems[0],
  ...githubItems.slice(0, 2),
  ...postItems.slice(1, 5),
  githubChartItems[1],
  ...bilibiliItems,
  ...updateItems,
  githubChartItems[2],
  ...postItems.slice(5),
  ...projectItems.slice(1),
  ...noteItems.slice(1),
  ...githubItems.slice(2),
  ...bookItems.slice(2),
  ...musicFeedItems.slice(1)
].filter(Boolean) as FeedItem[];

const bookDrawerEntries: DrawerEntry[] = books.map((book: HomeBook) => ({
  id: `book:${toSlug(book.title)}`,
  kind: 'book',
  title: book.title,
  kicker: `书架 / ${book.statusLabel}`,
  href: withBase('/books/'),
  summary: book.note,
  coverSrc: book.cover,
  tags: [book.statusLabel],
  details: [
    { label: '作者', value: book.author },
    { label: '状态', value: book.statusLabel }
  ]
}));

const musicDrawerEntries: DrawerEntry[] = musicItems.map((item) => ({
  id: `music:${item.id}`,
  kind: 'music',
  title: item.title,
  kicker: `音乐 / ${item.platform}`,
  href: withBase('/music/'),
  summary: item.note,
  coverSrc: item.cover,
  tags: item.mood,
  details: [
    { label: 'Artist', value: item.artist },
    ...(item.album ? [{ label: 'Album', value: item.album }] : []),
    { label: 'Platform', value: item.platform }
  ]
}));

const githubDrawerEntries: DrawerEntry[] = [
  {
    id: 'github:heatmap',
    kind: 'github',
    title: 'GitHub 活动热力图',
    kicker: 'GitHub / Heatmap',
    href: withBase('/github/'),
    summary: `${githubAnalytics.totalContributions} 次年度活动，最近 12 周作为首页 mini 图表展示，完整年度热力图在 GitHub 仪表盘里展开。`,
    chartVariant: 'heatmap',
    tags: ['heatmap', 'activity'],
    details: [
      { label: '年度活动', value: String(githubAnalytics.totalContributions) },
      { label: '活跃日', value: String(githubAnalytics.activeDays) }
    ]
  },
  {
    id: 'github:line',
    kind: 'github',
    title: '月度贡献折线',
    kicker: 'GitHub / Line',
    href: withBase('/github/'),
    summary: '从 GitHub snapshot 派生的月度贡献趋势。首页只保留摘要，完整图表进入 /github/。',
    chartVariant: 'line',
    tags: ['line', 'trend']
  },
  {
    id: 'github:language',
    kind: 'github',
    title: '语言占比',
    kicker: 'GitHub / Donut',
    href: withBase('/github/'),
    summary: githubAnalytics.topLanguage
      ? `${githubAnalytics.topLanguage.label} 当前占比 ${githubAnalytics.topLanguage.percent}%，完整语言分布在 /github/。`
      : '语言分布等待 GitHub snapshot 数据。',
    chartVariant: 'language',
    tags: ['donut', 'language']
  },
  ...github.repos.slice(0, 6).map((repo) => ({
    id: `github-repo:${repo.name}`,
    kind: 'github' as const,
    title: repo.name,
    kicker: 'GitHub / Repository',
    href: repo.htmlUrl,
    summary: repo.description || `${repo.language} repository`,
    tags: [repo.language],
    details: [
      { label: 'Stars', value: String(repo.stars) },
      { label: 'Issues', value: String(repo.issues) },
      { label: 'Updated', value: formatDate(new Date(repo.updatedAt)) }
    ]
  }))
];

const utilityDrawerEntries: DrawerEntry[] = [
  {
    id: 'bilibili:profile',
    kind: 'bilibili',
    title: profileLinks.bilibiliLabel,
    kicker: 'Bilibili',
    href: profileLinks.bilibili,
    summary: profileLinks.bilibiliDescription,
    accent: '#fb7299',
    tags: [profileLinks.bilibiliConfigured ? 'configured' : 'pending']
  },
  {
    id: 'update:evidence-library',
    kind: 'update',
    title: '史料素材库已经成为独立板块',
    kicker: 'Update',
    href: withBase('/evidence-library/'),
    summary: '用于沉淀 OpenList、Remotion、Evidence Resolver 和素材标注的公开说明入口。',
    tags: ['evidence', 'remotion']
  }
];

const drawerEntries = [
  ...articleDrawerEntries,
  ...bookDrawerEntries,
  ...musicDrawerEntries,
  ...githubDrawerEntries,
  ...utilityDrawerEntries
];
const drawerById = new Map(drawerEntries.map((entry) => [entry.id, entry]));
const relationSources = drawerEntries.map((entry) => ({
  id: entry.id,
  kind: entry.kind,
  title: entry.title,
  summary: entry.summary,
  tags: entry.tags ?? [],
  series: entry.series,
  href: entry.href,
  body: entry.body
})) satisfies KnowledgeRelationSource[];
const knowledgeDocs = drawerEntries.map((entry) => ({
  id: entry.id,
  type: entry.kind,
  title: entry.title,
  content: [entry.summary, ...(entry.tags ?? []), ...(entry.details?.map((detail) => `${detail.label} ${detail.value}`) ?? [])].join('\n'),
  tags: entry.tags ?? [],
  href: entry.href,
  drawerId: entry.id
}));

function getRelatedEntries(entry: DrawerEntry) {
  const source = relationSources.find((item) => item.id === entry.id);
  if (!source) return [];
  return getRelatedKnowledgeEntries(source, relationSources, 3)
    .map(({ entry: item }) => drawerById.get(item.id))
    .filter(Boolean) as DrawerEntry[];
}

function feedCardClass(item: FeedItem) {
  return ['home-feed-card', `home-feed-card--${item.type}`, `home-feed-card--${item.size ?? 'standard'}`].join(' ');
}
---

<BaseLayout title="emptyinkpot" description="emptyinkpot 的首页，聚合文章、书架、项目、GitHub 与视频入口。" hideSiteChrome={true}>
  <div class="home-feed-shell">
    <aside class="home-feed-rail" aria-label="个人状态与知识记忆">
      <section class="home-feed-profile">
        <a class="home-feed-brand" href={withBase('/')}>
          <img src={withBase('/images/branding/vita-atramenti-logo.png')} alt="emptyinkpot" />
          <span>emptyinkpot</span>
        </a>
        <img class="home-feed-avatar" src={github.profile.avatarUrl} alt={github.profile.name} />
        <h1>{github.profile.name}</h1>
        <p>Content OS · Knowledge System</p>
      </section>

      <section class="home-feed-rail-card home-feed-signals">
        <span>Signals</span>
        <strong>@{github.profile.login}</strong>
        <p>{github.totalContributions} 次年度活动 / {github.profile.publicRepos} 个公开仓库</p>
        <div class="home-feed-signal-grid" aria-label="GitHub signal summary">
          <div>
            <small>Posts</small>
            <b>{posts.length}</b>
          </div>
          <div>
            <small>Repos</small>
            <b>{github.profile.publicRepos}</b>
          </div>
          <div>
            <small>Active</small>
            <b>{githubAnalytics.activeDays}</b>
          </div>
        </div>
        <GitHubHeatmap weeks={recentHeatmapWeeks} compact />
        <div class="home-feed-trend" aria-label="最近 7 天活动趋势">
          {recentSignalDays.map((day) => (
            <i style={`--signal-height:${Math.max(10, Math.round((day.count / maxRecentSignal) * 100))}%`} title={`${day.date}: ${day.count}`} />
          ))}
        </div>
      </section>

      <section class="home-feed-rail-card home-feed-memory">
        <span>Reading Memory</span>
        <strong>最近阅读</strong>
        <ul data-sidebar-history>
          <li>暂无记录</li>
        </ul>
      </section>

      <section class="home-feed-rail-card home-feed-stats">
        <span>Knowledge Stats</span>
        <strong>知识状态</strong>
        <div class="home-feed-stat-grid">
          <div><small>高亮</small><b data-sidebar-stat="highlights">0</b></div>
          <div><small>批注</small><b data-sidebar-stat="annotations">0</b></div>
          <div><small>收藏</small><b data-sidebar-stat="bookmarks">0</b></div>
          <div><small>阅读</small><b data-sidebar-stat="history">0</b></div>
        </div>
        <ul data-sidebar-bookmarks>
          <li>暂无收藏</li>
        </ul>
      </section>

      <section class="home-feed-rail-card home-feed-quick">
        <span>Quick Actions</span>
        <button type="button" data-search-open>搜索</button>
        <a href={withBase('/knowledge/')}>Graph</a>
        <a href={withBase('/settings/')}>设置</a>
      </section>
    </aside>

    <main class="home-feed-main" data-pagefind-body>
      <section class="home-hero-banner" data-hero-banner aria-label="emptyinkpot hero banner">
        <div class="home-hero-banner__layer home-hero-banner__layer--bg" data-hero-layer="bg"></div>
        <div class="home-hero-banner__layer home-hero-banner__layer--mid" data-hero-layer="mid"></div>
        <div class="home-hero-banner__layer home-hero-banner__layer--front" data-hero-layer="front"></div>
        <div class="home-hero-banner__overlay"></div>
        <div class="home-hero-banner__content">
          <span data-hero-season-label>Seasonal Field</span>
          <h1>EMPTYINKPOT</h1>
          <p>Content OS · Tangible Knowledge UI</p>
        </div>
      </section>

      <div class="home-feed-toolbar" aria-label="首页内容筛选">
        <div>
          <span>Feed</span>
          <strong>连续浏览</strong>
        </div>
        <nav class="home-feed-tabs" aria-label="首页唯一导航">
          <button type="button" class="home-feed-tab home-feed-tab--search" data-search-open>搜索</button>
          <button type="button" class="home-feed-tab is-active" data-feed-filter="all">全部</button>
          <button type="button" class="home-feed-tab" data-feed-filter="post">文章</button>
          <button type="button" class="home-feed-tab" data-feed-filter="note">笔记</button>
          <button type="button" class="home-feed-tab" data-feed-filter="project">项目</button>
          <button type="button" class="home-feed-tab" data-feed-filter="book">书架</button>
          <button type="button" class="home-feed-tab" data-feed-filter="music">音乐</button>
          <button type="button" class="home-feed-tab" data-feed-filter="github">GitHub</button>
          <button type="button" class="home-feed-tab" data-feed-filter="bilibili">Bilibili</button>
          <button type="button" class="home-feed-tab" data-feed-filter="update">史料素材库</button>
          <a class="home-feed-tab" href={withBase('/settings/')}>设置</a>
        </nav>
      </div>

      <section class="home-feed-grid" aria-label="内容流">
        {feedItems.map((item) =>
          item.type === 'github' && item.githubVariant === 'heatmap' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--github"><span>GitHub</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <ChartCard
                kicker={item.kicker}
                title={item.title}
                summary={item.summary}
                metric={item.meta}
                compact
              >
                <GitHubHeatmap weeks={recentHeatmapWeeks} compact />
              </ChartCard>
            </button>
          ) : item.type === 'github' && item.githubVariant === 'line' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--github"><span>Line</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <ChartCard kicker={item.kicker} title={item.title} summary={item.summary} compact>
                <GitHubMonthlyLine points={githubAnalytics.monthly} compact />
              </ChartCard>
            </button>
          ) : item.type === 'github' && item.githubVariant === 'language' ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--github"><span>Donut</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <ChartCard kicker={item.kicker} title={item.title} summary={item.summary} compact>
                <GitHubLanguageDonut languages={githubAnalytics.languages} compact />
              </ChartCard>
            </button>
          ) : item.type === 'music' && item.musicItem ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class="bookmark bookmark--music"><span>Music</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              <MusicCard item={item.musicItem} compact inertCard />
            </button>
          ) : item.drawerId && drawerById.has(item.drawerId) ? (
            <button
              type="button"
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-drawer-id={item.drawerId}
              data-seal-target={item.drawerId ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
            >
              <div class={`bookmark bookmark--${item.type}`}><span>{item.type}</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              {item.coverSrc ? (
                <div class="home-feed-card__cover">
                  <img src={item.coverSrc} alt="" loading="lazy" />
                </div>
              ) : (
                <div class="home-feed-card__mark" style={item.accent ? `--feed-accent:${item.accent}` : undefined}>
                  {item.type}
                </div>
              )}
              <div class="home-feed-card__body">
                <div class="home-feed-card__meta">
                  <span>{item.kicker}</span>
                  {item.meta && <small>{item.meta}</small>}
                </div>
                <h2>{item.title}</h2>
                <p>{item.summary}</p>
                {item.tags?.length ? (
                  <div class="home-feed-card__tags">
                    {item.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                ) : null}
              </div>
            </button>
          ) : (
            <a
              class={feedCardClass(item)}
              data-feed-card
              data-feed-kind={item.type}
              data-seal-target={item.drawerId ?? item.href ?? item.id}
              data-seal-title={item.title}
              data-seal-kind={item.type}
              href={item.href ?? withBase('/')}
            >
              <div class={`bookmark bookmark--${item.type}`}><span>{item.type}</span></div>
              <span class="seal-trigger" role="button" tabindex="0" data-seal-trigger>盖章</span>
              {item.coverSrc ? (
                <div class="home-feed-card__cover">
                  <img src={item.coverSrc} alt="" loading="lazy" />
                </div>
              ) : (
                <div class="home-feed-card__mark" style={item.accent ? `--feed-accent:${item.accent}` : undefined}>
                  {item.type}
                </div>
              )}
              <div class="home-feed-card__body">
                <div class="home-feed-card__meta">
                  <span>{item.kicker}</span>
                  {item.meta && <small>{item.meta}</small>}
                </div>
                <h2>{item.title}</h2>
                <p>{item.summary}</p>
                {item.tags?.length ? (
                  <div class="home-feed-card__tags">
                    {item.tags.map((tag) => <span>{tag}</span>)}
                  </div>
                ) : null}
              </div>
            </a>
          )
        )}
      </section>
    </main>
  </div>

  <div class="home-article-layer" data-article-layer hidden>
    <button class="home-article-backdrop" type="button" data-article-close aria-label="关闭阅读抽屉"></button>
    <aside class="home-article-drawer" role="dialog" aria-modal="true" aria-labelledby="home-article-title">
      <div class="reading-progress" data-reading-progress></div>
      <header class="home-article-drawer__header">
        <div>
          <span data-article-kicker></span>
          <h2 id="home-article-title" data-article-title></h2>
        </div>
        <div class="home-article-drawer__actions">
          <div class="reader-theme-switch" aria-label="阅读主题">
            <button type="button" data-reader-theme="light">Light</button>
            <button type="button" data-reader-theme="sepia">Sepia</button>
            <button type="button" data-reader-theme="dark">Dark</button>
          </div>
          <button type="button" data-reader-bookmark>收藏</button>
          <button type="button" data-reader-seal>盖章</button>
          <a href={withBase('/knowledge/')} data-reader-graph>知识图谱</a>
          <a href={withBase('/posts/')} data-article-full>完整页面</a>
          <button type="button" data-article-close>关闭</button>
        </div>
      </header>
      <div class="home-article-drawer__body" data-article-body></div>
    </aside>
  </div>

  <div class="knowledge-search-layer" data-search-layer hidden>
    <button class="knowledge-search-backdrop" type="button" data-search-close aria-label="关闭搜索"></button>
    <section class="knowledge-search-panel" role="dialog" aria-modal="true" aria-label="Knowledge search">
      <div class="knowledge-search-input-row">
        <input type="search" data-search-input placeholder="搜索文章、项目、书架、音乐、GitHub、标记..." />
        <kbd>Esc</kbd>
      </div>
      <nav class="knowledge-search-tabs" aria-label="搜索类型">
        {['all', 'post', 'note', 'project', 'book', 'music', 'github', 'highlight', 'seal'].map((kind) => (
          <button type="button" class={kind === 'all' ? 'is-active' : ''} data-search-kind={kind}>{kind}</button>
        ))}
      </nav>
      <div class="knowledge-search-results" data-search-results>
        <p class="knowledge-search-empty">输入关键词，或按 Cmd/Ctrl + K 随时打开搜索。</p>
      </div>
