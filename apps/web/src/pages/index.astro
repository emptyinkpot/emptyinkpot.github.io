            <div>
              <HomeNumberTicker client:visible value={posts.length} />
              <small>Posts</small>
            </div>
            <div>
              <span data-github-metric="publicRepos"><HomeNumberTicker client:visible value={github.profile.publicRepos} /></span>
              <small>Repos</small>
            </div>
            <div>
              <HomeNumberTicker client:visible value={projects.length} />
              <small>Projects</small>
            </div>
            <div>
              <HomeNumberTicker client:visible value={knowledgeDocs.length} />
              <small>Nodes</small>
            </div>
          </div>
        </div>
