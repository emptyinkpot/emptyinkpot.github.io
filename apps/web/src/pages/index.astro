          <div><small data-copy-key="home.stats.annotations">批注</small><b data-sidebar-stat="annotations">0</b></div>
          <div><small data-copy-key="home.stats.bookmarks">收藏</small><b data-sidebar-stat="bookmarks">0</b></div>
