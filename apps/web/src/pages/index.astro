---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ChartCard from '../components/visualizations/ChartCard.astro';
import GitHubHeatmap from '../components/visualizations/GitHubHeatmap.astro';
import GitHubLanguageDonut from '../components/visualizations/GitHubLanguageDonut.astro';
import GitHubMonthlyLine from '../components/visualizations/GitHubMonthlyLine.astro';
import GitHubRuntimeSync from '../components/visualizations/GitHubRuntimeSync.astro';
import MusicCard from '../components/showcase/MusicCard.astro';
import HomeCommandPalette from '../components/react/HomeCommandPalette';
import HomeNumberTicker from '../components/react/HomeNumberTicker';
import { formatDate, getExcerptFromBody, getPrimaryCategory, getReadingTime, sortPosts } from '../lib/content';
import { buildGitHubAnalytics, getRecentHeatmapWeeks } from '../lib/analytics';
import { books } from '../data/books';
import { musicItems, type MusicItem } from '../data/music';
import { visualItems, type VisualItem } from '../data/visuals';
import { getGitHubOverview } from '../lib/github';
import { profileLinks } from '../lib/profile';
import { getPostCover } from '../lib/postCovers';
import { getRelatedKnowledgeEntries, type KnowledgeRelationSource } from '../lib/knowledge/relations';
import { defaultSealDefinitions, sealDefinitionStorageKey } from '../lib/knowledge/seals';
import { withBase } from '../lib/site';

type DrawerKind = 'post' | 'note' | 'project' | 'book' | 'music' | 'github' | 'visual' | 'knowledge' | 'bilibili' | 'update';

type DrawerEntry = {
  id: string;
  kind: DrawerKind;
  title: string;
  kicker: string;
  date?: string;
  href: string;
  summary: string;
  Content?: Awaited<ReturnType<typeof render>>['Content'];
  toc?: Array<{ href: string; className: string; text: string }>;
  coverSrc?: string;
  accent?: string;
  tags?: string[];
  series?: string;
  body?: string;
  details?: Array<{ label: string; value: string }>;
  chartVariant?: 'heatmap' | 'line' | 'language';
  visualItem?: VisualItem;
  readHref?: string;
};

type FeedItem = {
  id: string;
  type: 'post' | 'note' | 'project' | 'book' | 'music' | 'github' | 'visual' | 'bilibili' | 'update';
  title: string;
  summary: string;
  kicker: string;
  meta?: string;
  href?: string;
  drawerId?: string;
  githubVariant?: 'repo' | 'heatmap' | 'line' | 'language' | 'team';
  musicItem?: MusicItem;
  visualItem?: VisualItem;
  coverSrc?: string;
  tags?: string[];
  accent?: string;
  size?: 'compact' | 'standard' | 'tall';
};

const sealTypes = defaultSealDefinitions;

const posts = sortPosts(await getCollection('posts', ({ data }) => !data.draft));
const notes = [...(await getCollection('notes', ({ data }) => !data.draft))].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const projects = [...(await getCollection('projects'))].sort(
  (a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0)
);
const github = await getGitHubOverview('emptyinkpot');
const githubAnalytics = buildGitHubAnalytics(github);
const recentHeatmapWeeks = getRecentHeatmapWeeks(githubAnalytics, 12);

const drawerSources = [
  ...posts.map((entry) => ({ entry, kind: 'post' as const })),
  ...notes.map((entry) => ({ entry, kind: 'note' as const })),
  ...projects.map((entry) => ({ entry, kind: 'project' as const }))
];

const articleDrawerEntries: DrawerEntry[] = await Promise.all(
  drawerSources.map(async ({ entry, kind }) => {
    const rendered = await render(entry as CollectionEntry<'posts'>);
    const basePath = kind === 'post' ? 'posts' : kind === 'note' ? 'notes' : 'projects';
    const summary =
      'summary' in entry.data && entry.data.summary
        ? entry.data.summary
        : entry.data.description ?? getExcerptFromBody(entry.body, 180);
    const tags =
      kind === 'post'
        ? [
            getPrimaryCategory(entry as CollectionEntry<'posts'>),
            ...(entry as CollectionEntry<'posts'>).data.tags,
            ...((entry as CollectionEntry<'posts'>).data.series ? [(entry as CollectionEntry<'posts'>).data.series] : [])
          ]
        : kind === 'project'
          ? (entry as CollectionEntry<'projects'>).data.stack
          : ['note'];

    return {
      id: `${kind}:${entry.id}`,
      kind,
      title: entry.data.title,
      kicker: kind === 'post' ? getPrimaryCategory(entry as CollectionEntry<'posts'>) : kind === 'note' ? '札记' : '项目工坊',
      date: 'date' in entry.data && entry.data.date ? formatDate(entry.data.date) : undefined,
      href: withBase(`/${basePath}/${entry.id}/`),
      summary,
      tags,
      series: kind === 'post' ? (entry as CollectionEntry<'posts'>).data.series : undefined,
      body: entry.body,
      Content: rendered.Content,
      toc: rendered.headings
        .filter((heading) => heading.depth <= 3)
        .map((heading) => ({
          href: `#${heading.slug}`,
          className: `depth-${heading.depth}`,
          text: heading.text
        }))
    };
  })
);

const postItems: FeedItem[] = posts.map((post, index) => ({
  id: `post-${post.id}`,
  type: 'post',
  title: post.data.title,
  summary: post.data.summary ?? post.data.description ?? getExcerptFromBody(post.body, index === 0 ? 220 : 130),
  kicker: getPrimaryCategory(post),
  meta: `${formatDate(post.data.date)} / ${getReadingTime(post.body)} min read`,
  href: withBase(`/posts/${post.id}/`),
  drawerId: `post:${post.id}`,
  coverSrc: getPostCover(post),
  tags: post.data.tags.slice(0, 3),
  size: index % 5 === 0 ? 'tall' : index % 3 === 0 ? 'compact' : 'standard'
}));

const noteItems: FeedItem[] = notes.map((note) => ({
  id: `note-${note.id}`,
  type: 'note',
  title: note.data.title,
  summary: note.data.description ?? getExcerptFromBody(note.body, 120),
  kicker: '札记',
  meta: formatDate(note.data.date),
  href: withBase(`/notes/${note.id}/`),
  drawerId: `note:${note.id}`,
  tags: ['note'],
  size: 'compact'
}));

const projectItems: FeedItem[] = projects.map((project) => ({
  id: `project-${project.id}`,
  type: 'project',
  title: project.data.title,
  summary: project.data.description ?? getExcerptFromBody(project.body, 130),
  kicker: `项目工坊 / ${project.data.status}`,
  meta: project.data.stack.slice(0, 3).join(' / '),
  href: withBase(`/projects/${project.id}/`),
  drawerId: `project:${project.id}`,
  tags: project.data.stack.slice(0, 3),
  size: 'standard'
}));

const githubItems: FeedItem[] = github.repos.slice(0, 6).map((repo, index) => ({
  id: `github-${repo.name}`,
  type: 'github',
  githubVariant: 'repo',
  title: repo.name,
  summary: `${repo.language} / ${repo.stars} stars / ${repo.issues} issues`,
  kicker: 'GitHub',
  meta: `更新 ${formatDate(new Date(repo.updatedAt))}`,
  href: repo.htmlUrl,
  drawerId: `github-repo:${repo.name}`,
  accent: ['#660874', '#244a5a', '#3b6b50', '#8e53a2'][index % 4],
  tags: [repo.language],
  size: 'compact'
}));

const githubChartItems: FeedItem[] = [
  {
    id: 'github-heatmap-mini',
    type: 'github',
    githubVariant: 'heatmap',
    title: 'GitHub 活动热力图',
    summary: `${githubAnalytics.totalContributions} 次年度活动 / ${githubAnalytics.activeDays} 个活跃日`,
    kicker: 'GitHub / Heatmap',
    meta: '最近 12 周',
    href: withBase('/github/'),
    drawerId: 'github:heatmap',
    tags: ['heatmap', 'activity'],
    size: 'standard'
  },
  {
    id: 'github-line-mini',
    type: 'github',
    githubVariant: 'line',
    title: '月度贡献折线',
    summary: '打开页面后由 GitHub runtime API 刷新月度活动趋势。',
    kicker: 'GitHub / Line',
    meta: 'monthly',
    href: withBase('/github/'),
    drawerId: 'github:line',
    tags: ['line', 'trend'],
    size: 'compact'
  },
  {
    id: 'github-language-mini',
    type: 'github',
    githubVariant: 'language',
    title: '语言占比',
    summary: githubAnalytics.topLanguage
      ? `${githubAnalytics.topLanguage.label} 当前占比 ${githubAnalytics.topLanguage.percent}%`
      : '语言分布等待快照数据。',
    kicker: 'GitHub / Donut',
    meta: 'languages',
    href: withBase('/github/'),
    drawerId: 'github:language',
    tags: ['donut', 'language'],
    size: 'compact'
  }
];

const bookItems: FeedItem[] = books.map((book) => ({
  id: `book-${book.id}`,
  type: 'book',
  title: book.title,
  summary: book.note,
  kicker: `书架 / ${book.statusLabel}`,
  meta: book.author,
  href: withBase(`/books/${book.id}/`),
  drawerId: `book:${book.id}`,
  coverSrc: book.cover,
  tags: [book.category, book.statusLabel, book.sourceType.toUpperCase(), ...book.tags].slice(0, 4),
  size: 'compact'
}));

const musicFeedItems: FeedItem[] = musicItems.map((item) => ({
  id: `music-${item.id}`,
  type: 'music',
  title: item.title,
  summary: item.note,
  kicker: `音乐 / ${item.platform}`,
  meta: item.artist,
  href: withBase('/music/'),
  drawerId: `music:${item.id}`,
  musicItem: item,
  coverSrc: item.cover,
  tags: item.mood,
  size: 'compact'
}));

const bilibiliItems: FeedItem[] = profileLinks.bilibiliConfigured
  ? [
      {
        id: 'bilibili-profile',
        type: 'bilibili',
        title: profileLinks.bilibiliLabel,
        summary: profileLinks.bilibiliDescription,
        kicker: 'Bilibili',
        meta: '视频主页',
        href: profileLinks.bilibili,
        drawerId: 'bilibili:profile',
        tags: ['video'],
        accent: '#fb7299',
        size: 'compact'
      }
    ]
  : [];

const updateItems: FeedItem[] = [
  {
    id: 'update-evidence-library',
    type: 'update',
    title: '史料素材库已经成为独立板块',
    summary: '用于沉淀 OpenList、Remotion、Evidence Resolver 和素材标注的公开说明入口。',
    kicker: 'Update',
    meta: 'evidence-library',
    href: withBase('/evidence-library/'),
    drawerId: 'update:evidence-library',
    tags: ['evidence', 'remotion'],
    size: 'standard'
  }
];

const visualFeedItems: FeedItem[] = visualItems.map((item, index) => ({
  id: `visual:${item.id}`,
  type: 'visual',
  title: item.title,
  summary: item.summary,
  kicker: `Visual / ${item.type}`,
  meta: item.tags.slice(0, 2).join(' / '),
  href: withBase('/visuals/'),
  drawerId: `visual:${item.id}`,
  coverSrc: item.image,
  tags: item.tags,
  accent: item.palette.dominant,
  visualItem: item,
  size: index === 0 ? 'tall' : 'standard'
}));

const feedItems = [
  postItems[0],
  visualFeedItems[0],
  ...projectItems.slice(0, 1),
  ...noteItems.slice(0, 1),
  ...bookItems.slice(0, 2),
  githubChartItems[0],
  musicFeedItems[0],
  ...githubItems.slice(0, 2),
  ...postItems.slice(1, 5),
  githubChartItems[1],
  visualFeedItems[1],
  ...bilibiliItems,
  ...updateItems,
  githubChartItems[2],
  ...postItems.slice(5),
  ...projectItems.slice(1),
  ...noteItems.slice(1),
  ...githubItems.slice(2),
  ...visualFeedItems.slice(2),
  ...bookItems.slice(2),
  ...musicFeedItems.slice(1)
].filter(Boolean) as FeedItem[];

const bookDrawerEntries: DrawerEntry[] = books.map((book) => ({
  id: `book:${book.id}`,
  kind: 'book',
  title: book.title,
  kicker: `书架 / ${book.statusLabel}`,
  href: withBase(`/books/${book.id}/`),
  readHref: withBase(`/reader/${book.id}/`),
  summary: book.description ?? book.note,
  coverSrc: book.cover,
  tags: [book.category, book.statusLabel, book.sourceType.toUpperCase(), ...book.tags].slice(0, 6),
  details: [
    { label: '作者', value: book.author },
    { label: '分类', value: book.category },
    { label: '状态', value: book.statusLabel },
    { label: '来源', value: `${book.sourceType.toUpperCase()} / OpenList` },
    { label: '路径', value: book.openlistPath ?? '未配置' }
  ]
}));

const musicDrawerEntries: DrawerEntry[] = musicItems.map((item) => ({
  id: `music:${item.id}`,
  kind: 'music',
  title: item.title,
  kicker: `音乐 / ${item.platform}`,
  href: withBase('/music/'),
  summary: item.note,
  coverSrc: item.cover,
  tags: item.mood,
  details: [
    { label: 'Artist', value: item.artist },
    ...(item.album ? [{ label: 'Album', value: item.album }] : []),
    { label: 'Platform', value: item.platform }
  ]
}));

const githubDrawerEntries: DrawerEntry[] = [
  {
    id: 'github:heatmap',
    kind: 'github',
    title: 'GitHub 活动热力图',
    kicker: 'GitHub / Heatmap',
    href: withBase('/github/'),
    summary: `${githubAnalytics.totalContributions} 次年度活动，最近 12 周作为首页 mini 图表展示，完整年度热力图在 GitHub 仪表盘里展开。`,
    chartVariant: 'heatmap',
    tags: ['heatmap', 'activity'],
    details: [
      { label: '年度活动', value: String(githubAnalytics.totalContributions) },
      { label: '活跃日', value: String(githubAnalytics.activeDays) }
    ]
  },
  {
    id: 'github:line',
    kind: 'github',
    title: '月度贡献折线',
    kicker: 'GitHub / Line',
    href: withBase('/github/'),
    summary: '由 GitHub runtime API 聚合月度贡献趋势。首页保留摘要，完整图表进入 /github/。',
    chartVariant: 'line',
    tags: ['line', 'trend']
  },
  {
    id: 'github:language',
    kind: 'github',
    title: '语言占比',
    kicker: 'GitHub / Donut',
    href: withBase('/github/'),
    summary: githubAnalytics.topLanguage
      ? `${githubAnalytics.topLanguage.label} 当前占比 ${githubAnalytics.topLanguage.percent}%，完整语言分布在 /github/。`
      : '语言分布等待 GitHub snapshot 数据。',
    chartVariant: 'language',
    tags: ['donut', 'language']
  },
  ...github.repos.slice(0, 6).map((repo) => ({
    id: `github-repo:${repo.name}`,
    kind: 'github' as const,
    title: repo.name,
    kicker: 'GitHub / Repository',
    href: repo.htmlUrl,
    summary: repo.description || `${repo.language} repository`,
    tags: [repo.language],
    details: [
      { label: 'Stars', value: String(repo.stars) },
      { label: 'Issues', value: String(repo.issues) },
      { label: 'Updated', value: formatDate(new Date(repo.updatedAt)) }
    ]
  }))
];

const visualDrawerEntries: DrawerEntry[] = visualItems.map((item) => ({
  id: `visual:${item.id}`,
  kind: 'visual',
  title: item.title,
  kicker: `视觉素材 / ${item.type}`,
  href: withBase('/visuals/'),
  summary: item.summary,
  coverSrc: item.image,
  accent: item.palette.dominant,
  tags: item.tags,
  visualItem: item,
  details: [
    { label: '类型', value: item.type },
    { label: '来源', value: item.source ?? '未记录' },
    { label: '主色', value: item.palette.dominant },
    { label: '用途', value: '视觉素材 / 设计锚点 / Graph 节点' }
  ]
}));

const utilityDrawerEntries: DrawerEntry[] = [
  {
    id: 'knowledge:index',
    kind: 'knowledge',
    title: 'Knowledge Graph',
    kicker: 'Knowledge / Index',
    href: withBase('/knowledge/'),
    summary: '文章、项目、书架、音乐、GitHub 和本地标记共同进入知识图谱。首页入口默认打开这张摘要索引，完整关系图保留在 Knowledge 页面。',
    tags: ['graph', 'memory', 'reader'],
    details: [
      { label: '知识入口', value: String(articleDrawerEntries.length + bookDrawerEntries.length + musicDrawerEntries.length + githubDrawerEntries.length + 2 + bilibiliItems.length) },
      { label: '标签', value: String(new Set(posts.flatMap((post) => post.data.tags)).size) },
      { label: '交互', value: '抽屉预览 / 完整图谱' }
    ]
  },
  ...(profileLinks.bilibiliConfigured
    ? [
        {
          id: 'bilibili:profile',
          kind: 'bilibili' as const,
          title: profileLinks.bilibiliLabel,
          kicker: 'Bilibili',
          href: profileLinks.bilibili,
          summary: profileLinks.bilibiliDescription,
          accent: '#fb7299',
          tags: ['configured']
        }
      ]
    : []),
  {
    id: 'update:evidence-library',
    kind: 'update',
    title: '史料素材库已经成为独立板块',
    kicker: 'Update',
    href: withBase('/evidence-library/'),
    summary: '用于沉淀 OpenList、Remotion、Evidence Resolver 和素材标注的公开说明入口。',
    tags: ['evidence', 'remotion']
  }
];

const drawerEntries = [
  ...articleDrawerEntries,
  ...bookDrawerEntries,
  ...musicDrawerEntries,
  ...githubDrawerEntries,
  ...visualDrawerEntries,
  ...utilityDrawerEntries
];
const drawerById = new Map(drawerEntries.map((entry) => [entry.id, entry]));
const relationSources = drawerEntries.map((entry) => ({
  id: entry.id,
  kind: entry.kind,
  title: entry.title,
  summary: entry.summary,
  tags: entry.tags ?? [],
  series: entry.series,
  href: entry.href,
  body: entry.body
})) satisfies KnowledgeRelationSource[];
const knowledgeDocs = drawerEntries.map((entry) => ({
  id: entry.id,
  type: entry.kind,
  title: entry.title,
  content: [entry.summary, ...(entry.tags ?? []), ...(entry.details?.map((detail) => `${detail.label} ${detail.value}`) ?? [])].join('\n'),
  tags: entry.tags ?? [],
  href: entry.href,
  drawerId: entry.id
}));

function getRelatedEntries(entry: DrawerEntry) {
  const source = relationSources.find((item) => item.id === entry.id);
  if (!source) return [];
  return getRelatedKnowledgeEntries(source, relationSources, 3)
    .map(({ entry: item }) => drawerById.get(item.id))
    .filter(Boolean) as DrawerEntry[];
}

function feedCardClass(item: FeedItem) {
  return ['home-feed-card', `home-feed-card--${item.type}`, `home-feed-card--${item.size ?? 'standard'}`].join(' ');
}

function hoverPreviewAttrs(item: FeedItem) {
  return {
    'data-hover-preview': 'true',
    'data-hover-type': item.type,
    'data-hover-id': item.drawerId ?? item.id,
    'data-hover-title': item.title,
    'data-hover-summary': item.summary,
    'data-hover-kicker': item.kicker,
    'data-hover-meta': item.meta,
    'data-hover-image': item.coverSrc,
    'data-hover-accent': item.visualItem?.palette.dominant ?? item.accent,
    'data-hover-tags': JSON.stringify(item.tags ?? [])
  };
}

const latestPost = posts[0];
const latestProject = projects[0];
const latestRepo = github.repos[0];
const latestBook = books[0];
const latestMusic = musicItems[0];
const uniqueTagCount = new Set(posts.flatMap((post) => post.data.tags)).size;
const activityItems = [
  latestPost && `最新文章：${latestPost.data.title}`,
  latestProject && `项目工坊：${latestProject.data.title} / ${latestProject.data.progress}%`,
  latestRepo && `GitHub：${latestRepo.name} 更新于 ${formatDate(new Date(latestRepo.updatedAt))}`,
  latestBook && `书架：${latestBook.title}`,
  latestMusic && `音乐：${latestMusic.title}`,
  `Knowledge：${knowledgeDocs.length} 个入口 / ${uniqueTagCount} 个标签`
].filter(Boolean) as string[];
const homeCommands = [
  { id: 'search', label: '搜索全站', description: '文章、项目、书架、音乐、GitHub、本地标记', action: 'search', icon: 'search' },
  { id: 'posts', label: '文章', description: `${posts.length} 篇公开文章`, href: withBase('/posts/'), icon: 'posts' },
  { id: 'projects', label: '项目工坊', description: latestProject ? `${latestProject.data.title} / ${latestProject.data.progress}%` : '项目空间', href: withBase('/projects/'), icon: 'projects' },
  { id: 'project-workbench', label: '项目工作台', description: 'GitHub Workbench / Wiki / Timeline', href: withBase('/projects/site-v2/'), icon: 'projects' },
  { id: 'github', label: 'GitHub', description: `${github.profile.publicRepos} 个公开仓库`, href: withBase('/github/'), icon: 'github' },
  { id: 'books', label: '书架', description: `${books.length} 条阅读记录`, href: withBase('/books/'), icon: 'books' },
  { id: 'music', label: '音乐', description: `${musicItems.length} 条音乐记录`, href: withBase('/music/'), icon: 'music' },
  { id: 'knowledge', label: 'Knowledge Graph', description: `${knowledgeDocs.length} 个知识入口`, href: withBase('/knowledge/'), icon: 'knowledge' },
  { id: 'openlist', label: 'OpenList', description: '嵌入查看当前文件源', action: 'openlist', icon: 'external' },
  { id: 'settings', label: '设置', description: '阅读排版、Graph、视觉偏好', href: withBase('/settings/'), icon: 'settings' }
];
---

<BaseLayout title="emptyinkpot" description="emptyinkpot 的首页，聚合文章、书架、项目、GitHub 与视频入口。" hideSiteChrome={true}>
  <div class="home-feed-shell" data-github-live-root data-github-username="emptyinkpot">
    <aside class="home-feed-rail" aria-label="系统导航与上下文状态" data-home-sidebar>
      <button class="home-sidebar-collapse" type="button" data-sidebar-collapse aria-label="折叠右侧栏" aria-expanded="true">
        <span data-sidebar-collapse-icon>›</span>
      </button>

      <section class="home-feed-profile home-sidebar-section">
        <a class="home-feed-brand" href={withBase('/')}>
          <img src={withBase('/images/branding/vita-atramenti-logo.png')} alt="emptyinkpot" data-image-key="home.brand.logo" />
          <span data-sidebar-label data-copy-key="home.brand.name">emptyinkpot</span>
        </a>
        <img class="home-feed-avatar" src={github.profile.avatarUrl} alt={github.profile.name} data-image-key="home.profile.avatar" data-github-profile="avatar" />
        <h1 data-sidebar-label data-github-profile="name">{github.profile.name}</h1>
        <p data-sidebar-label data-copy-key="home.profile.tagline">Content OS · Knowledge System</p>
        <small class="github-live-status" data-sidebar-label data-github-live-status data-github-live-state="loading">GitHub 快照待同步</small>
      </section>

      <nav class="home-feed-rail-card home-sidebar-section home-sidebar-nav" aria-label="站点导航">
        <span data-sidebar-label data-copy-key="home.sidebar.nav">Navigation</span>
        <a class="home-sidebar-item" href={withBase('/projects/')} aria-label="项目工坊"><b>项</b><span data-sidebar-label>项目工坊</span></a>
        <a class="home-sidebar-item" href={withBase('/knowledge/')} aria-label="知识图谱"><b>知</b><span data-sidebar-label>知识图谱</span></a>
        <a class="home-sidebar-item" href={withBase('/books/')} aria-label="书架"><b>书</b><span data-sidebar-label>书架</span></a>
        <a class="home-sidebar-item" href={withBase('/visuals/')} aria-label="视觉素材"><b>视</b><span data-sidebar-label>视觉素材</span></a>
        <a class="home-sidebar-item" href={withBase('/github/')} aria-label="GitHub"><b>G</b><span data-sidebar-label>GitHub</span></a>
        <a class="home-sidebar-item" href={withBase('/settings/')} aria-label="设置"><b>设</b><span data-sidebar-label>设置</span></a>
      </nav>

      <section class="home-feed-rail-card home-feed-memory home-sidebar-section">
