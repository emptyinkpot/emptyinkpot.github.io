---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { architectureCodexEntries, architectureCodexGlossary, getCodexHref } from '../../data/architectureCodex';
import { withBase } from '../../lib/site';

const activeEntries = architectureCodexEntries.filter((entry) => entry.status === 'active').length;
---

<BaseLayout title="Architecture Codex / emptyinkpot" description="emptyinkpot 的系统设计档案，记录阅读器、知识运行时、视觉系统和数据架构的设计理由。">
  <main class="codex-page" data-pagefind-body>
    <section class="codex-hero">
      <p class="section-kicker">Architecture Codex</p>
      <h1>这里记录系统为什么长成现在这样。</h1>
      <p>
        Codex 不是普通博客，也不是教程。它保存 Reader、OpenList、MySQL、Graph、视觉语言和书架策展的设计考古，供未来的自己、协作者和 AI 维护者读取。
      </p>
      <dl>
        <div>
          <dt>Systems</dt>
          <dd>{architectureCodexEntries.length}</dd>
        </div>
        <div>
          <dt>Active</dt>
          <dd>{activeEntries}</dd>
        </div>
        <div>
          <dt>Glossary</dt>
          <dd>{architectureCodexGlossary.length}</dd>
        </div>
      </dl>
    </section>

    <section class="codex-index" aria-label="Architecture Codex entries">
      {
        architectureCodexEntries.map((entry) => (
          <a class="codex-entry-card" href={getCodexHref(entry.slug)}>
            <span>{entry.status}</span>
            <h2>{entry.title}</h2>
            <p>{entry.subtitle}</p>
            <small>{entry.systems.slice(0, 4).join(' / ')}</small>
          </a>
        ))
      }
    </section>

    <section class="codex-glossary" aria-label="Codex glossary">
      <div>
        <p class="section-kicker">Glossary</p>
        <h2>项目自己的词汇系统</h2>
      </div>
      <dl>
        {
          architectureCodexGlossary.map((item) => (
            <div>
              <dt>{item.term}</dt>
              <dd>{item.definition}</dd>
            </div>
          ))
        }
      </dl>
    </section>

    <section class="codex-protocol" aria-label="Codex protocol">
      <p class="section-kicker">Maintenance Protocol</p>
      <h2>以后新增大系统，先写档案，再写界面。</h2>
      <p>
        每个新系统必须回答 Inspiration、Rejected、Runtime、Tradeoff、Future Direction 和 Related Systems。没有这些记录的功能，只能算临时 UI，不算 MyBlog 的长期架构。
      </p>
      <a href={withBase('/knowledge/')}>查看 Knowledge Graph</a>
    </section>
  </main>
</BaseLayout>
