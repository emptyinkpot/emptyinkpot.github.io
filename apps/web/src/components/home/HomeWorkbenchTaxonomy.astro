---
import HomeWorkbenchSectionLine from './HomeWorkbenchSectionLine.astro';

interface ItemCard {
  kicker: string;
  title: string;
  meta: string;
  href: string;
}

interface Props {
  topics: ItemCard[];
  series: ItemCard[];
}

const { topics, series } = Astro.props as Props;
---

<section class="home-workbench__double">
  <article class="home-workbench__card home-workbench__card--panel">
    <HomeWorkbenchSectionLine leading="SECTION / TOPICS" trailing="主题入口" tight={true} />
    <div class="home-workbench__mini-grid">
      {topics.map((item) => (
        <a href={item.href} class="home-workbench__mini-card">
          <span>{item.kicker}</span>
          <strong>{item.title}</strong>
          <small>{item.meta}</small>
        </a>
      ))}
    </div>
  </article>

  <article class="home-workbench__card home-workbench__card--panel">
    <HomeWorkbenchSectionLine leading="SECTION / SERIES" trailing="连续阅读" tight={true} />
    <div class="home-workbench__mini-grid">
      {series.map((item) => (
        <a href={item.href} class="home-workbench__mini-card">
          <span>{item.kicker}</span>
          <strong>{item.title}</strong>
          <small>{item.meta}</small>
        </a>
      ))}
    </div>
  </article>
</section>
