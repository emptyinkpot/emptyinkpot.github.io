---
import type { HomePlannedCard } from '../../lib/home';
import HomeWorkbenchSectionLine from './HomeWorkbenchSectionLine.astro';
import HomeWorkbenchDeck from './HomeWorkbenchDeck.astro';

interface Props {
  cards: HomePlannedCard[];
}

const { cards } = Astro.props as Props;
const deckItems = cards.map((card, index) => ({ ...card, summary: card.summary, variant: index === 2 ? 'accent' : 'default' as const }));
---

<section class="home-workbench__planned">
  <HomeWorkbenchSectionLine leading="SECTION / PLANNED EXPANSION" trailing="为后续归档、阅读路径与实验区预留位置" />
  <HomeWorkbenchDeck items={deckItems} columns={3} />
</section>
