---
import type { CollectionEntry } from 'astro:content';
import type { HomeCheckInData, HomeHeroData, HomeSnapshotData } from '../../lib/home';
import HomeWorkbenchSectionLine from './HomeWorkbenchSectionLine.astro';

interface Props {
  hero: HomeHeroData;
  snapshot: HomeSnapshotData;
  checkIn: HomeCheckInData;
  featuredPost?: CollectionEntry<'posts'>;
}

const { hero, snapshot, checkIn, featuredPost } = Astro.props as Props;
---

<section class="home-workbench__hero">
  <article class="home-workbench__hero-main home-workbench__card home-workbench__card--panel">
    <HomeWorkbenchSectionLine leading={hero.kicker} trailing="唯一入口 / 编辑部首页" tight={true} />

    <h1>{hero.title}</h1>
    <p class="home-workbench__hero-summary">{hero.summary}</p>

    <div class="home-workbench__hero-actions">
      {hero.actions.map((action) => <a href={action.href}>{action.label}</a>)}
    </div>

    <div class="home-workbench__hero-tags">
      {hero.tags.map((tag) => <span>{tag}</span>)}
    </div>

    <div class="home-workbench__heatmap">
      <div class="home-workbench__heatmap-head">
        <strong>{checkIn.title}</strong>
        <span>{checkIn.statLine}</span>
      </div>
      <div class="home-workbench__months">
        {checkIn.months.map((month) => <span>{month}</span>)}
      </div>
      <div class="home-workbench__weeks">
        {
          checkIn.weeks.map((week) => (
            <div class="home-workbench__week">
              {week.days.map((day) => <span class:list={['home-workbench__cell', `home-workbench__cell--${day.level}`]}></span>)}
            </div>
          ))
        }
      </div>
      <div class="home-workbench__legend">{checkIn.legend}</div>
    </div>
  </article>

  <aside class="home-workbench__hero-side">
    <article class="home-workbench__snapshot">
      <HomeWorkbenchSectionLine leading="EDITORIAL SNAPSHOT" trailing="当前站点信号" tone="snap" />
      <h2>{snapshot.kicker}</h2>
      <div class="home-workbench__snapshot-metrics">
        {snapshot.metrics.map((metric) => (
          <div>
            <strong>{metric.value}</strong>
            <span>{metric.label}</span>
          </div>
        ))}
      </div>
      <ul>
        {snapshot.lines.map((line) => <li>{line}</li>)}
      </ul>
    </article>

    {
      featuredPost && (
        <article class="home-workbench__card home-workbench__card--accent home-workbench__hero-feature">
          <HomeWorkbenchSectionLine leading="FEATURED STORY" trailing="主推文章入口" tone="snap" />
          <strong class="home-workbench__blocktitle">{featuredPost.data.title}</strong>
          <p class="home-workbench__blockmeta home-workbench__blockmeta--light">
            {featuredPost.data.summary ?? featuredPost.data.description ?? '主推文章入口'}
          </p>
        </article>
      )
    }
  </aside>
</section>
