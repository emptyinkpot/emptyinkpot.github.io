---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '../shared/ArticleCard.astro';
import { withBase } from '../../lib/site';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props as Props;
---

<section class="space-y-5">
  <div class="home-editorial-sectionhead">
    <div>
      <p class="section-kicker">Latest Posts</p>
      <h2 class="home-editorial-sectiontitle">博客内容</h2>
    </div>
    <a class="home-editorial-link" href={withBase('/posts')}>
      查看全部文章
    </a>
  </div>

  <div class="grid gap-3 md:grid-cols-2">
    {posts.map((post) => <ArticleCard post={post} />)}
  </div>
</section>
