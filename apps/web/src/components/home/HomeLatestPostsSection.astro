---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '../shared/ArticleCard.astro';
import { withBase } from '../../lib/site';

interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props as Props;
---

<section class="space-y-5">
  <div class="section-heading">
    <div>
      <p class="section-kicker">Latest Posts</p>
      <h2 class="section-title">最新文章以卡片网格呈现，而不是直接铺全文。</h2>
    </div>
    <a class="text-sm text-stone-600 transition hover:text-stone-950" href={withBase('/posts')}>
      查看全部文章
    </a>
  </div>

  <div class="grid gap-5 md:grid-cols-2">
    {posts.map((post) => <ArticleCard post={post} />)}
  </div>
</section>
