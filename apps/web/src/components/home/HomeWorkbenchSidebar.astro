---
import { withBase } from '../../lib/site';
import HomeWorkbenchPanel from './HomeWorkbenchPanel.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  items: NavItem[];
}

const { items } = Astro.props as Props;
---

<aside class="home-side-rail">
  <div class="home-side-rail__inner">
    <HomeWorkbenchPanel leading="IDENTITY / BRAND" trailing="侧边导航" panel={true} className="home-side-rail__panel home-side-rail__profile-panel">
      <div class="home-side-rail__profile">
        <div class="home-side-rail__avatar-shell">
          <img src={withBase('/images/branding/vita-atramenti-logo.png')} alt="Vita Atramenti" class="home-side-rail__avatar" />
        </div>
        <p class="home-side-rail__name">emptyinkpot</p>
        <p class="home-side-rail__desc">Structured writing / projects / maintenance notes</p>
      </div>
    </HomeWorkbenchPanel>

    <HomeWorkbenchPanel leading="SECTION / NAVIGATION" trailing="站内主入口" panel={true} className="home-side-rail__panel">
      <nav class="home-side-rail__nav" aria-label="Homepage quick navigation">
        {
          items.map((item, index) => (
            <a href={item.href} class:list={['home-side-rail__link', index === 0 && 'home-side-rail__link--active']}>
              <span class="home-side-rail__link-index">{String(index + 1).padStart(2, '0')}</span>
              <span>{item.label}</span>
            </a>
          ))
        }
      </nav>
    </HomeWorkbenchPanel>
  </div>
</aside>
