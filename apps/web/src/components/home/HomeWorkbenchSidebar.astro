---
import { withBase } from '../../lib/site';
import HomeWorkbenchPanel from './HomeWorkbenchPanel.astro';

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  items: NavItem[];
}

const { items } = Astro.props as Props;
---

<aside class="home-side-rail">
  <div class="home-side-rail__inner">
    <HomeWorkbenchPanel leading="IDENTITY / BRAND / 品牌识别" trailing="侧边导航" panel={true} className="home-side-rail__panel home-side-rail__profile-panel">
      <div class="home-side-rail__profile">
        <div class="home-side-rail__brandbar">
          <img src={withBase('/images/branding/vita-atramenti-logo.png')} alt="Vita Atramenti logo" class="home-side-rail__brandlogo" />
          <span>天国网络科技株式会社</span>
        </div>
        <div class="home-side-rail__avatar-shell">
          <span class="home-side-rail__avatar-orb" aria-hidden="true"></span>
        </div>
        <p class="home-side-rail__name">emptyinkpot</p>
        <p class="home-side-rail__desc">结构化写作 / 项目索引 / 维护记录</p>

        <nav class="home-side-rail__nav" aria-label="Homepage quick navigation">
          {
            items.map((item, index) => (
              <a href={item.href} class:list={['home-side-rail__link', index === 0 && 'home-side-rail__link--active']}>
                <span>{item.label}</span>
              </a>
            ))
          }
        </nav>
      </div>
    </HomeWorkbenchPanel>
  </div>
</aside>
