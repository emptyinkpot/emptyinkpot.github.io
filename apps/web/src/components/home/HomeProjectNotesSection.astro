---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../../lib/content';
import { withBase } from '../../lib/site';

interface Props {
  activeProject?: CollectionEntry<'projects'>;
  latestNotes: CollectionEntry<'notes'>[];
}

const { activeProject, latestNotes } = Astro.props as Props;
---

<section class="grid gap-5 lg:grid-cols-[1.1fr_0.9fr]">
  {
    activeProject && (
      <section class="home-section-card md:p-7">
        <div class="home-editorial-sectionhead">
          <div>
            <p class="section-kicker">Project Snapshot</p>
            <h2 class="home-editorial-sectiontitle home-editorial-sectiontitle--compact">让博客逐步具备项目展示的第二条内容线。</h2>
          </div>
          <a class="pill" href={withBase(`/projects/${activeProject.id}/`)}>
            {activeProject.data.status}
          </a>
        </div>

        <div class="mt-6 grid gap-6 lg:grid-cols-[1.2fr_0.8fr] lg:items-start">
          <div class="space-y-4">
            <h3 class="text-2xl font-semibold text-stone-950">{activeProject.data.title}</h3>
            <p class="max-w-3xl text-base leading-8 text-stone-600">{activeProject.data.description}</p>
            <a class="text-sm text-stone-600 transition hover:text-stone-950" href={withBase('/projects')}>
              查看全部项目
            </a>
          </div>

          <div class="flex flex-wrap gap-3">
            {activeProject.data.stack.map((item) => <span class="pill">{item}</span>)}
          </div>
        </div>
      </section>
    )
  }

  <section class="home-notes-panel rounded-[0.2rem] p-6">
    <div class="home-editorial-sectionhead">
      <div>
        <p class="section-kicker mb-4 text-[color:var(--home-accent-strong)]">Notes</p>
        <h2 class="home-editorial-sectiontitle home-editorial-sectiontitle--compact">用轻量笔记承接阶段反馈与碎片沉淀。</h2>
      </div>
      <a class="home-editorial-link text-[color:var(--home-accent)]" href={withBase('/notes')}>
        查看 notes
      </a>
    </div>

    <div class="mt-6 space-y-3">
      {
        latestNotes.length ? (
          latestNotes.map((note) => (
            <a class="home-list-card block bg-white" href={withBase(`/notes/${note.id}/`)}>
              <p class="section-kicker mb-2">{formatDate(note.data.date)}</p>
              <h3 class="text-lg font-medium text-stone-950">{note.data.title}</h3>
              {note.data.description && <p class="mt-2 text-sm leading-7 text-stone-600">{note.data.description}</p>}
            </a>
          ))
        ) : (
          <div class="rounded-[1.25rem] border border-dashed border-[color:var(--home-line)] bg-white p-4 text-sm leading-7 text-stone-500">
            当前公开 notes 还在整理中，后续会把设计取舍、迁移记录和阶段日志持续放进来。
          </div>
        )
      }
    </div>
  </section>
</section>
