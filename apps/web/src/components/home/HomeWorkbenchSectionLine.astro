---
interface Props {
  leading: string;
  trailing: string;
  tone?: 'default' | 'snap';
  tight?: boolean;
}

const { leading, trailing, tone = 'default', tight = false } = Astro.props as Props;
---

<div class:list={['home-workbench__sectionline', tight && 'home-workbench__sectionline--tight', tone === 'snap' && 'home-workbench__sectionline--snap']}>
  <span>{trailing}</span>
  <div aria-hidden="true"></div>
  <span>{leading}</span>
</div>
