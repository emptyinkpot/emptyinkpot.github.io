<script is:inline>
  (() => {
    const setupPanelWheel = (selector) => {
      const panel = document.querySelector(selector);
      if (!panel) return;

      panel.addEventListener(
        'wheel',
        (event) => {
          if (window.innerWidth <= 900) return;
          if (Math.abs(event.deltaY) < Math.abs(event.deltaX)) return;
          if (panel.scrollHeight <= panel.clientHeight) return;

          const nextTop = panel.scrollTop + event.deltaY;
          const maxTop = panel.scrollHeight - panel.clientHeight;
          const clampedTop = Math.max(0, Math.min(nextTop, maxTop));

          if (clampedTop === panel.scrollTop) return;

          event.preventDefault();
          panel.scrollTop = clampedTop;
        },
        { passive: false }
      );
    };

    const setupTeamSwitcher = () => {
      const switchers = document.querySelectorAll('[data-team-switcher]');
      const panelGroups = document.querySelectorAll('[data-team-panel]');

      const activate = (teamId) => {
        switchers.forEach((switcher) => {
          switcher.querySelectorAll('[data-team-trigger]').forEach((button) => {
            const isActive = button.getAttribute('data-team-trigger') === teamId;
            button.classList.toggle('is-active', isActive);
            button.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });
        });

        panelGroups.forEach((panel) => {
          panel.classList.toggle('is-active', panel.getAttribute('data-team-panel') === teamId);
        });
      };

      switchers.forEach((switcher) => {
        switcher.querySelectorAll('[data-team-trigger]').forEach((button) => {
          button.addEventListener('click', () => activate(button.getAttribute('data-team-trigger')));
        });
      });
    };

    const setupLatestPostPreview = () => {
      const groups = document.querySelectorAll('[data-latest-preview]');

      groups.forEach((group) => {
        const triggers = group.querySelectorAll('[data-post-trigger]');
        const panels = group.querySelectorAll('[data-post-panel]');

        if (!triggers.length || !panels.length) return;

        const activate = (postId) => {
          if (!postId) return;

          triggers.forEach((trigger) => {
            const isActive = trigger.getAttribute('data-post-trigger') === postId;
            trigger.classList.toggle('is-active', isActive);
            trigger.setAttribute('aria-selected', isActive ? 'true' : 'false');
            trigger.setAttribute('tabindex', isActive ? '0' : '-1');
          });

          panels.forEach((panel) => {
            const isActive = panel.getAttribute('data-post-panel') === postId;
            panel.classList.toggle('is-active', isActive);
            panel.setAttribute('aria-hidden', isActive ? 'false' : 'true');
          });
        };

        const orderedTriggers = Array.from(triggers);

        triggers.forEach((trigger) => {
          const postId = trigger.getAttribute('data-post-trigger');

          trigger.addEventListener('click', () => activate(postId));
          trigger.addEventListener('mouseenter', () => activate(postId));
          trigger.addEventListener('focus', () => activate(postId));
          trigger.addEventListener('keydown', (event) => {
            const currentIndex = Number(trigger.getAttribute('data-post-index') ?? '0');
            const nextIndex =
              event.key === 'ArrowDown'
                ? Math.min(currentIndex + 1, orderedTriggers.length - 1)
                : event.key === 'ArrowUp'
                  ? Math.max(currentIndex - 1, 0)
                  : currentIndex;

            if (nextIndex === currentIndex) return;

            event.preventDefault();
            const nextTrigger = orderedTriggers[nextIndex];
            nextTrigger.focus();
            activate(nextTrigger.getAttribute('data-post-trigger'));
          });
        });

        activate(orderedTriggers[0]?.getAttribute('data-post-trigger'));
      });
    };

    const mount = () => {
      setupPanelWheel('.home-editorial-page');
      setupPanelWheel('.home-side-rail__inner');
      setupTeamSwitcher();
      setupLatestPostPreview();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount, { once: true });
    } else {
      mount();
    }
  })();
</script>
