<script is:inline>
  (() => {
    const setupPanelWheel = (selector) => {
      const panel = document.querySelector(selector);
      if (!panel) return;

      panel.addEventListener(
        'wheel',
        (event) => {
          if (window.innerWidth <= 900) return;
          if (Math.abs(event.deltaY) < Math.abs(event.deltaX)) return;
          if (panel.scrollHeight <= panel.clientHeight) return;

          const nextTop = panel.scrollTop + event.deltaY;
          const maxTop = panel.scrollHeight - panel.clientHeight;
          const clampedTop = Math.max(0, Math.min(nextTop, maxTop));

          if (clampedTop === panel.scrollTop) return;

          event.preventDefault();
          panel.scrollTop = clampedTop;
        },
        { passive: false }
      );
    };

    const setupTeamSwitcher = () => {
      const switchers = document.querySelectorAll('[data-team-switcher]');
      const panelGroups = document.querySelectorAll('[data-team-panel]');

      const activate = (teamId) => {
        switchers.forEach((switcher) => {
          switcher.querySelectorAll('[data-team-trigger]').forEach((button) => {
            const isActive = button.getAttribute('data-team-trigger') === teamId;
            button.classList.toggle('is-active', isActive);
            button.setAttribute('aria-selected', isActive ? 'true' : 'false');
          });
        });

        panelGroups.forEach((panel) => {
          panel.classList.toggle('is-active', panel.getAttribute('data-team-panel') === teamId);
        });
      };

      switchers.forEach((switcher) => {
        switcher.querySelectorAll('[data-team-trigger]').forEach((button) => {
          button.addEventListener('click', () => activate(button.getAttribute('data-team-trigger')));
        });
      });
    };

    const mount = () => {
      setupPanelWheel('.home-editorial-page');
      setupPanelWheel('.home-side-rail__inner');
      setupTeamSwitcher();
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', mount, { once: true });
    } else {
      mount();
    }
  })();
</script>
