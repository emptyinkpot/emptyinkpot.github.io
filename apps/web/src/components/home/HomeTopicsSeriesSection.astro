---
import type { HomeTaxonomyItem } from '../../lib/home';
import { withBase } from '../../lib/site';

interface Props {
  topics: HomeTaxonomyItem[];
  series: HomeTaxonomyItem[];
}

const { topics, series } = Astro.props as Props;
---

<section class="grid gap-5 lg:grid-cols-[1.05fr_0.95fr]">
  <div class="home-section-card">
    <div class="home-editorial-sectionhead">
      <div>
        <p class="section-kicker mb-4">Topics</p>
        <h2 class="home-editorial-sectiontitle home-editorial-sectiontitle--narrow">内容入口不是归档页，而是可导航的主题结构。</h2>
      </div>
      <a class="home-editorial-link" href={withBase('/categories')}>
        全部分区
      </a>
    </div>

    <div class="space-y-3">
      {
        topics.map((topic) => (
          <a class="home-list-card block" href={topic.href}>
            <p class="section-kicker mb-2">Topic</p>
            <h3 class="text-lg font-medium text-stone-950">{topic.label}</h3>
            <p class="mt-2 text-sm text-[color:var(--home-accent)]">{topic.count} 篇文章</p>
          </a>
        ))
      }
    </div>
  </div>

  <div class="home-section-card">
    <div class="home-editorial-sectionhead">
      <div>
        <p class="section-kicker mb-4">Series</p>
        <h2 class="home-editorial-sectiontitle home-editorial-sectiontitle--narrow">系列承担连续阅读，把零散文章串成专题。</h2>
      </div>
      <a class="home-editorial-link" href={withBase('/series')}>
        查看系列
      </a>
    </div>

    <div class="space-y-3">
      {
        series.length ? (
          series.map((item) => (
            <a class="home-list-card flex items-center justify-between gap-4" href={item.href}>
              <div>
                <p class="section-kicker mb-2">Series</p>
                <h3 class="text-lg font-medium text-stone-950">{item.label}</h3>
              </div>
              <span class="pill">{item.count} 篇</span>
            </a>
          ))
        ) : (
          <p class="text-sm leading-7 text-stone-500">当前还没有公开系列，后续会随着内容迁移逐步补齐。</p>
        )
      }
    </div>
  </div>
</section>
