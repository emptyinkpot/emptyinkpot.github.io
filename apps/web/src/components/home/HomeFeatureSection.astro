---
import type { CollectionEntry } from 'astro:content';
import FeaturedCard from '../shared/FeaturedCard.astro';

interface Props {
  featuredPost?: CollectionEntry<'posts'>;
}

const { featuredPost } = Astro.props as Props;
---

{
  featuredPost && (
    <section class="space-y-5">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Feature Story</p>
          <h2 class="section-title">先让首页具备“主推内容”的重心。</h2>
        </div>
      </div>
      <FeaturedCard post={featuredPost} />
    </section>
  )
}
