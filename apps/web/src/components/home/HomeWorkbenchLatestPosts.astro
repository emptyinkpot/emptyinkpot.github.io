---
import HomeWorkbenchSectionLine from './HomeWorkbenchSectionLine.astro';
import { withBase } from '../../lib/site';

interface LatestPostCard {
  id: string;
  href: string;
  title: string;
  date: string;
  category: string;
  categoryHref: string;
  summary: string;
  preview: string;
  tags: { label: string; href: string }[];
  coverSrc?: string;
}

interface Props {
  posts: LatestPostCard[];
}

const { posts } = Astro.props as Props;
---

<section class="home-workbench__feed">
  <HomeWorkbenchSectionLine leading="LATEST POSTS / 最新文章" trailing="严格两栏基线结构" />

  <div class="home-workbench__feedcard home-workbench__card home-workbench__card--panel">
    <header>
      <div class="home-workbench__feedhead">
        <strong>最新文章 / 博客内容</strong>
        <small>悬停、点击或键盘上下键都能切换；右侧会放大显示摘要、标签和正文入口</small>
      </div>
      <a href={withBase('/posts')}>进入文章</a>
    </header>

    <div class="home-workbench__feedsplit" data-latest-preview>
      <div class="home-workbench__postlist" role="tablist" aria-label="首页最新文章预览列表">
        {
          posts.map((post, index) => (
            <button
              type="button"
              class:list={['home-workbench__postitem', index === 0 && 'is-active']}
              data-post-trigger={post.id}
              data-post-index={index}
              id={`latest-post-tab-${post.id}`}
              role="tab"
              aria-selected={index === 0 ? 'true' : 'false'}
              aria-controls={`latest-post-panel-${post.id}`}
              tabindex={index === 0 ? '0' : '-1'}
            >
              <div class="home-workbench__postcover">
                {post.coverSrc ? (
                  <img src={post.coverSrc} alt={post.title} loading="lazy" />
                ) : (
                  <>
                    <i></i>
                    <span>文章封面</span>
                    <small>{post.category}</small>
                  </>
                )}
              </div>
              <div class="home-workbench__postbody">
                <div class="home-workbench__postrow">
                  <div class="home-workbench__postmeta">
                    <span>{post.date}</span>
                    <span>{post.category}</span>
                  </div>
                  <span class="home-workbench__postcue" aria-hidden="true">切换预览</span>
                </div>
                <strong>{post.title}</strong>
                <p>{post.summary}</p>
              </div>
            </button>
          ))
        }
      </div>

      <aside class="home-workbench__postpreview" aria-live="polite">
        {
          posts.map((post, index) => (
            <article
              class:list={['home-workbench__postpreview-panel', index === 0 && 'is-active']}
              data-post-panel={post.id}
              id={`latest-post-panel-${post.id}`}
              role="tabpanel"
              aria-labelledby={`latest-post-tab-${post.id}`}
              aria-hidden={index === 0 ? 'false' : 'true'}
            >
              <div class="home-workbench__postpreview-meta">
                <span>{post.date}</span>
                <a href={post.categoryHref}>{post.category}</a>
              </div>

              <a class="home-workbench__postpreview-cover" href={post.href}>
                {post.coverSrc ? (
                  <img src={post.coverSrc} alt={post.title} loading="lazy" />
                ) : (
                  <>
                    <i></i>
                    <span>内容预览</span>
                    <small>{post.category}</small>
                  </>
                )}
              </a>

              <div class="home-workbench__postpreview-copy">
                <strong><a href={post.href}>{post.title}</a></strong>
                <p>{post.preview}</p>
              </div>

              <div class="home-workbench__postpreview-tags">
                {post.tags.length > 0 ? (
                  post.tags.map((tag) => <a href={tag.href}>{tag.label}</a>)
                ) : (
                  <a href={post.categoryHref}>{post.category}</a>
                )}
              </div>

              <div class="home-workbench__postpreview-actions">
                <a href={post.href}>阅读全文</a>
              </div>
            </article>
          ))
        }
      </aside>
    </div>
  </div>
</section>
