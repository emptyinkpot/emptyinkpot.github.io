---
import type { HomeHeroData, HomeSnapshotData } from '../../lib/home';
import { withBase } from '../../lib/site';

interface Props {
  hero: HomeHeroData;
  snapshot: HomeSnapshotData;
}

const { hero, snapshot } = Astro.props as Props;
---

<section class="home-poster-hero space-y-4">
  <div class="home-poster-topbar">
    <a class="home-poster-brand" href={withBase('/')}>
      <img src={withBase('/images/branding/vita-atramenti-logo.png')} alt="Vita Atramenti logo" class="home-poster-brand__logo" />
      <div>
        <p class="home-poster-brand__title">emptyinkpot</p>
        <p class="home-poster-brand__subtitle">structured writing / projects / maintenance notes</p>
      </div>
    </a>
    <div class="home-poster-issue">ISSUE 01&nbsp;&nbsp;首页改版与内容聚合设计</div>
  </div>

  <div class="grid gap-4 lg:grid-cols-[1.55fr_0.8fr]">
    <div class="home-poster-hero__panel">
      <p class="section-kicker text-[color:var(--home-accent)]">{hero.kicker}</p>
      <div class="space-y-4">
        <h1 class="home-poster-hero__title">{hero.title}</h1>
        <p class="max-w-3xl text-sm leading-7 text-stone-600 md:text-base">{hero.summary}</p>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        {
          hero.actions.map((action) => (
            <a
              class:list={[
                'home-poster-action',
                action.variant === 'primary' ? 'home-poster-action--primary' : 'home-poster-action--secondary'
              ]}
              href={action.href}
            >
              {action.label}
            </a>
          ))
        }
      </div>

      <div class="mt-4 flex flex-wrap gap-2">
        {hero.tags.map((tag) => <span class="home-poster-tag">{tag}</span>)}
      </div>

      <div class="home-poster-leadline">
        <h2 class="home-poster-leadline__title">先让首页具备主推内容的重心。</h2>
      </div>
    </div>

    <div class="home-snapshot-panel">
      <p class="section-kicker mb-4 text-white/80">{snapshot.kicker}</p>
      <div class="grid grid-cols-2 gap-3">
        {
          snapshot.metrics.map((metric) => (
            <div class="home-snapshot-metric">
              <p class="text-3xl font-semibold text-stone-950">{metric.value}</p>
              <p class="mt-2 text-[11px] text-stone-500">{metric.label}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-5 space-y-2 text-[12px] leading-6 text-white/88">
        {snapshot.lines.map((line, index) => <p>{index + 1}. {line}</p>)}
      </div>
    </div>
  </div>
</section>
