---
import type { CollectionEntry } from 'astro:content';
import HomeWorkbenchSectionLine from './HomeWorkbenchSectionLine.astro';
import { withBase } from '../../lib/site';

interface Props {
  activeProject?: CollectionEntry<'projects'>;
  latestNote?: CollectionEntry<'notes'>;
}

const { activeProject, latestNote } = Astro.props as Props;
const activeProjectHref = activeProject ? withBase(`/projects/${activeProject.id}/`) : withBase('/projects');
const latestNoteHref = latestNote ? withBase(`/notes/${latestNote.id}/`) : withBase('/notes');
---

<section class="home-workbench__double home-workbench__double--project">
  <a class="home-workbench__card home-workbench__card--panel home-workbench__projectlink" href={activeProjectHref}>
    <HomeWorkbenchSectionLine leading="PROJECT / 项目主线" trailing="项目主线" tight={true} />
    <div class="home-workbench__projectblock">
      <strong>{activeProject?.data.title ?? '项目占位'}</strong>
      <p>{activeProject?.data.description ?? '当前项目摘要'}</p>
      <div class="home-workbench__badges">
        {(activeProject?.data.stack ?? []).slice(0, 4).map((stack) => <span>{stack}</span>)}
      </div>
    </div>
  </a>

  <a class="home-workbench__card home-workbench__card--accent home-workbench__projectlink" href={latestNoteHref}>
    <HomeWorkbenchSectionLine leading="NOTES / 阶段笔记" trailing="阶段笔记" tone="snap" />
    <div class="home-workbench__projectblock">
      <strong>{latestNote?.data.title ?? 'notes 正在整理中'}</strong>
      <p>{latestNote?.data.description ?? '后续会持续放入设计取舍、迁移记录与阶段日志。'}</p>
    </div>
  </a>
</section>
