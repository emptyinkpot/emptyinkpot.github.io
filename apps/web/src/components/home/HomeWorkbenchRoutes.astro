---
import type { HomeRouteCard } from '../../lib/home';
import HomeWorkbenchSectionLine from './HomeWorkbenchSectionLine.astro';

interface Props {
  topCards: HomeRouteCard[];
  bottomCards: HomeRouteCard[];
}

const { topCards, bottomCards } = Astro.props as Props;
---

<section class="home-workbench__routes">
  <HomeWorkbenchSectionLine leading="SECTION / SITE ROUTES" trailing="关于、搜索、更新与工具入口分层落位" />

  <div class="home-workbench__triple">
    {topCards.map((card) => (
      <a href={card.href} class:list={['home-workbench__route-card', card.variant === 'accent' && 'is-accent']}>
        <span>{card.kicker}</span>
        <strong>{card.title}</strong>
        <small>{card.summary}</small>
      </a>
    ))}
  </div>

  <div class="home-workbench__double">
    {bottomCards.map((card) => (
      <a href={card.href} class:list={['home-workbench__route-card', card.variant === 'accent' && 'is-accent']}>
        <span>{card.kicker}</span>
        <strong>{card.title}</strong>
        <small>{card.summary}</small>
      </a>
    ))}
  </div>
</section>
