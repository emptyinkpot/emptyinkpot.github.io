---
import type { HomeRouteCard } from '../../lib/home';
import HomeWorkbenchSectionLine from './HomeWorkbenchSectionLine.astro';
import HomeWorkbenchDeck from './HomeWorkbenchDeck.astro';

interface Props {
  topCards: HomeRouteCard[];
  bottomCards: HomeRouteCard[];
}

const { topCards, bottomCards } = Astro.props as Props;
---

<section class="home-workbench__routes">
  <HomeWorkbenchSectionLine leading="SECTION / SITE ROUTES" trailing="关于、搜索、更新与工具入口分层落位" />
  <HomeWorkbenchDeck items={topCards.map((card) => ({ ...card, summary: card.summary, variant: card.variant === 'accent' ? 'accent' : 'default' }))} columns={3} />
  <HomeWorkbenchDeck items={bottomCards.map((card) => ({ ...card, summary: card.summary, variant: card.variant === 'accent' ? 'accent' : 'default' }))} columns={2} />
</section>
