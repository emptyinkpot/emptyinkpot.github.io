---
import type { CollectionEntry } from 'astro:content';
import { formatDate, getExcerptFromBody, getPrimaryCategory, toSlug } from '../../lib/content';
import { withBase } from '../../lib/site';

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props as Props;
const excerpt = post.data.description ?? getExcerptFromBody(post.body, 118);
---

<article class="home-post-card h-full p-4 md:p-4">
  <div class="mb-4 flex items-center justify-between gap-4 text-[10px] uppercase tracking-[0.22em] text-[color:var(--home-accent)]">
    <a class="relative z-10 transition hover:text-stone-900" href={withBase(`/categories/${toSlug(getPrimaryCategory(post))}/`)}>
      {getPrimaryCategory(post)}
    </a>
    <span>{formatDate(post.data.date)}</span>
  </div>

  <div class="space-y-2">
    <h3 class="text-lg font-semibold leading-tight text-stone-900 md:text-[1.35rem]">
      <a class="stretched-link" href={withBase(`/posts/${post.id}/`)}>{post.data.title}</a>
    </h3>
    <p class="line-clamp-2 text-sm leading-6 text-stone-600">{excerpt}</p>
  </div>
</article>
