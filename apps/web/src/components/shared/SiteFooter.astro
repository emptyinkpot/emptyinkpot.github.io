---
import { withBase } from '../../lib/site';
---

<footer class="page-wrap pb-10 pt-8 text-sm text-stone-500">
  <div class="glass-card rounded-[2rem] px-6 py-5">
    <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div>
        <p class="text-sm font-medium text-stone-700">emptyinkpot</p>
        <p>面向长期写作、项目沉淀与持续维护记录的结构化内容站。</p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a class="footer-link" href="https://github.com/emptyinkpot/emptyinkpot.github.io" target="_blank" rel="noreferrer">
          GitHub
        </a>
        <a class="footer-link" href={withBase('/rss.xml')}>
          RSS
        </a>
        <a class="footer-link" href={withBase('/updates')}>
          Updates
        </a>
        <a class="footer-link" href="https://emptyinkpot.github.io/" target="_blank" rel="noreferrer">
          Current Site
        </a>
      </div>
    </div>
  </div>
