---
import { stripBase, withBase } from '../../lib/site';

const pathname = stripBase(Astro.url.pathname);
const navItems = [
  { href: '/', label: '首页' },
  { href: '/posts', label: '文章' },
  { href: '/series', label: '专题' },
  { href: '/projects', label: '项目' },
  { href: '/updates', label: '更新' },
  { href: '/search', label: '搜索' },
  { href: '/about', label: '关于' }
];
---

<header class="page-wrap pt-6 md:pt-8">
  <div class="glass-card flex flex-col gap-4 rounded-[2rem] px-5 py-4 md:flex-row md:items-center md:justify-between md:px-6">
    <a class="flex items-center gap-3 md:gap-4" href={withBase('/')}>
      <span class="flex h-14 w-14 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-[#050505] p-1.5 shadow-[0_10px_30px_rgba(0,0,0,0.18)] ring-1 ring-black/10 md:h-16 md:w-16 md:p-1.5">
        <img
          src={withBase('/images/branding/vita-atramenti-logo.png')}
          alt="Vita Atramenti logo"
          class="h-full w-full scale-[1.38] object-contain"
          loading="eager"
          decoding="async"
        />
      </span>
      <div class="min-w-0">
        <p class="text-xs uppercase tracking-[0.32em] text-stone-500">emptyinkpot</p>
        <p class="text-sm text-stone-700">结构化写作、项目记录与维护笔记</p>
      </div>
    </a>

    <nav class="flex flex-wrap items-center gap-2 text-sm text-stone-600">
      {
        navItems.map((item) => {
          const active =
            item.href === '/'
              ? pathname === '/'
              : pathname === item.href || pathname.startsWith(`${item.href}/`);

          return (
            <a
              href={withBase(item.href)}
              class:list={[
                'rounded-full px-4 py-2 transition',
                active ? 'bg-stone-900 text-stone-50 shadow-sm' : 'hover:bg-white/75 hover:text-stone-900'
              ]}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
