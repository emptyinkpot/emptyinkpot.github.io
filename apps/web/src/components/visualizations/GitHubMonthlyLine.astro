---
import { getLineChartPoints, type MonthlyPoint } from '../../lib/analytics';

interface Props {
  points: MonthlyPoint[];
  compact?: boolean;
}

const { points, compact = false } = Astro.props;
const width = 320;
const height = compact ? 92 : 128;
const polyline = getLineChartPoints(points, width, height);
---

<div
  class:list={['github-line-chart', compact && 'github-line-chart--compact']}
  data-github-viz="monthly-line"
  data-github-compact={compact ? 'true' : undefined}
>
  <svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label="GitHub monthly contribution line chart">
    <path d={`M0 ${height} H${width}`} />
    <polyline points={polyline} />
  </svg>
  <div class="github-line-chart__labels">
    {points.map((point) => (
      <span>
        <strong>{point.value}</strong>
        <small>{point.label}</small>
      </span>
    ))}
  </div>
</div>
