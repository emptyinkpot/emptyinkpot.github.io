---
import { formatDate } from '../../lib/content';
import type { RepoMatrixItem } from '../../lib/analytics';

interface Props {
  repos: RepoMatrixItem[];
  compact?: boolean;
}

const { repos, compact = false } = Astro.props;
---

<div class:list={['github-repo-matrix', compact && 'github-repo-matrix--compact']}>
  {repos.map((repo) => (
    <a class="github-repo-matrix__item" href={repo.htmlUrl}>
      <strong>{repo.name}</strong>
      <span>{repo.language || 'Unknown'} / {repo.stars} stars / {repo.issues} issues</span>
      <small>{formatDate(new Date(repo.updatedAt))}</small>
    </a>
  ))}
</div>
