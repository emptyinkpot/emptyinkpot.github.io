---
import type { HomeBook } from '../../data/books';
import BookCover from './BookCover.astro';

interface Props {
  book: HomeBook;
  compact?: boolean;
}

const { book, compact = false } = Astro.props;
const href = book.href ?? '/books/';
---

<a class:list={['showcase-card', compact && 'showcase-card--compact']} href={href}>
  <BookCover title={book.title} cover={book.cover} />
  <div>
    <span>书架 / {book.statusLabel}</span>
    <strong>{book.title}</strong>
    <small>{book.author}</small>
    <p>{book.note}</p>
  </div>
</a>
