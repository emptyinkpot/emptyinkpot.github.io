---
import type { MusicItem } from '../../data/music';
import AlbumCover from './AlbumCover.astro';

interface Props {
  item: MusicItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;
const href = item.href ?? '/music/';
---

<a class:list={['showcase-card', 'showcase-card--music', compact && 'showcase-card--compact']} href={href}>
  <AlbumCover title={item.title} cover={item.cover} />
  <div>
    <span>音乐 / {item.platform}</span>
    <strong>{item.title}</strong>
    <small>{item.artist}{item.album ? ` / ${item.album}` : ''}</small>
    <p>{item.note}</p>
    <div class="showcase-card__tags">
      {item.mood.map((tag) => <em>{tag}</em>)}
    </div>
  </div>
</a>
