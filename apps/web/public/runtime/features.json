{
  "schemaVersion": 1,
  "updatedAt": "2026-05-07",
  "thesis": "Runtime features declare authority before UI. MyBlog projections read explicit runtime registries instead of guessing from scattered routes.",
  "features": {
    "markdownRuntime": {
      "enabled": true,
      "authority": "obsidian-vault",
      "truth": "E:\\Vaults\\Obsidian",
      "producer": "tools/build-runtime-content-index.mjs",
      "consumers": [
        "apps/web/src/pages/index.astro",
        "apps/web/src/pages/posts/index.astro",
        "apps/web/src/pages/posts/[slug].astro",
        "apps/web/src/pages/categories/[slug].astro",
        "apps/web/src/pages/tags/[slug].astro",
        "apps/web/src/pages/series/[slug].astro",
        "apps/web/src/pages/rss.xml.ts",
        "apps/web/src/pages/data/knowledge-index.json.ts"
      ],
      "projection": ["feed", "reader", "search", "graph"]
    },
    "runtimeBooks": {
      "enabled": true,
      "authority": "obsidian-vault",
      "truth": "E:\\Vaults\\Obsidian\\docs\\books\\original",
      "producer": "apps/admin-next OpenList gateway and cover cache",
      "consumers": [
        "apps/web/src/pages/books/index.astro",
        "apps/web/src/pages/books/[id].astro",
        "apps/web/src/pages/reader/[id].astro"
      ],
      "projection": ["bookshelf", "reader", "home-drawer"]
    },
    "readerRuntime": {
      "enabled": true,
      "authority": "mysql/admin-next",
      "truth": "reader_memory and reader_highlights tables",
      "producer": "apps/admin-next Runtime API",
      "consumers": [
        "apps/web/src/components/books/BookReader.tsx",
        "apps/web/src/pages/index.astro"
      ],
      "projection": ["memory", "highlights", "annotations"]
    }
  }
}
