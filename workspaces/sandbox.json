{
  "schemaVersion": 1,
  "workspaceType": "sandbox",
  "description": "Disposable prototype workspace. It may test ideas, but any production change must be promoted through a workspace with the required capability.",
  "capabilities": {
    "canBuild": false,
    "canDeploy": false,
    "canModifyRuntime": false,
    "canTouchPWA": false,
    "canModifyRuntimeSchema": false,
    "canModifyOpenListAuthority": false
  },
  "deploymentAuthority": false,
  "allowedFeatures": [
    "prototype",
    "research",
    "throwaway-demo"
  ],
  "forbiddenFeatures": [
    "deployment",
    "pwa",
    "runtime-books",
    "runtime-schema",
    "openlist-authority",
    "server-runtime",
    "production-content"
  ]
}
