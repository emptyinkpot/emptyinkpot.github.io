{
  "projectName": "MyBlog Quartz",
  "canonicalDoc": "README.md",
  "githubRepo": "https://github.com/emptyinkpot/emptyinkpot.github.io",
  "defaultBranch": "main",
  "framework": {
    "name": "Quartz",
    "status": "primary",
    "upstream": "https://github.com/jackyzha0/quartz",
    "branch": "v4",
    "commit": "d25a6eabf96751ffca56f8a8139272def7a65041"
  },
  "myblogIntegration": {
    "status": "plugin-layer",
    "rule": "Quartz is the repository shape and primary framework; MyBlog behavior enters through Quartz plugins, layout, configuration, and content sync.",
    "plugin": "quartz/plugins/transformers/myblogStyle.ts",
    "contentSync": "quartz/myblog/sync-content.mjs",
    "contentRoot": "content",
    "buildOutputRoot": "apps/web/dist"
  },
  "contentTruth": {
    "authoringTruthRoot": "Windows:E:\\Vaults\\Obsidian",
    "serverHotMirrorRoot": "Linux:/home/vault/Obsidian",
    "publicContentAccessRoot": "/openlist/Obsidian",
    "defaultDocsRoot": "E:/Vaults/Obsidian/docs",
    "linuxDocsRoot": "/home/vault/Obsidian/docs"
  },
  "commands": {
    "sync": "npm run myblog:sync",
    "build": "npm run build",
    "dev": "npm run dev",
    "check": "npm run check"
  }
}
